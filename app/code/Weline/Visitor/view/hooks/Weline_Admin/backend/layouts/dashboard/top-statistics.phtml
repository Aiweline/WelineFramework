<?php
/**
 * 后台首页顶部统计卡片 Hook 实现
 *
 * Hook 名称：Weline_Admin::backend::layouts::dashboard::top-statistics
 *
 * 功能：
 * - 在 Admin 后台首页顶部展示真实的访客像素统计汇总数据
 * - 使用 Weline_Visitor 的 PixelStatisticsService 聚合所有站点数据
 *
 * @hook-priority 150
 * @hook-sort-order 0
 * @hook-solo false
 */

/** @var \Weline\Framework\View\Template $this */

use Weline\Visitor\Service\PixelStatisticsService;

try {
    $overview      = PixelStatisticsService::getGlobalDashboardOverview();
    $stats         = $overview['stats'] ?? [];
    $websiteIds    = $overview['website_ids'] ?? [];

    $totalCount    = (int)($stats['total_count']   ?? 0);
    $dealedCount   = (int)($stats['dealed_count']  ?? 0);
    $unDealCount   = (int)($stats['un_deal_count'] ?? 0);
    $totalValue    = (float)($stats['total_value'] ?? 0);
    $siteCount     = is_array($websiteIds) ? count($websiteIds) : 0;

    $dealRate      = $totalCount > 0 ? round($dealedCount * 100 / $totalCount, 2) : 0.0;
} catch (\Throwable $e) {
    // 失败时不影响后台首页其他内容，直接回退到默认实现
    return;
}
?>
