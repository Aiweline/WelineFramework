<?php
/**
 * Global storefront visitor pixel bootstrap.
 *
 * Hook: Weline_Theme::frontend::layouts::base::body-end
 * @hook-priority 120
 * @hook-sort-order 50
 * @hook-solo false
 */
?>
<?php
$__pixel_name = 'weshop_storefront_behavior';
$__tp = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Framework\View\Template::class);
$__data = new \Weline\Framework\DataObject\DataObject([
    'pixel_code' => '',
    'name' => $__pixel_name,
    'enable' => 1,
]);
$__event = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Framework\Event\EventsManager::class);
$__event->dispatch('Weline_Visitor::taglib_pixel', $__data);

if (!empty($__data->getData('enable'))) {
    $__tp->assign('pixel_code', str_ireplace('</script>', '<\/script>', (string)$__data->getData('pixel_code')));
    $__js = $__tp->fetch('Weline_Visitor::taglib/js/pixel.phtml');
    echo str_replace('{:name}', htmlspecialchars($__pixel_name, ENT_QUOTES, 'UTF-8'), $__js);
}
?>
