<?php
/**
 * Global storefront visitor pixel bootstrap.
 *
 * Hook: Weline_Theme::frontend::layouts::base::body-end
 * @hook-priority 120
 * @hook-sort-order 50
 * @hook-solo false
 */
?>
<?php
$__request_path_raw = (string)($this->request->getPathInfo() ?: \w_env_request_uri());
$__request_path_parsed = parse_url($__request_path_raw, PHP_URL_PATH);
$__request_path = strtolower((string)(is_string($__request_path_parsed) && $__request_path_parsed !== '' ? $__request_path_parsed : $__request_path_raw));
if ($__request_path === '/customer/account'
    || $__request_path === 'customer/account'
    || str_contains($__request_path, '/customer/account/')
) {
    return;
}

$__visitor_tracking_config = [
    'module' => 'Weline_Visitor',
    'pixel' => ['enabled' => true],
    'hotBuffer' => [
        'enabled' => true,
        'flushInterval' => 15,
        'batchSize' => 500,
        'ttl' => 300,
        'source' => 'Weline_Visitor default',
    ],
    'consent' => [
        'enabled' => false,
        'source' => 'Weline_Visitor default',
    ],
    'trafficRules' => [
        'source' => 'Weline_Visitor default',
        'excludeLocalForwarding' => true,
        'excludedHosts' => [],
        'excludedPathPrefixes' => [],
        'excludedQueryKeys' => [],
        'excludedReferrerHosts' => [],
        'excludedUserAgentKeywords' => [],
    ],
    'ga4' => [
        'enabled' => false,
        'configured' => false,
        'measurementId' => '',
        'enableInDev' => false,
        'autoTrackVisitorEvents' => true,
        'ctaEventName' => 'cta_click',
        'debugMode' => false,
        'source' => 'Weline_Visitor default',
    ],
    'forwarders' => [
        'eventBus' => ['enabled' => true, 'contractVersion' => 'weline-visitor-event/v1'],
        'ga4' => ['enabled' => false, 'configured' => false, 'measurementId' => '', 'autoTrackVisitorEvents' => true],
        'custom' => ['enabled' => false, 'script' => ''],
    ],
];
try {
    $__visitor_tracking_config = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Visitor\Service\VisitorTrackingConfig::class)
        ->getRuntimeConfig();
} catch (\Throwable $throwable) {
    if (defined('DEV') && DEV) {
        w_log_error('读取 Visitor 前台统计配置失败: ' . $throwable->getMessage());
    }
}
$__visitor_pixel_enabled = !empty($__visitor_tracking_config['pixel']['enabled']);
$__visitor_ga4_enabled = !empty($__visitor_tracking_config['ga4']['enabled']);
$__visitor_panel_enabled = false;
try {
    $__visitor_panel_enabled = \Weline\Framework\Manager\ObjectManager::getInstance(
        \Weline\Framework\Runtime\DeveloperAccessPolicy::class
    )->shouldInjectBootstrap();
} catch (\Throwable) {
    $__visitor_panel_enabled = false;
}

$__pixel_name = 'weshop_storefront_behavior';
$__data = new \Weline\Framework\DataObject\DataObject([
    'pixel_code' => '',
    'name' => $__pixel_name,
    'enable' => $__visitor_pixel_enabled ? 1 : 0,
]);
$__event = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Framework\Event\EventsManager::class);
$__event->dispatch('Weline_Visitor::taglib_pixel', $__data);
$__visitor_pixel_enabled = $__visitor_pixel_enabled && !empty($__data->getData('enable'));

$__visitor_tracking_config['pixel']['enabled'] = $__visitor_pixel_enabled;
$__visitor_tracking_json = json_encode(
    $__visitor_tracking_config,
    JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP
);
if ($__visitor_tracking_json === false) {
    $__visitor_tracking_json = '{}';
}

if ($__visitor_pixel_enabled || $__visitor_ga4_enabled || $__visitor_panel_enabled) {
    $__pixel_script_url = '@static(Weline_Visitor::js/pixel.js)?v=20260702-visitor-forwarder-traffic-2';
    $__visitor_panel_script_url = '@static(Weline_Visitor::js/weline-panel-visitor.js)?v=20260702-visitor-panel-events-2';
    ?>
<script>
(function () {
    'use strict';

    var visitorTrackingConfig = <?= $__visitor_tracking_json ?>;
    var shouldLoadPixel = <?= ($__visitor_pixel_enabled || $__visitor_ga4_enabled) ? 'true' : 'false' ?>;
    window.__WelineVisitorTrackingConfig = visitorTrackingConfig;
    window.__SITE_GA4__ = Object.assign({}, window.__SITE_GA4__ || {}, visitorTrackingConfig.ga4 || {}, {
        source: (visitorTrackingConfig.ga4 && visitorTrackingConfig.ga4.source) || 'Weline_Visitor SystemConfig'
    });
    try {
        window.dispatchEvent(new CustomEvent('weline:visitor-tracking-config', { detail: visitorTrackingConfig }));
    } catch (error) {
    }

    if (!shouldLoadPixel) {
        return;
    }

    if (window.__WelinePixelLazyScheduled) {
        return;
    }
    window.__WelinePixelLazyScheduled = true;

    function loadWelinePixel() {
        if (window.__WelinePixelLazyLoaded || window.__WelinePixelLoaded) {
            return;
        }

        window.__WelinePixelLazyLoaded = true;
        window.__WelinePixelName = '<?= htmlspecialchars($__pixel_name, ENT_QUOTES, 'UTF-8') ?>';
        var script = document.createElement('script');
        script.src = '<?= $__pixel_script_url ?>';
        script.async = true;
        document.head.appendChild(script);
    }

    function scheduleWelinePixel() {
        window.setTimeout(function () {
            if ('requestIdleCallback' in window) {
                window.requestIdleCallback(loadWelinePixel, { timeout: 8000 });
                return;
            }
            window.setTimeout(loadWelinePixel, 1000);
        }, 3500);
    }

    window.__WelineLoadPixel = loadWelinePixel;
    if (document.readyState === 'complete') {
        scheduleWelinePixel();
    } else {
        window.addEventListener('load', scheduleWelinePixel, { once: true });
    }
})();
</script>
<?php
}

if ($__visitor_panel_enabled) {
    ?>
<script src="<?= $__visitor_panel_script_url ?? '@static(Weline_Visitor::js/weline-panel-visitor.js)?v=20260701-visitor-panel-5' ?>"
        data-no-extract="true"
        data-load-order="last"
        data-weline-panel-visitor-bootstrap="true"></script>
<?php
}
?>
