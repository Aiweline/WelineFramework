<?php
/**
 * Global storefront visitor pixel bootstrap.
 *
 * Hook: Weline_Theme::frontend::layouts::base::body-end
 * @hook-priority 120
 * @hook-sort-order 50
 * @hook-solo false
 */
?>
<?php
$__request_path_raw = (string)($this->request->getPathInfo() ?: \w_env_request_uri());
$__request_path_parsed = parse_url($__request_path_raw, PHP_URL_PATH);
$__request_path = strtolower((string)(is_string($__request_path_parsed) && $__request_path_parsed !== '' ? $__request_path_parsed : $__request_path_raw));
if ($__request_path === '/customer/account'
    || $__request_path === 'customer/account'
    || str_contains($__request_path, '/customer/account/')
) {
    return;
}

$__pixel_name = 'weshop_storefront_behavior';
$__data = new \Weline\Framework\DataObject\DataObject([
    'pixel_code' => '',
    'name' => $__pixel_name,
    'enable' => 1,
]);
$__event = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Framework\Event\EventsManager::class);
$__event->dispatch('Weline_Visitor::taglib_pixel', $__data);

if (!empty($__data->getData('enable'))) {
    $__pixel_script_url = '@static(Weline_Visitor::js/pixel.js)?v=20260521-static-1';
    $__pixel_custom_code = str_ireplace('</script>', '<\/script>', (string)$__data->getData('pixel_code'));
    $__pixel_custom_code_json = json_encode(
        $__pixel_custom_code,
        JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT
    );
    ?>
<script>
(function () {
    'use strict';

    if (window.__WelinePixelLazyScheduled) {
        return;
    }
    window.__WelinePixelLazyScheduled = true;

    function loadWelinePixel() {
        if (window.__WelinePixelLazyLoaded || window.__WelinePixelLoaded) {
            return;
        }

        window.__WelinePixelLazyLoaded = true;
        window.__WelinePixelName = '<?= htmlspecialchars($__pixel_name, ENT_QUOTES, 'UTF-8') ?>';
        window.__WelinePixelCustomCode = <?= $__pixel_custom_code_json ?: "''" ?>;
        var script = document.createElement('script');
        script.src = '<?= $__pixel_script_url ?>';
        script.async = true;
        document.head.appendChild(script);
    }

    function scheduleWelinePixel() {
        window.setTimeout(function () {
            if ('requestIdleCallback' in window) {
                window.requestIdleCallback(loadWelinePixel, { timeout: 8000 });
                return;
            }
            window.setTimeout(loadWelinePixel, 1000);
        }, 3500);
    }

    window.__WelineLoadPixel = loadWelinePixel;
    if (document.readyState === 'complete') {
        scheduleWelinePixel();
    } else {
        window.addEventListener('load', scheduleWelinePixel, { once: true });
    }
})();
</script>
<?php
}
?>
