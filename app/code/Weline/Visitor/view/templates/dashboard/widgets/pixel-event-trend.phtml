<?php
/**
 * Dashboard Widget: 像素事件趋势
 */
$service = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Visitor\Service\PixelDashboardWidgetData::class);
$config = [
    'range' => $this->getData('range') ?: '7d',
    'website_id' => $this->getData('website_id') ?: '',
];
$dashboard = $service->getDashboard($config);
$trend = is_array($dashboard['trend'] ?? null) ? $dashboard['trend'] : [];
$filters = is_array($dashboard['filters'] ?? null) ? $dashboard['filters'] : [];
$range = (string)($filters['range'] ?? $config['range']);
$max = 1;
foreach ($trend as $row) {
    $max = max($max, (int)($row['count'] ?? 0));
}
$h = static fn($value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
?>
<section class="dashboard-widget dashboard-widget-pixel dashboard-widget-pixel-trend">
    <header>
        <h3><?= __('像素事件趋势') ?></h3>
        <span><?= $h($service->rangeLabel($range)) ?></span>
    </header>
    <?php if ($trend === []): ?>
        <div class="pixel-empty"><?= __('当前范围暂无像素事件') ?></div>
    <?php else: ?>
        <div class="pixel-trend-bars">
            <?php foreach ($trend as $row): ?>
                <?php
                $count = (int)($row['count'] ?? 0);
                $height = max(4, min(100, (int)round(($count / $max) * 100)));
                $label = substr((string)($row['date'] ?? ''), 5) ?: '-';
                ?>
                <div title="<?= $h(__('事件 %{1}', [$count])) ?>">
                    <i style="height: <?= (int)$height ?>%"></i>
                    <strong><?= $h($service->formatNumber($count)) ?></strong>
                    <span><?= $h($label) ?></span>
                </div>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</section>
<style>
.dashboard-widget-pixel-trend {
    min-height: 230px;
}
.pixel-trend-bars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(34px, 1fr));
    gap: 8px;
    height: 180px;
    align-items: end;
}
.pixel-trend-bars div {
    min-width: 0;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 5px;
    text-align: center;
}
.pixel-trend-bars i {
    display: block;
    width: 100%;
    min-height: 12px;
    border-radius: 6px 6px 3px 3px;
    background: linear-gradient(180deg, #06b6d4 0%, #2563eb 100%);
}
.pixel-trend-bars strong {
    color: var(--w-dashboard-heading, #1f2937);
    font-size: 11px;
    line-height: 1;
    overflow-wrap: anywhere;
}
.pixel-trend-bars span,
.pixel-empty {
    color: var(--w-dashboard-muted, #6b7280);
    font-size: 12px;
    line-height: 1.2;
}
.pixel-empty {
    min-height: 150px;
    display: grid;
    place-items: center;
    border: 1px dashed var(--w-dashboard-border, #e5e7eb);
    border-radius: 8px;
}
</style>
