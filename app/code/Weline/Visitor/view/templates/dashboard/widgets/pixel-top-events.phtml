<?php
/**
 * Dashboard Widget: 热门像素事件
 */
$service = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Visitor\Service\PixelDashboardWidgetData::class);
$config = [
    'range' => $this->getData('range') ?: '7d',
    'website_id' => $this->getData('website_id') ?: '',
];
$dashboard = $service->getDashboard($config);
$rows = array_slice(is_array($dashboard['event_rows'] ?? null) ? $dashboard['event_rows'] : [], 0, 6);
$filters = is_array($dashboard['filters'] ?? null) ? $dashboard['filters'] : [];
$range = (string)($filters['range'] ?? $config['range']);
$max = 1;
foreach ($rows as $row) {
    $max = max($max, (int)($row['count'] ?? 0));
}
$h = static fn($value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
?>
<section class="dashboard-widget dashboard-widget-pixel dashboard-widget-pixel-events">
    <header>
        <h3><?= __('热门像素事件') ?></h3>
        <span><?= $h($service->rangeLabel($range)) ?></span>
    </header>
    <?php if ($rows === []): ?>
        <div class="pixel-empty compact"><?= __('当前范围暂无事件') ?></div>
    <?php else: ?>
        <table>
            <tbody>
            <?php foreach ($rows as $row): ?>
                <?php
                $count = (int)($row['count'] ?? 0);
                $share = (float)($row['share'] ?? 0);
                $width = max(3, min(100, (int)round(($count / $max) * 100)));
                ?>
                <tr>
                    <th>
                        <strong><?= $h($row['event'] ?? '-') ?></strong>
                        <span><?= $h(__('访客 %{1}', [$service->formatNumber($row['active_users'] ?? 0)])) ?></span>
                    </th>
                    <td>
                        <div class="pixel-event-count"><?= $h($service->formatNumber($count)) ?></div>
                        <div class="pixel-progress"><span style="width: <?= (int)$width ?>%"></span></div>
                    </td>
                    <td><?= $h($service->formatPercent($share)) ?></td>
                </tr>
            <?php endforeach; ?>
            </tbody>
        </table>
    <?php endif; ?>
</section>
<style>
.dashboard-widget-pixel-events table {
    width: 100%;
    border-collapse: collapse;
}
.dashboard-widget-pixel-events th,
.dashboard-widget-pixel-events td {
    padding: 9px 0;
    border-bottom: 1px solid var(--w-dashboard-border, #e5e7eb);
    vertical-align: middle;
}
.dashboard-widget-pixel-events tr:last-child th,
.dashboard-widget-pixel-events tr:last-child td {
    border-bottom: 0;
}
.dashboard-widget-pixel-events th {
    width: 42%;
    padding-right: 12px;
    text-align: left;
}
.dashboard-widget-pixel-events th strong {
    display: block;
    color: var(--w-dashboard-heading, #1f2937);
    font-size: 13px;
    line-height: 1.25;
    overflow-wrap: anywhere;
}
.dashboard-widget-pixel-events th span,
.dashboard-widget-pixel-events td {
    color: var(--w-dashboard-muted, #6b7280);
    font-size: 12px;
}
.pixel-event-count {
    margin-bottom: 5px;
    color: var(--w-dashboard-heading, #1f2937);
    font-weight: 700;
}
.pixel-progress {
    height: 7px;
    border-radius: 999px;
    background: var(--w-dashboard-surface-soft, #f8fafc);
    overflow: hidden;
}
.pixel-progress span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: #14b8a6;
}
.pixel-empty.compact {
    min-height: 110px;
}
</style>
