<?php
/**
 * Dashboard Widget: 像素实时动向
 */
$service = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Visitor\Service\PixelDashboardWidgetData::class);
$config = [
    'range' => 'today',
    'website_id' => $this->getData('website_id') ?: '',
];
$dashboard = $service->getDashboard($config);
$rows = is_array($dashboard['realtime_rows'] ?? null) ? $dashboard['realtime_rows'] : [];
$recent = array_slice(is_array($dashboard['recent_events'] ?? null) ? $dashboard['recent_events'] : [], 0, 3);
$max = 1;
$total = 0;
foreach ($rows as $row) {
    $count = (int)($row['count'] ?? 0);
    $total += $count;
    $max = max($max, $count);
}
$h = static fn($value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
?>
<section class="dashboard-widget dashboard-widget-pixel dashboard-widget-pixel-realtime">
    <header>
        <h3><?= __('像素实时动向') ?></h3>
        <span><?= __('最近 1 小时') ?></span>
    </header>
    <div class="pixel-realtime-total">
        <strong><?= $h($service->formatNumber($total)) ?></strong>
        <span><?= __('事件触发') ?></span>
    </div>
    <div class="pixel-realtime-bars">
        <?php foreach ($rows as $row): ?>
            <?php
            $count = (int)($row['count'] ?? 0);
            $height = max(6, min(100, (int)round(($count / $max) * 100)));
            $time = substr((string)($row['timestamp'] ?? ''), 11, 5) ?: '-';
            ?>
            <div title="<?= $h(__('事件 %{1}', [$count])) ?>">
                <i style="height: <?= (int)$height ?>%"></i>
                <span><?= $h($time) ?></span>
            </div>
        <?php endforeach; ?>
    </div>
    <?php if ($recent !== []): ?>
        <ul class="pixel-recent-list">
            <?php foreach ($recent as $event): ?>
                <li>
                    <strong><?= $h($event['event'] ?? '-') ?></strong>
                    <span><?= $h(substr((string)($event['created_at'] ?? ''), 11, 5)) ?></span>
                </li>
            <?php endforeach; ?>
        </ul>
    <?php endif; ?>
</section>
