<?php
/**
 * Dashboard Widget: 像素概览
 */
$service = \Weline\Framework\Manager\ObjectManager::getInstance(\Weline\Visitor\Service\PixelDashboardWidgetData::class);
$config = [
    'range' => $this->getData('range') ?: '7d',
    'website_id' => $this->getData('website_id') ?: '',
];
$dashboard = $service->getDashboard($config);
$summary = is_array($dashboard['summary'] ?? null) ? $dashboard['summary'] : [];
$filters = is_array($dashboard['filters'] ?? null) ? $dashboard['filters'] : [];
$range = (string)($filters['range'] ?? $config['range']);
$siteLabel = !empty($filters['website_id'])
    ? __('站点 #%{1}', [(int)$filters['website_id']])
    : __('全部站点');
$items = [
    ['label' => __('事件'), 'value' => $service->formatNumber($summary['total_events'] ?? 0), 'hint' => $service->rangeLabel($range)],
    ['label' => __('访客'), 'value' => $service->formatNumber($summary['active_users'] ?? 0), 'hint' => __('按 IP 去重')],
    ['label' => __('类型'), 'value' => $service->formatNumber($summary['event_types'] ?? 0), 'hint' => __('事件种类')],
    ['label' => __('处理率'), 'value' => $service->formatPercent($summary['processed_rate'] ?? 0), 'hint' => __('Cron 处理')],
];
$change = (float)($summary['event_change'] ?? 0);
$changeClass = $change >= 0 ? 'positive' : 'negative';
$h = static fn($value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
?>
<section class="dashboard-widget dashboard-widget-pixel dashboard-widget-pixel-overview">
    <header>
        <h3><?= __('像素概览') ?></h3>
        <span><?= $h($siteLabel) ?></span>
    </header>
    <div class="pixel-overview-grid">
        <?php foreach ($items as $item): ?>
            <div>
                <strong><?= $h($item['value']) ?></strong>
                <span><?= $h($item['label']) ?></span>
                <small><?= $h($item['hint']) ?></small>
            </div>
        <?php endforeach; ?>
    </div>
    <footer class="pixel-widget-foot">
        <span class="<?= $h($changeClass) ?>"><?= $h($service->formatPercent($change)) ?></span>
        <small><?= __('较上一周期') ?></small>
    </footer>
</section>
