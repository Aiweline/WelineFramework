    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
}
.pixel-overview-grid div {
    min-width: 0;
    border-radius: 6px;
    background: var(--w-dashboard-surface-soft, #f8fafc);
    padding: 12px 8px;
    text-align: center;
}
.pixel-overview-grid strong {
    display: block;
    color: var(--bs-primary, #2563eb);
    font-size: 22px;
    line-height: 1;
    overflow-wrap: anywhere;
}
.pixel-overview-grid span {
    display: block;
    margin-top: 7px;
    font-size: 13px;
    line-height: 1.25;
}
.pixel-overview-grid small {
    display: block;
    margin-top: 3px;
    color: var(--w-dashboard-muted, #6b7280);
    font-size: 12px;
    line-height: 1.25;
}
.pixel-widget-foot {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--w-dashboard-muted, #6b7280);
    font-size: 12px;
}
