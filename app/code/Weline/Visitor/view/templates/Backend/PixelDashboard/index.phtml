<script>
// 趋势图表（支持双Y轴：记录数和价值）
const trendCtx = document.getElementById('trendChart');
if (trendCtx) {
    const trendData = <?= json_encode($trends) ?>;
    new Chart(trendCtx, {
        type: 'line',
        data: {
            labels: trendData.map(item => item.date),
            datasets: [{
                label: '<?= __('记录数') ?>',
                data: trendData.map(item => item.count || 0),
                borderColor: 'rgb(102, 126, 234)',
                backgroundColor: 'rgba(102, 126, 234, 0.1)',
                tension: 0.4,
                fill: true,
                yAxisID: 'y'
            }, {
                label: '<?= __('价值') ?>',
                data: trendData.map(item => item.value || 0),
                borderColor: 'rgb(17, 153, 142)',
                backgroundColor: 'rgba(17, 153, 142, 0.1)',
                tension: 0.4,
                fill: true,
                yAxisID: 'y1'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    display: true
                }
            },
            scales: {
                y: {
                    type: 'linear',
                    display: true,
                    position: 'left',
                    beginAtZero: true,
                    title: {
                        display: true,
                        text: '<?= __('记录数') ?>'
                    }
                },
                y1: {
                    type: 'linear',
                    display: true,
                    position: 'right',
                    beginAtZero: true,
                    grid: {
                        drawOnChartArea: false
                    },
                    title: {
                        display: true,
                        text: '<?= __('价值') ?>'
                    }
                }
            }
        }
    });
}

// 事件分布饼图
const eventDistributionCtx = document.getElementById('eventDistributionChart');
if (eventDistributionCtx) {
    const topEvents = <?= json_encode($top_events ?? []) ?>;
    const eventLabels = Object.keys(topEvents);
    const eventData = Object.values(topEvents);
    
    new Chart(eventDistributionCtx, {
        type: 'pie',
        data: {
            labels: eventLabels,
            datasets: [{
                data: eventData,
                backgroundColor: [
                    'rgba(102, 126, 234, 0.8)',
                    'rgba(17, 153, 142, 0.8)',
                    'rgba(240, 147, 251, 0.8)',
                    'rgba(79, 172, 254, 0.8)',
                    'rgba(255, 99, 132, 0.8)',
                    'rgba(54, 162, 235, 0.8)',
                    'rgba(255, 206, 86, 0.8)',
                    'rgba(75, 192, 192, 0.8)',
                    'rgba(153, 102, 255, 0.8)',
                    'rgba(255, 159, 64, 0.8)'
                ]
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    display: true,
                    position: 'bottom'
                }
            }
        }
    });
}

// 实时数据刷新
let autoRefreshInterval = null;

function refreshData() {
    // 刷新实时数据
    const websiteIds = <?= json_encode($websiteIds ?? []) ?>;
    if (websiteIds.length > 0) {
        const firstWebsiteId = websiteIds[0];
        fetch('<?= $this->getUrl("*/pixel_dashboard/getRealtimeData") ?>?websiteId=' + firstWebsiteId + '&interval=10&hours=24')
            .then(response => response.json())
            .then(data => {
                if (data.code === 200 && data.data) {
                    // 更新实时数据
                    if (data.data.current_period) {
                        // 可以在这里更新实时数据卡片
                        console.log('实时数据已更新', data.data);
                    }
                }
            })
            .catch(error => {
                console.error('刷新数据失败:', error);
            });
    }
}

function toggleAutoRefresh() {
    const checkbox = document.getElementById('autoRefresh');
    if (checkbox.checked) {
        // 开启自动刷新，每30秒刷新一次
        autoRefreshInterval = setInterval(refreshData, 30000);
    } else {
        // 关闭自动刷新
        if (autoRefreshInterval) {
            clearInterval(autoRefreshInterval);
            autoRefreshInterval = null;
        }
    }
}

function exportData() {
    const websiteIds = <?= json_encode($websiteIds ?? []) ?>;
    const websiteId = websiteIds.length > 0 ? websiteIds[0] : 0;
    const url = '<?= $this->getUrl("*/pixel_dashboard/export") ?>?websiteId=' + websiteId + '&format=csv';
    window.open(url, '_blank');
}

function viewWebsiteDetail(websiteId) {
    // 跳转到站点详情页面
    window.location.href = '<?= $this->getUrl("*/pixel_dashboard/detail") ?>?websiteId=' + websiteId;
}

// 页面加载完成后初始化
document.addEventListener('DOMContentLoaded', function() {
    // 检查是否需要自动刷新
    const autoRefreshCheckbox = document.getElementById('autoRefresh');
    if (autoRefreshCheckbox && autoRefreshCheckbox.checked) {
        toggleAutoRefresh();
    }
});
</script>

