<script>
(function() {
    'use strict';
    
    var trends = <?= json_encode($trends) ?>;
    var topEvents = <?= json_encode($top_events ?? []) ?>;
    var websiteIds = <?= json_encode($websiteIds ?? []) ?>;
    var autoRefreshInterval = null;
    
    // 趋势图表
    var trendCtx = document.getElementById('trendChart');
    if (trendCtx) {
        new Chart(trendCtx, {
            type: 'line',
            data: {
                labels: trends.map(function(item) { return item.date; }),
                datasets: [{
                    label: '<?= __('记录数') ?>',
                    data: trends.map(function(item) { return item.count || 0; }),
                    borderColor: 'rgb(102, 126, 234)',
                    backgroundColor: 'rgba(102, 126, 234, 0.1)',
                    tension: 0.4,
                    fill: true,
                    yAxisID: 'y'
                }, {
                    label: '<?= __('价值') ?>',
                    data: trends.map(function(item) { return item.value || 0; }),
                    borderColor: 'rgb(17, 153, 142)',
                    backgroundColor: 'rgba(17, 153, 142, 0.1)',
                    tension: 0.4,
                    fill: true,
                    yAxisID: 'y1'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { display: true }
                },
                scales: {
                    y: {
                        type: 'linear',
                        display: true,
                        position: 'left',
                        beginAtZero: true,
                        title: { display: true, text: '<?= __('记录数') ?>' }
                    },
                    y1: {
                        type: 'linear',
                        display: true,
                        position: 'right',
                        beginAtZero: true,
                        grid: { drawOnChartArea: false },
                        title: { display: true, text: '<?= __('价值') ?>' }
                    }
                }
            }
        });
    }

    // 事件分布饼图
    var eventDistributionCtx = document.getElementById('eventDistributionChart');
    if (eventDistributionCtx) {
        var eventLabels = Object.keys(topEvents);
        var eventData = Object.values(topEvents);
        
        new Chart(eventDistributionCtx, {
            type: 'pie',
            data: {
                labels: eventLabels,
                datasets: [{
                    data: eventData,
                    backgroundColor: [
                        'rgba(102, 126, 234, 0.8)',
                        'rgba(17, 153, 142, 0.8)',
                        'rgba(240, 147, 251, 0.8)',
                        'rgba(79, 172, 254, 0.8)',
                        'rgba(255, 99, 132, 0.8)',
                        'rgba(54, 162, 235, 0.8)',
                        'rgba(255, 206, 86, 0.8)',
                        'rgba(75, 192, 192, 0.8)',
                        'rgba(153, 102, 255, 0.8)',
                        'rgba(255, 159, 64, 0.8)'
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { display: true, position: 'bottom' }
                }
            }
        });
    }

    function refreshData() {
        if (websiteIds.length > 0) {
            var firstWebsiteId = websiteIds[0];
            fetch('<?= $this->getUrl("*/pixel_dashboard/getRealtimeData") ?>?websiteId=' + firstWebsiteId + '&interval=10&hours=24')
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.code === 200 && data.data) {
                        console.log('实时数据已更新', data.data);
                    }
                })
                .catch(function(error) {
                    console.error('刷新数据失败:', error);
                });
        }
    }

    function toggleAutoRefresh() {
        var checkbox = document.getElementById('autoRefresh');
        if (checkbox.checked) {
            autoRefreshInterval = setInterval(refreshData, 30000);
        } else {
            if (autoRefreshInterval) {
                clearInterval(autoRefreshInterval);
                autoRefreshInterval = null;
            }
        }
    }

    function exportData() {
        var websiteId = websiteIds.length > 0 ? websiteIds[0] : 0;
        var url = '<?= $this->getUrl("*/pixel_dashboard/export") ?>?websiteId=' + websiteId + '&format=csv';
        window.open(url, '_blank');
    }

    // 绑定事件
    document.getElementById('refreshPixelData').addEventListener('click', refreshData);
    document.getElementById('exportPixelData').addEventListener('click', exportData);
    document.getElementById('autoRefresh').addEventListener('change', toggleAutoRefresh);
})();
</script>
