/**
 * 多站点像素事件监听看板
 *
 * @var \Weline\Framework\View\Template $this
 * @var array $filters
 * @var array $website_options
 * @var array $event_options
 * @var array $summary
 * @var array $trend
 * @var array $event_rows
 * @var array $site_rows
 * @var array $source_rows
 * @var array $realtime_rows
 * @var array $recent_events
 */

$filters = $filters ?? [];
$websiteOptions = $website_options ?? [];
$eventOptions = $event_options ?? [];
$summary = $summary ?? [];
$trend = $trend ?? [];
$eventRows = $event_rows ?? [];
$siteRows = $site_rows ?? [];
$sourceRows = $source_rows ?? [];
$realtimeRows = $realtime_rows ?? [];
$recentEvents = $recent_events ?? [];

$h = static fn($value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$num = static fn($value, int $decimals = 0): string => number_format((float)$value, $decimals);
$selectedWebsite = (string)($filters['website_id_raw'] ?? '');
$selectedEvent = (string)($filters['event'] ?? '');
$selectedRange = (string)($filters['range'] ?? '30d');
$rangeLabels = [
    'today' => __('今日'),
    'yesterday' => __('昨日'),
    '7d' => __('近 7 天'),
    '30d' => __('近 30 天'),
    '90d' => __('近 90 天'),
    'custom' => __('自定义'),
];
$startInput = $selectedRange === 'custom' ? (string)($filters['start_day'] ?? '') : '';
$endInput = $selectedRange === 'custom' ? (string)($filters['end_day'] ?? '') : '';
$currentQuery = [
    'websiteId' => $selectedWebsite,
    'event' => $selectedEvent,
    'range' => $selectedRange,
    'startDate' => (string)($filters['start_day'] ?? ''),
    'endDate' => (string)($filters['end_day'] ?? ''),
];
$currentQuery = array_filter($currentQuery, static fn($value): bool => $value !== null && $value !== '');
$exportQuery = $currentQuery;
$exportQuery['format'] = 'csv';
$exportUrl = $this->getUrl('*/pixel_dashboard/export') . '?' . http_build_query($exportQuery);
$refreshUrl = $this->getUrl('*/pixel_dashboard/index') . (!empty($currentQuery) ? '?' . http_build_query($currentQuery) : '');
$trendMax = max(1, ...array_map(static fn($row): int => (int)($row['count'] ?? 0), $trend ?: [['count' => 0]]));
$eventMax = max(1, ...array_map(static fn($row): int => (int)($row['count'] ?? 0), $eventRows ?: [['count' => 0]]));
$realtimeMax = max(1, ...array_map(static fn($row): int => (int)($row['count'] ?? 0), $realtimeRows ?: [['count' => 0]]));
$eventChange = (float)($summary['event_change'] ?? 0);
$eventChangeClass = $eventChange >= 0 ? 'text-success' : 'text-danger';
?>

