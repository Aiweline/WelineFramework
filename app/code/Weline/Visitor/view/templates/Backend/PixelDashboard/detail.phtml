<script>
(function() {
    'use strict';
    
    <?php if (!empty($businessValue['data_points'])): ?>
    // 商业价值趋势图
    var businessValueCtx = document.getElementById('businessValueChart');
    if (businessValueCtx) {
        var businessData = <?= json_encode($businessValue['data_points']) ?>;
        new Chart(businessValueCtx, {
            type: 'line',
            data: {
                labels: businessData.map(function(item) { return item.date; }),
                datasets: [{
                    label: '<?= __('价值') ?>',
                    data: businessData.map(function(item) { return item.value; }),
                    borderColor: 'rgb(102, 126, 234)',
                    backgroundColor: 'rgba(102, 126, 234, 0.1)',
                    tension: 0.4,
                    fill: true,
                    yAxisID: 'y'
                }, {
                    label: '<?= __('事件数') ?>',
                    data: businessData.map(function(item) { return item.events; }),
                    borderColor: 'rgb(17, 153, 142)',
                    backgroundColor: 'rgba(17, 153, 142, 0.1)',
                    tension: 0.4,
                    fill: true,
                    yAxisID: 'y1'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: { legend: { display: true } },
                scales: {
                    y: { type: 'linear', display: true, position: 'left', beginAtZero: true },
                    y1: { type: 'linear', display: true, position: 'right', beginAtZero: true, grid: { drawOnChartArea: false } }
                }
            }
        });
    }
    <?php endif; ?>

    <?php if (!empty($dailyComparison['comparisons'])): ?>
    // 每日对比图表
    var dailyComparisonCtx = document.getElementById('dailyComparisonChart');
    if (dailyComparisonCtx) {
        var comparisonData = <?= json_encode($dailyComparison['comparisons']) ?>;
        new Chart(dailyComparisonCtx, {
            type: 'bar',
            data: {
                labels: comparisonData.map(function(item) { return item.date; }),
                datasets: [{
                    label: '<?= __('今天') ?>',
                    data: comparisonData.map(function(item) { return item.today.value; }),
                    backgroundColor: 'rgba(102, 126, 234, 0.8)'
                }, {
                    label: '<?= __('昨天') ?>',
                    data: comparisonData.map(function(item) { return item.yesterday.value; }),
                    backgroundColor: 'rgba(17, 153, 142, 0.8)'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: { legend: { display: true } },
                scales: { y: { beginAtZero: true } }
            }
        });
    }
    <?php endif; ?>
})();
</script>
