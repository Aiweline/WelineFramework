<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!-- 登录后发送像素数据 -->
    <event name="Weline_Frontend_Account_Login::login_after">
        <observer name="Weline_Visitor::login_pixel"
                  instance="Weline\Visitor\Observer\LoginPixel"
                  disabled="false"
                  shared="true"
                  sort="100"/>
    </event>
    <!-- 注册后发送像素数据 -->
    <event name="Weline_Frontend_Account_Register::register_after">
        <observer name="Weline_Visitor::register_pixel"
                  instance="Weline\Visitor\Observer\RegisterPixel"
                  disabled="false"
                  shared="true"
                  sort="100"/>
    </event>
    <!-- 部署模式切换到prod后生成像素加密token -->
    <event name="Weline_Framework_Deploy_Mode_Set::prod_after">
        <observer name="Weline_Visitor::deploy_mode_set_prod_after"
                  instance="Weline\Visitor\Observer\DeployModeSetProdAfter"
                  disabled="false"
                  shared="true"
                  sort="100"/>
    </event>
</config>

