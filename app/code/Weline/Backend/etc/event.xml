<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <event name="Weline_Framework_Module::module_upgrade">
        <observer name="Weline_Backend::menu_upgrade" instance="Weline\Backend\Observer\UpgradeMenu" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Resource::compiler">
        <observer name="Weline_Backend::compiler" instance="Weline\Backend\Observer\Compiler" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Framework_View::header">
        <observer name="Weline_Backend::header" instance="Weline\Backend\Observer\Header" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Framework_View::footer">
        <observer name="Weline_Backend::footer" instance="Weline\Backend\Observer\Footer" disabled="false" shared="true" sort="0"/>
    </event>
    <!-- API认证Observer已迁移到Weline_Api模块 -->
    <!-- <event name="Weline_Framework_RestController::init_before">
        <observer name="Weline_Backend::init_before" instance="Weline\Backend\Observer\ApiControllerInitBefore" disabled="false" shared="true" sort="0"/>
    </event> -->
    <event name="Weline_Framework_Http::response_redirect_before">
        <observer name="Weline_Backend::response_redirect_before" instance="Weline\Backend\Observer\ResponseRedirectBefore" disabled="false" shared="true" sort="0"/>
    </event>
</config>