<script>
(function() {
    'use strict';

    var WelineNotification = {
        markAllRead: function() {
            window.Weline.Api.request('<?= $this->getBackendUrl('system/backend/notification/markAllRead') ?>', { method: 'POST' })
            .then(function(response) {
                var data = response.data;
                if (response.ok && data && data.success) {
                    BackendToast.success(data.message || '<?= __('已标记全部已读') ?>');
                    setTimeout(function() { window.location.reload(); }, 500);
                }
            })
            .catch(function(error) {
                console.error('Mark all read error:', error);
            });
        },

        updateBadge: function() {
            var badge = document.querySelector('.weline-notification-badge');
            if (badge) {
                var current = parseInt(badge.textContent) || 0;
                if (current > 1) {
                    badge.textContent = current - 1;
                } else {
                    badge.remove();
                }
            }
        }
    };

    window.WelineNotification = WelineNotification;

    document.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-notification-action="mark-all-read"]');
        if (!trigger) {
            return;
        }

        event.preventDefault();
        WelineNotification.markAllRead();
    });
})();
</script>
