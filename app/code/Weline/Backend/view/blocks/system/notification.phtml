<?php
/**
 * 增强版系统通知下拉组件
 * 
 * @var \Weline\Framework\View\Template $this
 */

use Weline\Backend\Block\System\Notification;
use Weline\Framework\Manager\ObjectManager;

/** @var Notification $block */
$block = ObjectManager::getInstance(Notification::class);
$notifications = $block->getNotifications();
$unreadCount = $block->getUnreadCount();
?>

<div class="dropdown d-inline-block weline-notification-dropdown">
    <button type="button" class="btn header-item noti-icon waves-effect" 
            id="page-header-notifications-dropdown"
            data-bs-toggle="dropdown" aria-expanded="false">
        <i class="ri-notification-3-line"></i>
        <?php if ($unreadCount > 0): ?>
        <span class="noti-dot weline-notification-badge"><?= $unreadCount > 99 ? '99+' : $unreadCount ?></span>
        <?php endif; ?>
    </button>
    <div class="dropdown-menu dropdown-menu-lg dropdown-menu-end p-0 weline-notification-menu"
         aria-labelledby="page-header-notifications-dropdown">
        <div class="p-3 weline-notification-header">
            <div class="row align-items-center">
                <div class="col">
                    <h6 class="m-0"><?= __('通知') ?></h6>
                </div>
                <div class="col-auto">
                    <?php if ($unreadCount > 0): ?>
                    <a href="javascript:void(0)" class="small weline-notification-mark-all" 
                       onclick="WelineNotification.markAllRead()">
                        <?= __('全部已读') ?>
                    </a>
                    <?php endif; ?>
                </div>
            </div>
        </div>
        <div data-simplebar style="max-height: 300px;" class="weline-notification-list">
            <?php if (empty($notifications)): ?>
            <div class="weline-notification-empty">
                <i class="mdi mdi-bell-off"></i>
                <p><?= __('暂无通知') ?></p>
            </div>
            <?php else: ?>
            <?php foreach ($notifications as $notification): ?>
            <?php
            $type = $notification['type'] ?? 'info';
            $typeColor = $block->getTypeColor($type);
            $typeIcon = $block->getTypeIcon($type);
            $typeLabel = $block->getTypeLabel($type);
            $isRead = (bool) ($notification['is_read'] ?? false);
            ?>
            <a href="javascript:void(0)" 
               class="text-reset notification-item weline-notification-item <?= $isRead ? '' : 'weline-notification-unread' ?>"
               data-notification-id="<?= $notification['notification_id'] ?? '' ?>"
               onclick="WelineNotification.markRead(<?= $notification['notification_id'] ?? 0 ?>)">
                <div class="d-flex">
                    <div class="flex-shrink-0 me-3">
                        <?php if (!empty($notification['is_icon']) && !empty($notification['avatar'])): ?>
                        <div class="avatar-xs">
                            <span class="avatar-title rounded-circle font-size-16" style="background: <?= $typeColor ?>">
                                <i class="<?= htmlspecialchars($notification['avatar']) ?>"></i>
                            </span>
                        </div>
                        <?php else: ?>
                        <div class="avatar-xs">
                            <span class="avatar-title rounded-circle font-size-16" style="background: <?= $typeColor ?>">
                                <i class="<?= $typeIcon ?>"></i>
                            </span>
                        </div>
                        <?php endif; ?>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center mb-1">
                            <h6 class="mb-0 me-2"><?= htmlspecialchars($notification['title'] ?? '') ?></h6>
                            <span class="badge weline-notification-type-badge" style="background: <?= $typeColor ?>">
                                <?= $typeLabel ?>
                            </span>
                        </div>
                        <div class="font-size-12 text-muted">
                            <p class="mb-1 weline-notification-content"><?= $notification['content'] ?? '' ?></p>
                            <p class="mb-0">
                                <i class="mdi mdi-clock-outline"></i> 
                                <?= $notification['create_time'] ?? '' ?>
                                <?php if (!empty($notification['topic_code'])): ?>
                                <span class="ms-2 weline-notification-topic">
                                    <i class="mdi mdi-tag-outline"></i> <?= htmlspecialchars($notification['topic_code']) ?>
                                </span>
                                <?php endif; ?>
                            </p>
                        </div>
                    </div>
                    <?php if (!$isRead): ?>
                    <div class="weline-notification-dot"></div>
                    <?php endif; ?>
                </div>
            </a>
            <?php endforeach; ?>
            <?php endif; ?>
        </div>
        <div class="p-2 border-top weline-notification-footer">
            <div class="d-grid">
                <a class="btn btn-sm btn-link font-size-14 text-center" 
                   href="<?= $this->getBackendUrl('*/backend/notificationsubscription') ?>">
                    <i class="mdi mdi-cog me-1"></i> <?= __('管理订阅') ?>
                </a>
            </div>
        </div>
    </div>
</div>

