<?php
/**
 * 增强版系统通知下拉组件
 * 
 * @var \Weline\Framework\View\Template $this
 */

use Weline\Backend\Block\System\Notification;
use Weline\Framework\Manager\ObjectManager;

/** @var Notification $block */
$block = ObjectManager::getInstance(Notification::class);
$notifications = $block->getNotifications();
$unreadCount = $block->getUnreadCount();
?>

<div class="dropdown d-inline-block weline-notification-dropdown">
    <button type="button" class="btn header-item noti-icon waves-effect" 
            id="page-header-notifications-dropdown"
            data-bs-toggle="dropdown" aria-expanded="false">
        <span class="weline-notification-icon-wrapper">
            <i class="ri-notification-3-line"></i>
            <?php if ($unreadCount > 0): ?>
            <span class="weline-notification-badge"><?= $unreadCount > 99 ? '99+' : $unreadCount ?></span>
            <?php endif; ?>
        </span>
    </button>
    <div class="dropdown-menu dropdown-menu-lg dropdown-menu-end p-0 weline-notification-menu"
         aria-labelledby="page-header-notifications-dropdown">
        <div class="p-3 weline-notification-header">
            <div class="row align-items-center">
                <div class="col">
                    <h6 class="m-0"><?= __('通知') ?></h6>
                </div>
                <div class="col-auto">
                    <?php if ($unreadCount > 0): ?>
                    <button type="button" class="small weline-notification-mark-all"
                            data-notification-action="mark-all-read">
                        <?= __('全部已读') ?>
                    </button>
                    <?php endif; ?>
                </div>
            </div>
        </div>
        <div data-simplebar style="max-height: 300px;" class="weline-notification-list">
            <?php if (empty($notifications)): ?>
            <div class="weline-notification-empty">
                <i class="mdi mdi-bell-off"></i>
                <p><?= __('暂无通知') ?></p>
            </div>
            <?php else: ?>
            <?php foreach ($notifications as $notification): ?>
            <?php
            $type = $notification['type'] ?? 'info';
            $typeColor = $block->getTypeColor($type);
            $typeIcon = $block->getTypeIcon($type);
            $typeLabel = $block->getTypeLabel($type);
            $avatar = $notification['avatar'] ?? '';
            if ($avatar === 'ri-sitemap-line') {
                $avatar = 'ri-file-list-line';
            }
            $isRead = (bool) ($notification['is_read'] ?? false);
            $notificationId = $notification['notification_id'] ?? 0;
            $detailUrl = $this->getBackendUrl('system/backend/notification/detail', ['id' => $notificationId]);
            ?>
            <a href="<?= $detailUrl ?>" 
               class="text-reset notification-item weline-notification-item <?= $isRead ? '' : 'weline-notification-unread' ?>"
               data-notification-id="<?= $notificationId ?>">
                <div class="weline-notification-icon-wrap" style="background: <?= $typeColor ?>">
                    <?php if (!empty($notification['is_icon']) && $avatar !== ''): ?>
                    <i class="<?= htmlspecialchars($avatar) ?>"></i>
                    <?php else: ?>
                    <i class="<?= $typeIcon ?>"></i>
                    <?php endif; ?>
                </div>
                <div class="weline-notification-main">
                    <div class="weline-notification-header">
                        <h6 class="weline-notification-title"><?= htmlspecialchars($notification['title'] ?? '') ?></h6>
                        <span class="weline-notification-type-badge" style="background: <?= $typeColor ?>">
                            <?= $typeLabel ?>
                        </span>
                        <span class="weline-notification-read-badge weline-notification-read-badge--<?= $isRead ? 'read' : 'unread' ?>">
                            <?= $isRead ? __('已读') : __('未读') ?>
                        </span>
                    </div>
                    <p class="weline-notification-content"><?= htmlspecialchars(mb_substr(strip_tags($notification['content'] ?? ''), 0, 80)) ?><?= mb_strlen(strip_tags($notification['content'] ?? '')) > 80 ? '...' : '' ?></p>
                    <div class="weline-notification-meta">
                        <span class="weline-notification-time">
                            <i class="mdi mdi-clock-outline"></i> <?= $notification['notification_time'] ?? '' ?>
                        </span>
                        <?php if (!empty($notification['topic_code'])): ?>
                        <span class="weline-notification-topic">
                            <i class="mdi mdi-tag-outline"></i> <?= htmlspecialchars($notification['topic_name'] ?? $notification['topic_code']) ?>
                        </span>
                        <?php endif; ?>
                    </div>
                </div>
                <?php if (!$isRead): ?>
                <div class="weline-notification-dot"></div>
                <?php endif; ?>
                <div class="weline-notification-arrow">
                    <i class="ri-arrow-right-s-line"></i>
                </div>
            </a>
            <?php endforeach; ?>
            <?php endif; ?>
        </div>
        <div class="p-2 border-top weline-notification-footer">
            <div class="d-flex justify-content-between align-items-center gap-2">
                <a class="btn btn-sm btn-primary weline-notification-btn-viewall flex-grow-1" 
                   href="<?= $this->getBackendUrl('system/backend/notification') ?>">
                    <i class="ri-notification-3-line me-1"></i> <?= __('查看全部') ?>
                </a>
                <a class="btn btn-sm btn-outline-secondary" 
                   href="<?= $this->getBackendUrl('system/backend/notificationsubscription') ?>"
                   title="<?= __('管理订阅') ?>">
                    <i class="mdi mdi-cog"></i>
                </a>
            </div>
        </div>
    </div>
