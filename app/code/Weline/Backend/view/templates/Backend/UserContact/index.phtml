<script>
(function() {
    'use strict';

    var WelineUserContact = {
        modal: null,

        init: function() {
            var modalEl = document.getElementById('addContactModal');
            if (modalEl && typeof bootstrap !== 'undefined') {
                this.modal = new bootstrap.Modal(modalEl);
            }
        },

        showAddModal: function(channelCode) {
            document.getElementById('addContactForm').reset();
            if (channelCode) {
                document.getElementById('contactChannelCode').value = channelCode;
            }
            if (this.modal) {
                this.modal.show();
            }
        },

        saveContact: function() {
            var form = document.getElementById('addContactForm');
            var formData = new FormData(form);

            fetch('<?= $this->getBackendUrl('*/backend/usercontact/save') ?>', {
                method: 'POST',
                body: new URLSearchParams(formData)
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    BackendToast.success(data.message);
                    if (WelineUserContact.modal) {
                        WelineUserContact.modal.hide();
                    }
                    setTimeout(function() { window.location.reload(); }, 1000);
                } else {
                    BackendToast.error(data.message);
                }
            })
            .catch(function(error) {
                console.error('Error:', error);
                BackendToast.error('<?= __('保存失败') ?>');
            });
        },

        setDefault: function(contactId) {
            BackendConfirm.show('<?= __('确定要将此联系人设为默认吗？') ?>').then(function(confirmed) {
                if (!confirmed) return;

                fetch('<?= $this->getBackendUrl('*/backend/usercontact/setDefault') ?>', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'contact_id=' + contactId
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.success) {
                        BackendToast.success(data.message);
                        setTimeout(function() { window.location.reload(); }, 1000);
                    } else {
                        BackendToast.error(data.message);
                    }
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    BackendToast.error('<?= __('设置失败') ?>');
                });
            });
        },

        deleteContact: function(contactId) {
            BackendConfirm.show('<?= __('确定要删除此联系人吗？') ?>').then(function(confirmed) {
                if (!confirmed) return;

                fetch('<?= $this->getBackendUrl('*/backend/usercontact/delete') ?>', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'contact_id=' + contactId
                })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.success) {
                        BackendToast.success(data.message);
                        setTimeout(function() { window.location.reload(); }, 1000);
                    } else {
                        BackendToast.error(data.message);
                    }
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    BackendToast.error('<?= __('删除失败') ?>');
                });
            });
        }
    };

    window.WelineUserContact = WelineUserContact;

    document.addEventListener('DOMContentLoaded', function() {
        WelineUserContact.init();
    });
})();
</script>
