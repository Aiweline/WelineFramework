<script>
(function() {
    'use strict';
    var prevUrl = <?= $prevId ? json_encode($detailUrlBase . '?id=' . (int)$prevId, $jsonForScriptFlags) : 'null' ?>;
    var nextUrl = <?= $nextId ? json_encode($detailUrlBase . '?id=' . (int)$nextId, $jsonForScriptFlags) : 'null' ?>;
    var markTopicReadUrl = <?= json_encode($this->getBackendUrl('system/backend/notification/markTopicRead'), $jsonForScriptFlags) ?>;
    var confirmMsgTemplate = <?= json_encode((string)__('确定要将「%{name}」类的所有通知标记为已读吗？'), $jsonForScriptFlags) ?>;

    document.addEventListener('keydown', function(e) {
        if (/input|textarea|select/i.test(document.activeElement && document.activeElement.tagName || '')) {
            return;
        }
        if (e.key === 'ArrowLeft' && prevUrl) {
            window.location.href = prevUrl;
        } else if (e.key === 'ArrowRight' && nextUrl) {
            window.location.href = nextUrl;
        }
    });

    var btn = document.querySelector('.weline-nd-mark-topic-read');
    if (btn) {
        btn.addEventListener('click', function() {
            var topicCode = btn.getAttribute('data-topic-code');
            var topicName = btn.getAttribute('data-topic-name') || topicCode;
            var msg = confirmMsgTemplate.replace('%{name}', topicName || topicCode || '');
            BackendConfirm.show(msg).then(function(confirmed) {
                if (!confirmed) return;
                var opts = { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ topic_code: topicCode }) };
                window.Weline.Api.request(markTopicReadUrl, opts)
                    .then(function(res) {
                        var data = (res && res.data) !== undefined ? res.data : res;
                        if (data.success) {
                            BackendToast.success(data.message || '<?= __('已标记为已读') ?>');
                            setTimeout(function() { window.location.reload(); }, 800);
                        } else {
                            BackendToast.error(data.message || '<?= __('操作失败') ?>');
                        }
                    })
                    .catch(function(err) {
                        BackendToast.error('<?= __('网络错误，请重试') ?>');
                    });
            });
        });
    }
})();
</script>
