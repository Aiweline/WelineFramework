<?php
/**
 * 通知中心页面（支持关键词、类型、已读状态过滤）
 *
 * @var \Weline\Framework\View\Template $this
 * @var array $notifications 通知列表
 * @var array $pagination 分页信息
 * @var array $filter 当前过滤条件 keyword, type, read
 * @var array $type_options 类型下拉选项
 */
$notifications = $notifications ?? [];
$pagination = $pagination ?? ['page' => 1, 'pages' => 1, 'total' => 0];
$filter = $filter ?? ['keyword' => '', 'type' => '', 'read' => 'all'];
$typeOptions = $type_options ?? [];
$baseUrl = $this->getBackendUrl('system/backend/notification');
$queryParams = function ($overrides = []) use ($filter) {
    $q = array_filter([
        'keyword' => $filter['keyword'] ?? '',
        'type' => $filter['type'] ?? '',
        'read' => ($filter['read'] ?? 'all') !== 'all' ? ($filter['read'] ?? '') : '',
    ]);
    return array_merge($q, $overrides);
};
?>

<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0 font-size-18">
                <i class="ri-notification-3-line me-2"></i><lang>通知中心</lang>
            </h4>
            <div class="d-flex gap-2">
                <a href="<?= $this->getBackendUrl('system/backend/notificationsubscription') ?>" class="btn btn-outline-secondary btn-sm">
                    <i class="mdi mdi-cog me-1"></i><lang>管理订阅</lang>
                </a>
                <?php if (!empty($notifications)): ?>
                <button type="button" class="btn btn-outline-primary btn-sm" onclick="WelineNotificationCenter.markAllRead()">
                    <i class="mdi mdi-check-all me-1"></i><lang>全部已读</lang>
                </button>
                <?php endif; ?>
            </div>
        </div>
    </div>
</div>

<div class='row'>
    <div class="col-12">
        <template>Weline_Component::message.phtml</template>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12">
        <div class="card weline-nc-filter-card">
            <div class="card-body py-3">
                <form method="get" action="<?= $baseUrl ?>" class="weline-nc-filter-form row g-2 align-items-end">
                    <input type="hidden" name="page" value="1">
                    <div class="col-12 col-md-4">
                        <label class="form-label small mb-1"><lang>关键词</lang></label>
                        <input type="text" name="keyword" class="form-control form-control-sm" placeholder="<?= __('搜索标题或内容') ?>"
                               value="<?= htmlspecialchars($filter['keyword'] ?? '') ?>">
                    </div>
                    <div class="col-6 col-md-2">
                        <label class="form-label small mb-1"><lang>类型</lang></label>
                        <select name="type" class="form-select form-select-sm">
                            <option value=""><lang>全部类型</lang></option>
                            <?php foreach ($typeOptions as $val => $label): ?>
                            <option value="<?= htmlspecialchars($val) ?>" <?= ($filter['type'] ?? '') === $val ? 'selected' : '' ?>><?= htmlspecialchars($label) ?></option>
                            <?php endforeach; ?>
                        </select>
                    </div>
                    <div class="col-6 col-md-2">
                        <label class="form-label small mb-1"><lang>状态</lang></label>
                        <select name="read" class="form-select form-select-sm">
                            <option value="all" <?= ($filter['read'] ?? 'all') === 'all' ? 'selected' : '' ?>><?= __('全部') ?></option>
                            <option value="unread" <?= ($filter['read'] ?? '') === 'unread' ? 'selected' : '' ?>><?= __('未读') ?></option>
                            <option value="read" <?= ($filter['read'] ?? '') === 'read' ? 'selected' : '' ?>><?= __('已读') ?></option>
                        </select>
                    </div>
                    <div class="col-12 col-md-auto d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="ri-search-line me-1"></i><lang>搜索</lang>
                        </button>
                        <a href="<?= $baseUrl ?>" class="btn btn-outline-secondary btn-sm"><lang>重置</lang></a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <?php if (empty($notifications)): ?>
        <div class="card">
            <div class="card-body">
                <div class="weline-nc-empty text-center py-5">
                    <i class="ri-notification-off-line weline-nc-empty-icon"></i>
                    <p class="mt-3 mb-0"><lang>暂无通知消息</lang></p>
                </div>
            </div>
        </div>
        <?php else: ?>
        <div class="weline-nc-list">
            <?php foreach ($notifications as $notification): ?>
            <?php
            $isRead = (bool) ($notification['is_read'] ?? false);
            $typeColor = $notification['type_color'] ?? 'var(--backend-color-info)';
            $typeLabel = $notification['type_label'] ?? __('信息');
            $typeIcon = $notification['avatar'] ?? 'ri-notification-line';
            ?>
            <a href="<?= $this->getBackendUrl('system/backend/notification/detail', ['id' => $notification['notification_id'] ?? 0]) ?>" 
               class="weline-nc-item <?= $isRead ? 'weline-nc-item-read' : '' ?>">
                <div class="weline-nc-item-icon" style="background: <?= $typeColor ?>">
                    <i class="<?= htmlspecialchars($typeIcon) ?>"></i>
                </div>
                <div class="weline-nc-item-content">
                    <div class="weline-nc-item-header">
                        <h5 class="weline-nc-item-title"><?= htmlspecialchars($notification['title'] ?? '') ?></h5>
                        <div class="weline-nc-item-meta">
                            <span class="weline-nc-type-badge" style="background: <?= $typeColor ?>"><?= $typeLabel ?></span>
                            <?php if (!$isRead): ?>
                            <span class="weline-nc-unread-dot"></span>
                            <?php endif; ?>
                        </div>
                    </div>
                    <p class="weline-nc-item-text"><?= htmlspecialchars(mb_substr(strip_tags($notification['content'] ?? ''), 0, 120)) ?><?= mb_strlen(strip_tags($notification['content'] ?? '')) > 120 ? '...' : '' ?></p>
                    <div class="weline-nc-item-footer">
                        <span class="weline-nc-item-time">
                            <i class="mdi mdi-clock-outline me-1"></i><?= $notification['notification_time'] ?? '' ?>
                        </span>
                        <?php if (!empty($notification['topic_code'])): ?>
                        <span class="weline-nc-item-topic">
                            <i class="mdi mdi-tag-outline me-1"></i><?= htmlspecialchars($notification['topic_name'] ?? $notification['topic_code']) ?>
                        </span>
                        <?php endif; ?>
                        <span class="weline-nc-view-link">
                            <lang>查看详情</lang> <i class="ri-arrow-right-s-line"></i>
                        </span>
                    </div>
                </div>
            </a>
            <?php endforeach; ?>
        </div>

        <?php if ($pagination['pages'] > 1): ?>
        <?php
        $pageLink = function ($pageNum) use ($baseUrl, $queryParams) {
            $params = array_filter($queryParams(['page' => $pageNum]));
            return $params ? $baseUrl . '?' . http_build_query($params) : $baseUrl;
        };
        ?>
        <div class="card mt-3">
            <div class="card-body">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center mb-0">
                        <?php if ($pagination['page'] > 1): ?>
                        <li class="page-item">
                            <a class="page-link" href="<?= $pageLink($pagination['page'] - 1) ?>">
                                <i class="mdi mdi-chevron-left"></i>
                            </a>
                        </li>
                        <?php endif; ?>
                        
                        <?php for ($i = max(1, $pagination['page'] - 2); $i <= min($pagination['pages'], $pagination['page'] + 2); $i++): ?>
                        <li class="page-item <?= $i === $pagination['page'] ? 'active' : '' ?>">
                            <a class="page-link" href="<?= $pageLink($i) ?>"><?= $i ?></a>
                        </li>
                        <?php endfor; ?>
                        
                        <?php if ($pagination['page'] < $pagination['pages']): ?>
                        <li class="page-item">
                            <a class="page-link" href="<?= $pageLink($pagination['page'] + 1) ?>">
                                <i class="mdi mdi-chevron-right"></i>
                            </a>
                        </li>
                        <?php endif; ?>
                    </ul>
                </nav>
                <p class="text-center text-muted mb-0 mt-2 small">
                    <lang>共</lang> <?= $pagination['total'] ?> <lang>条通知，第</lang> <?= $pagination['page'] ?> / <?= $pagination['pages'] ?> <lang>页</lang>
                </p>
            </div>
        </div>
        <?php endif; ?>
        <?php endif; ?>
    </div>
</div>

