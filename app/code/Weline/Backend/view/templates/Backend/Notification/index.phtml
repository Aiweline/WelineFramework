<script>
(function() {
    'use strict';

    var WelineNotificationCenter = {
        markAllRead: function() {
            BackendConfirm.show('<?= __('确定要将所有通知标记为已读吗？') ?>').then(function(confirmed) {
                if (!confirmed) return;

                var url = '<?= $this->getBackendUrl('*/backend/notification/markAllRead') ?>';
                var opts = { method: 'POST', headers: { 'Content-Type': 'application/json' } };
                window.Weline.Api.request(url, opts)
                .then(function(res) {
                    var data = (res && res.data) !== undefined ? res.data : res;
                    if (data.success) {
                        BackendToast.success(data.message || '<?= __('已标记全部已读') ?>');
                        setTimeout(function() { window.location.reload(); }, 800);
                    } else {
                        BackendToast.error(data.message || '<?= __('操作失败') ?>');
                    }
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    BackendToast.error('<?= __('网络错误，请重试') ?>');
                });
            });
        }
    };

    window.WelineNotificationCenter = WelineNotificationCenter;
})();
</script>
