<script>
function saveConfig(event) {
    event.preventDefault();
    const form = document.getElementById('configForm');
    const formData = new FormData(form);
    const data = {};
    
    // 将FormData转换为对象
    for (let [key, value] of formData.entries()) {
        if (key.startsWith('config[')) {
            const configKey = key.match(/config\[(.*?)\]/)[1];
            data['config[' + configKey + ']'] = value;
        } else {
            data[key] = value;
        }
    }
    
    fetch('<?= $this->getBackendUrl('*/backend/config/save') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showPageMessage('success', data.message);
            // 延迟刷新页面以显示更新后的配置
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        } else {
            showPageMessage('error', data.message);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showPageMessage('error', '<?= __('保存失败') ?>');
    });
}

function resetForm() {
    if (confirm('<?= __('确定要重置表单吗？') ?>')) {
        document.getElementById('configForm').reset();
    }
}
</script>

