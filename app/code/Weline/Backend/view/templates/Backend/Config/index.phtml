<script>
(function() {
    'use strict';
    
    window.saveConfig = function(event) {
        event.preventDefault();
        const form = document.getElementById('configForm');
        const formData = new FormData(form);
        const data = {};
        
        for (let [key, value] of formData.entries()) {
            if (key.startsWith('config[')) {
                const configKey = key.match(/config\[(.*?)\]/)[1];
                data['config[' + configKey + ']'] = value;
            } else {
                data[key] = value;
            }
        }
        
        var url = '<?= $this->getBackendUrl('*/backend/config/save') ?>';
        var opts = { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams(data).toString() };
        window.Weline.Api.request(url, opts)
        .then(function(res) {
            var data = (res && res.data) !== undefined ? res.data : res;
            if (data.success) {
                BackendToast.success(data.message);
                setTimeout(() => {
                    window.location.reload();
                }, 1000);
            } else {
                BackendToast.error(data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            BackendToast.error('<?= __('保存失败') ?>');
        });
    };

    window.resetForm = function() {
        AdminConfirm.show('<?= __('确定要重置表单吗？') ?>').then(function(confirmed) {
            if (confirmed) {
                document.getElementById('configForm').reset();
            }
        });
    };

    var configForm = document.getElementById('configForm');
    if (configForm) {
        configForm.addEventListener('submit', window.saveConfig);
    }

    document.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-config-action="reset"]');
        if (!trigger) {
            return;
        }

        event.preventDefault();
        window.resetForm();
    });
})();
</script>
