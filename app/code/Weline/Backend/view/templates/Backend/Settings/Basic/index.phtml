<script>
function saveSettings(event) {
    event.preventDefault();
    const formData = new FormData(event.target);
    
    fetch('<?= $this->getBackendUrl('*/backend/settings/basic/save') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showPageMessage('success', data.message);
        } else {
            showPageMessage('error', data.message);
        }
    })
    .catch(error => {
        showPageMessage('error', '<?= __('保存失败') ?>');
    });
}
</script>

