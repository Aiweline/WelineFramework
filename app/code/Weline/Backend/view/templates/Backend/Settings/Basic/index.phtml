<script>
(function() {
    'use strict';
    
    window.WelineBasicSettings = {
        save: function(event) {
            event.preventDefault();
            var formData = new FormData(event.target);
            
            fetch('<?= $this->getBackendUrl('*/backend/settings/basic/save') ?>', {
                method: 'POST',
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    AdminToast.success(data.message);
                } else {
                    AdminToast.error(data.message);
                }
            })
            .catch(function(error) {
                AdminToast.error('<?= __('保存失败') ?>');
            });
        }
    };
})();
</script>
