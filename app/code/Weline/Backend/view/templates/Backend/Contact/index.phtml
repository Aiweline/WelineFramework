<style>
.weline-contact-card { margin-bottom: 0; }
.weline-contact-card-header { background: var(--backend-color-card-header-bg, #f8f9fa); border-bottom: 1px solid var(--backend-color-border-default, #dee2e6); }
.weline-contact-channel-item { border-color: var(--backend-color-border-light, #e9ecef); }
</style>

<script>
(function() {
    'use strict';

    var adapterMap = <?= json_encode($adapter_map, $jsonForScriptFlags) ?>;
    var contactNameModalEl = document.getElementById('contactNameModal');
    var channelConfigModalEl = document.getElementById('channelConfigModal');
    var contactNameModal = null;
    var channelConfigModal = null;

    function escapeHtml(value) {
        var div = document.createElement('div');
        div.textContent = value == null ? '' : String(value);
        return div.innerHTML;
    }

    function escapeAttr(value) {
        return escapeHtml(value).replace(/"/g, '&quot;').replace(/'/g, '&#039;');
    }

    function confirmAction(message, onConfirm) {
        if (window.BackendConfirm && typeof window.BackendConfirm.show === 'function') {
            window.BackendConfirm.show(message).then(function(confirmed) {
                if (confirmed && onConfirm) {
                    onConfirm();
                }
            });
            return;
        }
        BackendToast.error(<?= json_encode((string)__('确认组件不可用，请刷新页面后重试'), $jsonForScriptFlags) ?>);
    }

    var WelineContact = {
        init: function() {
            if (contactNameModalEl && typeof bootstrap !== 'undefined') {
                contactNameModal = new bootstrap.Modal(contactNameModalEl);
            }
            if (channelConfigModalEl && typeof bootstrap !== 'undefined') {
                channelConfigModal = new bootstrap.Modal(channelConfigModalEl);
            }
        },

        showAddContactModal: function() {
            document.getElementById('contactIdInput').value = '';
            document.getElementById('contactNameInput').value = '';
            document.getElementById('contactNameModalTitle').textContent = '<?= __("新建联系人") ?>';
            if (contactNameModal) contactNameModal.show();
        },

        showEditContactModal: function(contactId, name) {
            document.getElementById('contactIdInput').value = contactId;
            document.getElementById('contactNameInput').value = name || '';
            document.getElementById('contactNameModalTitle').textContent = '<?= __("编辑联系人") ?>';
            if (contactNameModal) contactNameModal.show();
        },

        saveContactName: function() {
            var contactId = document.getElementById('contactIdInput').value;
            var contactName = document.getElementById('contactNameInput').value.trim();
            if (!contactName) {
                BackendToast.error('<?= __("请输入联系人名称") ?>');
                return;
            }
            var url = <?= json_encode($this->getBackendUrl('*/backend/contact/save'), $jsonForScriptFlags) ?>;
            var body = 'contact_name=' + encodeURIComponent(contactName);
            if (contactId) body += '&contact_id=' + contactId;
            window.Weline.Api.request(url, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body })
                .then(function(res) {
                    var data = (res && res.data) !== undefined ? res.data : res;
                    if (data.success) {
                        BackendToast.success(data.message);
                        if (contactNameModal) contactNameModal.hide();
                        setTimeout(function() { window.location.reload(); }, 800);
                    } else {
                        BackendToast.error(data.message || '<?= __("保存失败") ?>');
                    }
                })
                .catch(function(e) {
                    BackendToast.error('<?= __("保存失败") ?>');
                });
        },

        showAddChannelModal: function(contactId, contactName) {
            document.getElementById('channelConfigContactId').value = contactId;
            document.getElementById('channelConfigChannelCode').value = '';
            document.getElementById('channelConfigModalTitle').textContent = '<?= __("添加渠道配置") ?>' + (contactName ? ' - ' + contactName : '');
            document.getElementById('channelConfigChannelSelect').value = '';
            document.getElementById('channelConfigChannelSelect').disabled = false;
            WelineContact.renderChannelConfigFields('');
            if (channelConfigModal) channelConfigModal.show();
        },

        showEditChannelModal: function(contactId, channelCode, config) {
            document.getElementById('channelConfigContactId').value = contactId;
            document.getElementById('channelConfigChannelCode').value = channelCode;
            document.getElementById('channelConfigModalTitle').textContent = '<?= __("编辑渠道配置") ?>';
            document.getElementById('channelConfigChannelSelect').value = channelCode;
            document.getElementById('channelConfigChannelSelect').disabled = true;
            WelineContact.renderChannelConfigFields(channelCode, config || {});
            if (channelConfigModal) channelConfigModal.show();
        },

        renderChannelConfigFields: function(channelCode, values) {
            values = values || {};
            var container = document.getElementById('channelConfigFieldsContainer');
            if (!channelCode || !adapterMap[channelCode] || !adapterMap[channelCode].config_fields) {
                container.innerHTML = '<p class="text-muted"><lang>请先选择渠道</lang></p>';
                return;
            }
            var fields = adapterMap[channelCode].config_fields;
            var html = '';
            fields.forEach(function(f) {
                var val = values[f.name] !== undefined ? values[f.name] : '';
                var req = (f.required) ? ' required' : '';
                var ph = (f.placeholder || '');
                var fieldName = escapeAttr(f.name || '');
                var fieldLabel = escapeHtml(f.label || '');
                var fieldValue = escapeAttr(val || '');
                var fieldPlaceholder = escapeAttr(ph || '');
                if (f.type === 'password') {
                    html += '<div class="mb-3"><label class="form-label">' + fieldLabel + (f.required ? ' <span class="text-danger">*</span>' : '') + '</label><input type="password" class="form-control channel-config-field" name="' + fieldName + '" data-name="' + fieldName + '" value="' + fieldValue + '" placeholder="' + fieldPlaceholder + '"' + req + '></div>';
                } else if (f.type === 'textarea') {
                    html += '<div class="mb-3"><label class="form-label">' + fieldLabel + (f.required ? ' <span class="text-danger">*</span>' : '') + '</label><textarea class="form-control channel-config-field" name="' + fieldName + '" data-name="' + fieldName + '" placeholder="' + fieldPlaceholder + '" rows="3"' + req + '>' + escapeHtml(val || '') + '</textarea></div>';
                } else if (f.type === 'select' && f.options && typeof f.options === 'object') {
                    var opts = '<option value="">' + escapeHtml(ph || '') + '</option>';
                    for (var k in f.options) {
                        if (!f.options.hasOwnProperty(k)) continue;
                        var sel = (val === k || val === f.options[k]) ? ' selected' : '';
                        opts += '<option value="' + escapeAttr(k) + '"' + sel + '>' + escapeHtml(f.options[k]) + '</option>';
                    }
                    html += '<div class="mb-3"><label class="form-label">' + fieldLabel + (f.required ? ' <span class="text-danger">*</span>' : '') + '</label><select class="form-select channel-config-field" name="' + fieldName + '" data-name="' + fieldName + '"' + req + '>' + opts + '</select></div>';
                } else {
                    html += '<div class="mb-3"><label class="form-label">' + fieldLabel + (f.required ? ' <span class="text-danger">*</span>' : '') + '</label><input type="text" class="form-control channel-config-field" name="' + fieldName + '" data-name="' + fieldName + '" value="' + fieldValue + '" placeholder="' + fieldPlaceholder + '"' + req + '></div>';
                }
            });
            container.innerHTML = html;
        },

        saveChannelConfig: function() {
            var contactId = document.getElementById('channelConfigContactId').value;
            var channelCode = document.getElementById('channelConfigChannelCode').value || document.getElementById('channelConfigChannelSelect').value;
            if (!contactId || !channelCode) {
                BackendToast.error('<?= __("请选择渠道") ?>');
                return;
            }
            var config = {};
            document.querySelectorAll('#channelConfigFieldsContainer .channel-config-field').forEach(function(input) {
                var name = input.getAttribute('data-name') || input.name;
                if (name) config[name] = input.value || '';
            });
            var url = <?= json_encode($this->getBackendUrl('*/backend/contact/addChannelConfig'), $jsonForScriptFlags) ?>;
            var body = 'contact_id=' + contactId + '&channel_code=' + encodeURIComponent(channelCode);
            Object.keys(config).forEach(function(k) {
                body += '&config[' + encodeURIComponent(k) + ']=' + encodeURIComponent(config[k]);
            });
            window.Weline.Api.request(url, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body })
                .then(function(res) {
                    var data = (res && res.data) !== undefined ? res.data : res;
                    if (data.success) {
                        BackendToast.success(data.message);
                        if (channelConfigModal) channelConfigModal.hide();
                        setTimeout(function() { window.location.reload(); }, 800);
                    } else {
                        BackendToast.error(data.message || '<?= __("保存失败") ?>');
                    }
                })
                .catch(function() {
                    BackendToast.error('<?= __("保存失败") ?>');
                });
        },

        removeChannelConfig: function(contactId, channelCode) {
            confirmAction(<?= json_encode((string)__('确定要移除此渠道配置吗？'), $jsonForScriptFlags) ?>, function() {
                var url = <?= json_encode($this->getBackendUrl('*/backend/contact/removeChannelConfig'), $jsonForScriptFlags) ?>;
                var body = 'contact_id=' + contactId + '&channel_code=' + encodeURIComponent(channelCode);
                window.Weline.Api.request(url, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body })
                    .then(function(res) {
                        var data = (res && res.data) !== undefined ? res.data : res;
                        if (data.success) {
                            BackendToast.success(data.message);
                            setTimeout(function() { window.location.reload(); }, 800);
                        } else {
                            BackendToast.error(data.message || <?= json_encode((string)__('操作失败'), $jsonForScriptFlags) ?>);
                        }
                    })
                    .catch(function() {
                        BackendToast.error(<?= json_encode((string)__('操作失败'), $jsonForScriptFlags) ?>);
                    });
            });
        },

        deleteContact: function(contactId) {
            confirmAction(<?= json_encode((string)__('确定要删除此联系人吗？'), $jsonForScriptFlags) ?>, function() {
                var url = <?= json_encode($this->getBackendUrl('*/backend/contact/delete'), $jsonForScriptFlags) ?>;
                window.Weline.Api.request(url, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: 'contact_id=' + contactId })
                    .then(function(res) {
                        var data = (res && res.data) !== undefined ? res.data : res;
                        if (data.success) {
                            BackendToast.success(data.message);
                            setTimeout(function() { window.location.reload(); }, 800);
                        } else {
                            BackendToast.error(data.message || <?= json_encode((string)__('删除失败'), $jsonForScriptFlags) ?>);
                        }
                    })
                    .catch(function() {
                        BackendToast.error(<?= json_encode((string)__('删除失败'), $jsonForScriptFlags) ?>);
                    });
            });
        }
    };

    document.getElementById('channelConfigChannelSelect').addEventListener('change', function() {
        var code = this.value;
        document.getElementById('channelConfigChannelCode').value = code;
        WelineContact.renderChannelConfigFields(code);
    });

    document.addEventListener('click', function(e) {
        var btn = e.target && e.target.closest('.weline-edit-channel-btn');
        if (!btn) return;
        e.preventDefault();
        var contactId = btn.getAttribute('data-contact-id');
        var channelCode = btn.getAttribute('data-channel-code');
        var configStr = btn.getAttribute('data-config');
        var config = {};
        try {
            if (configStr) config = JSON.parse(configStr);
        } catch (err) {}
        WelineContact.showEditChannelModal(parseInt(contactId, 10), channelCode, config);
    });

    document.addEventListener('click', function(e) {
        var trigger = e.target && e.target.closest('[data-contact-action]');
        if (!trigger) return;
        e.preventDefault();

        var action = trigger.getAttribute('data-contact-action');
        var contactId = trigger.getAttribute('data-contact-id') || '';
        var contactName = trigger.getAttribute('data-contact-name') || '';
        var channelCode = trigger.getAttribute('data-channel-code') || '';

        if (action === 'add-contact') {
            WelineContact.showAddContactModal();
            return;
        }
        if (action === 'add-channel') {
            WelineContact.showAddChannelModal(parseInt(contactId || '0', 10), contactName);
            return;
        }
        if (action === 'edit-contact') {
            WelineContact.showEditContactModal(parseInt(contactId || '0', 10), contactName);
            return;
        }
        if (action === 'delete-contact') {
            WelineContact.deleteContact(parseInt(contactId || '0', 10));
            return;
        }
        if (action === 'remove-channel') {
            WelineContact.removeChannelConfig(parseInt(contactId || '0', 10), channelCode);
            return;
        }
        if (action === 'save-contact') {
            WelineContact.saveContactName();
            return;
        }
        if (action === 'save-channel') {
            WelineContact.saveChannelConfig();
        }
    });

    window.WelineContact = WelineContact;
    document.addEventListener('DOMContentLoaded', function() {
        WelineContact.init();
    });
})();
</script>
