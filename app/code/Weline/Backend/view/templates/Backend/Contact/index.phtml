                        <span class="small text-muted flex-grow-1 text-truncate" title="<?= htmlspecialchars($channelConfigJson, ENT_QUOTES, 'UTF-8') ?>">
                            <?= htmlspecialchars($channelConfigPreview, ENT_QUOTES, 'UTF-8') ?>…
