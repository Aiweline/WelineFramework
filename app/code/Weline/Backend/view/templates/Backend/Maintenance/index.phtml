<script>
function saveMaintenance(event) {
    event.preventDefault();
    const formData = new FormData(event.target);
    formData.append('enabled', document.getElementById('is_maintenance').checked ? '1' : '0');
    
    fetch('<?= $this->getBackendUrl('*/backend/maintenance/toggle') ?>', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showPageMessage('success', data.message);
            setTimeout(() => {
                location.reload();
            }, 1000);
        } else {
            showPageMessage('error', data.message);
        }
    })
    .catch(error => {
        showPageMessage('error', '<?= __('保存失败') ?>');
    });
}
</script>

