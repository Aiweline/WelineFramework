/**
 * 系统维护模式管理页面（内容模板）
 * 
 * 只包含页面内容，由布局系统自动包裹 HTML 框架
 * 布局由 BackendController::$layoutType = 'default.default' 控制
 *
 * @var \Weline\Framework\View\Template $this
 * @var bool $is_maintenance
 * @var string $maintenance_message
 */
$isMaintenance = (bool)($is_maintenance ?? false);
$maintenanceMessage = $maintenance_message ?? __('系统维护中，请稍后再试');
?>
<!-- 页面标题 -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0 font-size-18"><lang>系统维护模式</lang></h4>
        </div>
    </div>
</div>

<!-- 消息提示区域 -->
<div class='row'>
    <div class="col-12">
        <template>Weline_Component::message.phtml</template>
    </div>
</div>

<!-- 提示信息 -->
<div class="row">
    <div class="col-12">
        <div class="alert alert-warning">
            <i class="mdi mdi-alert me-2"></i>
            <strong><lang>重要提示</lang>:</strong> <lang>开启维护模式后，前台将显示维护页面，但后台仍可正常访问。</lang>
        </div>
    </div>
</div>

<!-- 维护模式设置 -->
<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title mb-4"><lang>维护模式设置</lang></h4>
                
                <form id="maintenanceForm">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="is_maintenance" name="enabled" 
                                           <?= $isMaintenance ? 'checked' : '' ?>>
                                    <label class="form-check-label" for="is_maintenance">
                                        <strong><lang>启用维护模式</lang></strong>
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="mb-3">
                                <label class="form-label"><lang>维护消息</lang></label>
                                <textarea class="form-control" id="maintenance_message" name="message" rows="5"><?= htmlspecialchars($maintenanceMessage) ?></textarea>
                                <div class="form-text"><lang>此消息将显示给访问前台的用户</lang></div>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="mdi mdi-content-save me-2"></i><lang>保存设置</lang>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- 当前状态 -->
<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title mb-4"><lang>当前状态</lang></h4>
                <div class="alert alert-<?= $isMaintenance ? 'warning' : 'success' ?>">
                    <i class="mdi mdi-<?= $isMaintenance ? 'alert' : 'check-circle' ?> me-2"></i>
                    <strong>
                        <?= $isMaintenance ? __('系统当前处于维护模式') : __('系统当前正常运行') ?>
                    </strong>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    window.WelineMaintenance = {
        save: function(event) {
            event.preventDefault();
            var formData = new FormData(event.target);
            formData.append('enabled', document.getElementById('is_maintenance').checked ? '1' : '0');
            
            var url = '<?= $this->getBackendUrl('*/backend/maintenance/toggle') ?>';
            var opts = { method: 'POST', body: formData };
            window.Weline.Api.request(url, opts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    BackendToast.success(data.message);
                    setTimeout(function() {
                        location.reload();
                    }, 1000);
                } else {
                    BackendToast.error(data.message);
                }
            })
            .catch(function(error) {
                BackendToast.error('<?= __('保存失败') ?>');
            });
        }
    };

    var maintenanceForm = document.getElementById('maintenanceForm');
    if (maintenanceForm) {
        maintenanceForm.addEventListener('submit', window.WelineMaintenance.save);
    }
})();
</script>
