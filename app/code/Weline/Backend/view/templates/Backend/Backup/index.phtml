<script>
(function() {
    'use strict';
    
    window.WelineBackup = {
        createBackup: function(event) {
            event.preventDefault();
            var formData = new FormData(event.target);
            
            var url = '<?= $this->getBackendUrl('*/backup/create') ?>';
            var opts = { method: 'POST', body: formData };
            window.Weline.Api.request(url, opts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    BackendToast.success(data.message);
                    setTimeout(function() {
                        location.reload();
                    }, 1000);
                } else {
                    BackendToast.error(data.message);
                }
            })
            .catch(function(error) {
                BackendToast.error('<?= __('创建备份失败') ?>');
            });
        },
        
        downloadBackup: function(filename) {
            BackendToast.info('<?= __('下载备份：') ?>' + filename);
        },
        
        deleteBackup: function(filename) {
            AdminConfirm.show('<?= __('确定要删除这个备份吗？') ?>').then(function(confirmed) {
                if (confirmed) {
                    BackendToast.info('<?= __('删除备份：') ?>' + filename);
                }
            });
        }
    };
})();
</script>
