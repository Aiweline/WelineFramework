<script>
(function() {
    'use strict';

    var WelineChannel = {
        deleteChannel: function(channelId) {
            BackendConfirm.show('<?= __('确定要删除此渠道吗？删除后将停止向该渠道发送通知。') ?>').then(function(confirmed) {
                if (!confirmed) return;

                var url = '<?= $this->getBackendUrl('*/backend/notificationchannel/delete') ?>';
                var opts = { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: 'channel_id=' + channelId };
                var req = window.Weline.Api.request(url, opts);
                req.then(function(res) {
                    var data = (res && res.data) || res;
                    if (data.success) {
                        BackendToast.success(data.message);
                        setTimeout(function() { window.location.reload(); }, 1000);
                    } else {
                        BackendToast.error(data.message);
                    }
                })
                .catch(function(error) {
                    console.error('Error:', error);
                    BackendToast.error('<?= __('删除失败') ?>');
                });
            });
        }
    };

    window.WelineChannel = WelineChannel;

    document.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-channel-action="delete"]');
        if (!trigger) {
            return;
        }

        event.preventDefault();
        WelineChannel.deleteChannel(trigger.getAttribute('data-channel-id') || '0');
    });
})();
</script>
