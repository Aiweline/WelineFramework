    margin-bottom: 0.5rem;
    color: var(--backend-color-text-secondary, #495057);
}
</style>

<script>
(function() {
    'use strict';

    var configFieldsData = <?= json_encode($config_fields, JSON_UNESCAPED_UNICODE) ?>;

    var WelineChannelForm = {
        onChannelCodeChange: function(code) {
            var container = document.getElementById('channelConfigFields');
            if (!code || !configFieldsData[code]) {
                container.innerHTML = '<p class="text-muted"><?= __('请先选择渠道类型') ?></p>';
                return;
            }

            var fields = configFieldsData[code];
            var html = '<h5 class="mb-3"><?= __('渠道配置') ?></h5>';

            fields.forEach(function(field) {
                var inputType = field.type === 'password' ? 'password' : 'text';
                var required = field.required ? 'required' : '';
                var requiredMark = field.required ? '<span class="text-danger">*</span>' : '';

                html += '<div class="mb-3">';
                html += '<label class="form-label">' + field.label + ' ' + requiredMark + '</label>';
                html += '<input type="' + inputType + '" class="form-control" ';
                html += 'name="channel_config[' + field.name + ']" ';
                html += 'placeholder="' + (field.placeholder || '') + '" ' + required + '>';
                html += '</div>';
            });

            container.innerHTML = html;
        },

        save: function() {
            var form = document.getElementById('channelForm');
            var formData = new FormData(form);

            var url = '<?= $this->getBackendUrl('*/backend/notificationchannel/save') ?>';
            var opts = { method: 'POST', body: new URLSearchParams(formData) };
            window.Weline.Api.request(url, opts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    BackendToast.success(data.message);
                    setTimeout(function() {
                        window.location.href = '<?= $this->getBackendUrl('*/backend/notificationchannel') ?>';
                    }, 1000);
                } else {
                    BackendToast.error(data.message);
                }
            })
            .catch(function(error) {
                console.error('Error:', error);
                BackendToast.error('<?= __('保存失败') ?>');
            });
        },

        test: function() {
            var form = document.getElementById('channelForm');
            var formData = new FormData(form);

            BackendToast.info('<?= __('正在测试连接...') ?>');

            var url = '<?= $this->getBackendUrl('*/backend/notificationchannel/test') ?>';
            var opts = { method: 'POST', body: new URLSearchParams(formData) };
            window.Weline.Api.request(url, opts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    BackendToast.success(data.message);
                } else {
                    BackendToast.error(data.message);
                }
            })
            .catch(function(error) {
                console.error('Error:', error);
                BackendToast.error('<?= __('测试失败') ?>');
            });
        }
    };

    window.WelineChannelForm = WelineChannelForm;
})();
</script>
