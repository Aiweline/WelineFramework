<script>
(function() {
    'use strict';

    var WelineSubscription = {
        toggle: function(checkbox) {
            var topicCode = checkbox.dataset.topic;
            var channel = checkbox.dataset.channel;

            window.Weline.Api.request('<?= $this->getBackendUrl('*/backend/notificationsubscription/toggle') ?>', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'topic_code=' + encodeURIComponent(topicCode) + '&channel=' + encodeURIComponent(channel)
            })
            .then(function(response) {
                var data = response.data;
                if (response.ok && data && data.success) {
                    BackendToast.success(data.message);
                    setTimeout(function() { window.location.reload(); }, 500);
                } else {
                    BackendToast.error((data && data.message) || '<?= __('操作失败') ?>');
                    checkbox.checked = !checkbox.checked;
                }
            })
            .catch(function(error) {
                console.error('Error:', error);
                BackendToast.error((error && error.message) || '<?= __('操作失败') ?>');
                checkbox.checked = !checkbox.checked;
            });
        },

        saveMinType: function(select) {
            var topicCode = select.dataset.topic;
            var channel = select.dataset.channel;
            var minType = select.value;

            window.Weline.Api.request('<?= $this->getBackendUrl('*/backend/notificationsubscription/save') ?>', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'topic_code=' + encodeURIComponent(topicCode) +
                    '&channel=' + encodeURIComponent(channel) +
                    '&min_type=' + encodeURIComponent(minType) +
                    '&is_enabled=1'
            })
            .then(function(response) {
                var data = response.data;
                if (response.ok && data && data.success) {
                    BackendToast.success(data.message);
                } else {
                    BackendToast.error((data && data.message) || '<?= __('保存失败') ?>');
                }
            })
            .catch(function(error) {
                console.error('Error:', error);
                BackendToast.error((error && error.message) || '<?= __('保存失败') ?>');
            });
        }
    };

    window.WelineSubscription = WelineSubscription;

    document.addEventListener('change', function(event) {
        if (event.target.matches('.weline-subscription-toggle')) {
            WelineSubscription.toggle(event.target);
            return;
        }

        if (event.target.matches('.weline-subscription-min-type')) {
            WelineSubscription.saveMinType(event.target);
        }
    });
})();
</script>
