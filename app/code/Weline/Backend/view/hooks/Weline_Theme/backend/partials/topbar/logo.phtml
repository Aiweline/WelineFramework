<?php
/**
 * 后台 Topbar Logo - 由 Backend 基础配置驱动，未配置时使用 Theme 默认 Logo。
 * Hook：Weline_Theme::backend::partials::topbar::logo
 * @hook-priority 100
 */
use Weline\Framework\Manager\ObjectManager;
use Weline\Theme\Helper\SiteBrand;

/** @var \Weline\Framework\View\Template $this */
$siteBrand = ObjectManager::getInstance(SiteBrand::class);
$logoDark = $siteBrand->resolveBackendLogoUrl($this, 'logo_dark', 70, 70);
$logoLight = $siteBrand->resolveBackendLogoUrl($this, 'logo_light', 70, 70);
$logoSm = $siteBrand->resolveMediaUrl('logo_sm', 50, 50);
if ($logoSm === '') {
    $logoSm = $siteBrand->resolveIconUrl($this, 50);
}

$homeUrl = $this->getBackendUrl('admin');
?>
<a href="<?= htmlspecialchars($homeUrl) ?>" class="logo logo-dark">
    <span class="logo-sm">
        <img src="<?= htmlspecialchars($logoSm) ?>" alt="logo-sm-dark" height="50">
    </span>
    <span class="logo-lg">
        <img src="<?= htmlspecialchars($logoDark) ?>" alt="logo-dark" height="70">
    </span>
</a>
<a href="<?= htmlspecialchars($homeUrl) ?>" class="logo logo-light">
    <span class="logo-sm">
        <img src="<?= htmlspecialchars($logoSm) ?>" alt="logo-sm-light" height="50">
    </span>
    <span class="logo-lg">
        <img src="<?= htmlspecialchars($logoLight) ?>" alt="logo-light" height="70">
    </span>
</a>
