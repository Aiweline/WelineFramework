<div class="multipass-account">
    <header class="multipass-account__intro">
        <h2 class="multipass-account__title"><lang>授权应用</lang></h2>
        <p class="multipass-account__desc"><lang>这里展示通过 Weline 账号授权通信登录的可信应用。撤销后，该应用的 Access Token 和 Refresh Token 会立即失效。</lang></p>
    </header>

    <?php if (empty($items)): ?>
        <div class="multipass-account__empty">
            <lang>暂无授权应用。您从 App、Skill、BBS 或 A2A 站点发起登录授权后，会在这里看到记录。</lang>
        </div>
    <?php else: ?>
        <div class="multipass-account__list">
            <?php foreach ($items as $item): ?>
                <?php
                $app = $item['app'] ?? null;
                $binding = $item['binding'] ?? null;
                $scopeDetails = (array)($item['scope_details'] ?? []);
                if (!$app || !$binding) {
                    continue;
                }
                $lastAuthorizedAt = method_exists($binding, 'getLastAuthorizedAt') ? (int)$binding->getLastAuthorizedAt() : 0;
                $lastAuthorizedText = $lastAuthorizedAt > 0 ? date('Y-m-d H:i', $lastAuthorizedAt) : (string)__('未知');
                $externalName = method_exists($binding, 'getExternalDisplayName') ? (string)$binding->getExternalDisplayName() : '';
                ?>
                <article class="multipass-account__card">
                    <div class="multipass-account__card-head">
                        <div>
                            <h3 class="multipass-account__app-name"><?= htmlspecialchars($app->getName(), ENT_QUOTES, 'UTF-8') ?></h3>
                            <p class="multipass-account__meta">
                                <?= htmlspecialchars($app->getTrustedDomain(), ENT_QUOTES, 'UTF-8') ?>
                                · <?= htmlspecialchars($app->getAppType(), ENT_QUOTES, 'UTF-8') ?>
                            </p>
                            <p class="multipass-account__meta">
                                <lang>最近授权</lang>：<?= htmlspecialchars($lastAuthorizedText, ENT_QUOTES, 'UTF-8') ?>
                                <?php if ($externalName !== ''): ?>
                                    · <lang>外部账号</lang>：<?= htmlspecialchars($externalName, ENT_QUOTES, 'UTF-8') ?>
                                <?php endif; ?>
                            </p>
                        </div>
                        <form method="post" action="<?= htmlspecialchars($revokeAction, ENT_QUOTES, 'UTF-8') ?>">
                            <?= $this->getFormKey($revokeAction) ?>
                            <input type="hidden" name="binding_id" value="<?= (int)$binding->getId() ?>">
                            <input type="hidden" name="return_url" value="<?= htmlspecialchars($returnUrl, ENT_QUOTES, 'UTF-8') ?>">
                            <button type="submit" class="multipass-account__revoke"><lang>撤销授权</lang></button>
                        </form>
                    </div>
                    <div class="multipass-account__scopes">
                        <?php foreach ($scopeDetails as $scope): ?>
                            <span class="multipass-account__scope"><?= htmlspecialchars((string)($scope['label'] ?? $scope['scope'] ?? ''), ENT_QUOTES, 'UTF-8') ?></span>
                        <?php endforeach; ?>
                    </div>
                </article>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</div>
