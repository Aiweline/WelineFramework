<script>
(function() {
    'use strict';

    var saveUrl = '<?= $this->getBackendUrl('multipass/backend/trusted-app/save') ?>';
    var rotateUrl = '<?= $this->getBackendUrl('multipass/backend/trusted-app/rotate-secret') ?>';

    function normalizeResponse(res) {
        return (res && res.data) !== undefined ? res.data : res;
    }

    function showSecret(secret) {
        document.getElementById('secretValue').textContent = secret || '';
        document.getElementById('secretPanel').style.display = secret ? 'block' : 'none';
    }

    window.copyIdentitySecret = function() {
        var secret = document.getElementById('secretValue').textContent || '';
        if (!secret) {
            return;
        }
        var textarea = document.createElement('textarea');
        textarea.value = secret;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
        BackendToast.success('<?= __('client_secret 已复制') ?>');
    };

    window.editTrustedApp = function(button) {
        var appData = JSON.parse(button.getAttribute('data-app') || '{}');
        document.getElementById('trustedAppOffcanvasTitle').textContent = '<?= __('编辑互通应用') ?>';
        document.getElementById('app_id').value = appData.app_id || '';
        document.getElementById('name').value = appData.name || '';
        document.getElementById('app_type').value = appData.app_type || 'app';
        document.getElementById('redirect_uri').value = appData.redirect_uri || '';
        document.getElementById('trusted_domain').value = appData.trusted_domain || '';
        document.getElementById('status').value = appData.status || 'active';
        document.querySelectorAll('.scope-checkbox').forEach(function(input) {
            input.checked = (appData.allowed_scopes || []).indexOf(input.value) !== -1;
        });

        var offcanvas = new bootstrap.Offcanvas(document.getElementById('trustedAppOffcanvas'));
        offcanvas.show();
    };

    window.rotateIdentitySecret = function(appId) {
        BackendConfirm.show('<?= __('确定要轮换该应用的 client_secret 吗？旧密钥会立即失效。') ?>')
            .then(function(confirmed) {
                if (!confirmed) {
                    return;
                }

                var formData = new FormData();
                formData.append('app_id', appId);
                window.Weline.Api.post(rotateUrl, formData)
                    .then(function(res) {
                        var data = normalizeResponse(res);
                        if (data.success || data.code === 200) {
                            showSecret(data.client_secret || '');
                            BackendToast.success(data.message || '<?= __('密钥已轮换') ?>');
                        } else {
                            BackendToast.error(data.message || data.msg || '<?= __('密钥轮换失败') ?>');
                        }
                    })
                    .catch(function() {
                        BackendToast.error('<?= __('请求失败') ?>');
                    });
            });
    };

    document.getElementById('trustedAppForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var formData = new FormData(this);
        window.Weline.Api.post(saveUrl, formData)
            .then(function(res) {
                var data = normalizeResponse(res);
                if (data.success || data.code === 200) {
                    showSecret(data.client_secret || '');
                    BackendToast.success(data.message || '<?= __('保存成功') ?>');
                    if (!data.client_secret) {
                        setTimeout(function() { window.location.reload(); }, 700);
                    }
                } else {
                    BackendToast.error(data.message || data.msg || '<?= __('保存失败') ?>');
                }
            })
            .catch(function() {
                BackendToast.error('<?= __('请求失败') ?>');
            });
    });

    document.querySelectorAll('[data-multipass-app-action]').forEach(function(button) {
        button.addEventListener('click', function() {
            var action = button.getAttribute('data-multipass-app-action') || '';
            if (action === 'copy-secret') {
                copyIdentitySecret();
                return;
            }
            if (action === 'edit') {
                editTrustedApp(button);
                return;
            }
            if (action === 'rotate') {
                rotateIdentitySecret(parseInt(button.getAttribute('data-app-id') || '0', 10));
            }
        });
    });

    document.getElementById('trustedAppOffcanvas').addEventListener('hidden.bs.offcanvas', function() {
        document.getElementById('trustedAppOffcanvasTitle').textContent = '<?= __('添加互通应用') ?>';
        document.getElementById('trustedAppForm').reset();
        document.getElementById('app_id').value = '';
        document.querySelectorAll('.scope-checkbox').forEach(function(input) {
            input.checked = ['profile.basic', 'profile.email', 'account.bind'].indexOf(input.value) !== -1;
        });
    });
})();
</script>
