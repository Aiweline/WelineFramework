<script>
(function() {
    'use strict';
    
    var selectedUserId = null;
    var selectedUserType = '<?= $userType ?>';
    var getUserListUrl = '<?= $this->getUrlBuilder()->getBackendUrl('multipass/backend/account/get-user-list?user_type=' . $userType . '&search=') ?>';
    var generateTokenUrl = '<?= $this->getUrlBuilder()->getBackendUrl('multipass/backend/account/generate-token') ?>';
    
    function searchUsers() {
        var search = document.getElementById('user-search').value.trim();
        var userList = document.getElementById('user-list');
        
        if (!search) {
            userList.innerHTML = '<div class="text-center text-muted py-5"><i class="mdi mdi-information-outline"></i> <?= __('请输入搜索关键词查找用户') ?></div>';
            return;
        }
        
        if (window.showLoading) showLoading();
        
        var url = getUserListUrl + encodeURIComponent(search);
        window.Weline.Api.get(url, { silent: true })
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (window.hideLoading) hideLoading();
                if (data.code === 200) {
                    displayUsers(data.data.users);
                } else {
                    showMessage('error', data.msg || '<?= __('获取用户列表失败') ?>');
                }
            })
            .catch(function(error) {
                if (window.hideLoading) hideLoading();
                showMessage('error', '<?= __('请求失败') ?>');
            });
    }
    
    function displayUsers(users) {
        var userList = document.getElementById('user-list');
        
        if (!users || users.length === 0) {
            userList.innerHTML = '<div class="text-center text-muted py-5"><i class="mdi mdi-account-off"></i> <?= __('未找到用户') ?></div>';
            return;
        }
        
        var html = '';
        users.forEach(function(user) {
            var username = (user.username || user.user_id || '').toString().replace(/'/g, "\\'").replace(/"/g, '&quot;');
            var email = (user.email || '').toString().replace(/'/g, "\\'").replace(/"/g, '&quot;');
            var avatar = (user.avatar || '').toString().replace(/"/g, '&quot;');
            var userId = user.user_id || user.id;
            var firstLetter = username ? username.charAt(0).toUpperCase() : '?';
            
            html += '<div class="weline-multipass-user-card" data-user-id="' + userId + '" data-username="' + username + '" data-email="' + email + '">' +
                '<div class="d-flex align-items-center">' +
                (avatar ? '<img src="' + avatar + '" class="rounded-circle me-2" width="40" height="40" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\';">' : '') +
                '<div class="rounded-circle bg-primary text-white me-2 d-flex align-items-center justify-content-center" style="width:40px;height:40px;' + (avatar ? 'display:none;' : '') + '">' + firstLetter + '</div>' +
                '<div class="flex-grow-1">' +
                '<div class="fw-bold">' + username + '</div>' +
                (email ? '<div class="text-muted small">' + email + '</div>' : '') +
                '</div>' +
                '<i class="mdi mdi-check-circle text-primary" style="display:none;"></i>' +
                '</div>' +
                '</div>';
        });
        
        userList.innerHTML = html;
        
        // Bind click events
        document.querySelectorAll('.weline-multipass-user-card').forEach(function(card) {
            card.addEventListener('click', function() {
                selectUser(this);
            });
        });
    }
    
    function selectUser(element) {
        selectedUserId = element.getAttribute('data-user-id');
        
        document.querySelectorAll('.weline-multipass-user-card').forEach(function(card) {
            card.classList.remove('selected');
            var checkIcon = card.querySelector('.mdi-check-circle');
            if (checkIcon) checkIcon.style.display = 'none';
        });
        
        element.classList.add('selected');
        var checkIcon = element.querySelector('.mdi-check-circle');
        if (checkIcon) checkIcon.style.display = 'block';
        
        var siteSelect = document.getElementById('site-select');
        var generateBtn = document.getElementById('generate-btn');
        
        if (siteSelect && siteSelect.value) {
            generateBtn.disabled = false;
        }
        
        var tokenResult = document.getElementById('token-result');
        if (tokenResult) tokenResult.classList.remove('show');
    }
    
    function generateToken() {
        var siteId = document.getElementById('site-select').value;
        
        if (!siteId || !selectedUserId) {
            showMessage('error', '<?= __('请先选择用户和站点') ?>');
            return;
        }
        
        if (window.showLoading) showLoading();
        
        var formData = new FormData();
        formData.append('user_id', selectedUserId);
        formData.append('site_id', siteId);
        formData.append('user_type', selectedUserType);
        
        var opts = { method: 'POST', body: formData };
        window.Weline.Api.request(generateTokenUrl, opts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (window.hideLoading) hideLoading();
                if (data.code === 200) {
                    displayTokenResult(data.data);
                } else {
                    showMessage('error', data.msg || '<?= __('生成令牌失败') ?>');
                }
            })
            .catch(function(error) {
                if (window.hideLoading) hideLoading();
                showMessage('error', '<?= __('请求失败') ?>');
            });
    }
    
    function displayTokenResult(data) {
        document.getElementById('result-site-name').textContent = data.site_name;
        document.getElementById('result-username').textContent = data.username;
        document.getElementById('result-token').textContent = data.token;
        document.getElementById('result-login-url').textContent = data.login_url;
        document.getElementById('open-login-url').href = data.login_url;
        
        document.getElementById('token-result').classList.add('show');
        document.getElementById('token-result').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    
    function copyToClipboard(text) {
        var textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
    }
    
    function showMessage(type, message) {
        if (window.AdminToast) {
            AdminToast[type === 'success' ? 'success' : 'error'](message);
        }
    }
    
    // Event bindings
    document.getElementById('multipass-search-btn').addEventListener('click', searchUsers);
    document.getElementById('user-search').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') searchUsers();
    });
    document.getElementById('site-select').addEventListener('change', function() {
        document.getElementById('generate-btn').disabled = !this.value || !selectedUserId;
    });
    document.getElementById('generate-btn').addEventListener('click', generateToken);
    document.getElementById('copy-token-btn').addEventListener('click', function() {
        copyToClipboard(document.getElementById('result-token').textContent);
        showMessage('success', '<?= __('Token已复制到剪贴板') ?>');
    });
    document.getElementById('copy-login-url-btn').addEventListener('click', function() {
        copyToClipboard(document.getElementById('result-login-url').textContent);
        showMessage('success', '<?= __('登录链接已复制到剪贴板') ?>');
    });
})();
</script>
