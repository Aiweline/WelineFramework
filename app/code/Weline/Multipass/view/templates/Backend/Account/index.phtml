<script>
let selectedUserId = null;
let selectedUserType = '<?= $userType ?>';

// 页面加载时自动选中对应的 tab
document.addEventListener('DOMContentLoaded', function() {
    const currentUserType = '<?= $userType ?>';
    const tabs = document.querySelectorAll('#user-type-tabs .nav-link');
    
    // 移除所有 active 类
    tabs.forEach(tab => {
        tab.classList.remove('active');
        tab.setAttribute('aria-selected', 'false');
        tab.setAttribute('aria-current', 'false');
    });
    
    // 选中当前对应的 tab
    tabs.forEach(tab => {
        const userType = tab.getAttribute('data-user-type');
        if (userType === currentUserType) {
            tab.classList.add('active');
            tab.setAttribute('aria-selected', 'true');
            tab.setAttribute('aria-current', 'page');
        }
    });
});

function searchUsers() {
    const search = document.getElementById('user-search').value.trim();
    const userList = document.getElementById('user-list');
    
    if (!search) {
        userList.innerHTML = '<div class="text-center text-muted py-5"><i class="mdi mdi-information-outline"></i> <?= __('请输入搜索关键词查找用户') ?></div>';
        return;
    }
    
    showLoading();
    
    fetch('<?= $this->getUrlBuilder()->getBackendUrl('multipass/backend/account/get-user-list?user_type=' . $userType . '&search=') ?>' + encodeURIComponent(search))
        .then(response => response.json())
        .then(data => {
            hideLoading();
            if (data.code === 200) {
                displayUsers(data.data.users);
            } else {
                showMessage('error', data.msg || '<?= __('获取用户列表失败') ?>');
            }
        })
        .catch(error => {
            hideLoading();
            showMessage('error', '<?= __('请求失败') ?>');
        });
}

function displayUsers(users) {
    const userList = document.getElementById('user-list');
    
    if (!users || users.length === 0) {
        userList.innerHTML = '<div class="text-center text-muted py-5"><i class="mdi mdi-account-off"></i> <?= __('未找到用户') ?></div>';
        return;
    }
    
    let html = '';
    users.forEach(user => {
        const username = (user.username || user.user_id || '').toString().replace(/'/g, "\\'").replace(/"/g, '&quot;');
        const email = (user.email || '').toString().replace(/'/g, "\\'").replace(/"/g, '&quot;');
        const avatar = (user.avatar || '').toString().replace(/"/g, '&quot;');
        const userId = user.user_id || user.id;
        const firstLetter = username ? username.charAt(0).toUpperCase() : '?';
        
        html += `
            <div class="user-card" data-user-id="${userId}" onclick="selectUser(${userId}, '${username}', '${email}', this)">
                <div class="d-flex align-items-center">
                    ${avatar ? `<img src="${avatar}" class="rounded-circle me-2" width="40" height="40" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">` : ''}
                    <div class="rounded-circle bg-primary text-white me-2 d-flex align-items-center justify-content-center" style="width:40px;height:40px;${avatar ? 'display:none;' : ''}">${firstLetter}</div>
                    <div class="flex-grow-1">
                        <div class="fw-bold">${username}</div>
                        ${email ? '<div class="text-muted small">' + email + '</div>' : ''}
                    </div>
                    <i class="mdi mdi-check-circle text-primary" style="display:none;"></i>
                </div>
            </div>
        `;
    });
    
    userList.innerHTML = html;
}

function selectUser(userId, username, email, element) {
    selectedUserId = userId;
    
    // 更新UI - 移除所有选中状态
    document.querySelectorAll('.user-card').forEach(card => {
        card.classList.remove('selected');
        const checkIcon = card.querySelector('.mdi-check-circle');
        if (checkIcon) {
            checkIcon.style.display = 'none';
        }
    });
    
    // 设置当前选中状态
    if (element) {
        element.classList.add('selected');
        const checkIcon = element.querySelector('.mdi-check-circle');
        if (checkIcon) {
            checkIcon.style.display = 'block';
        }
    }
    
    // 启用生成按钮
    const siteSelect = document.getElementById('site-select');
    const generateBtn = document.getElementById('generate-btn');
    
    if (siteSelect && siteSelect.value) {
        generateBtn.disabled = false;
    }
    
    // 隐藏之前的token结果
    const tokenResult = document.getElementById('token-result');
    if (tokenResult) {
        tokenResult.classList.remove('show');
    }
}

document.getElementById('site-select').addEventListener('change', function() {
    const generateBtn = document.getElementById('generate-btn');
    generateBtn.disabled = !this.value || !selectedUserId;
});

// 回车搜索
document.getElementById('user-search').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
        searchUsers();
    }
});

function generateToken() {
    const siteId = document.getElementById('site-select').value;
    
    if (!siteId || !selectedUserId) {
        showMessage('error', '<?= __('请先选择用户和站点') ?>');
        return;
    }
    
    showLoading();
    
    const formData = new FormData();
    formData.append('user_id', selectedUserId);
    formData.append('site_id', siteId);
    formData.append('user_type', selectedUserType);
    
    fetch('<?= $this->getUrlBuilder()->getBackendUrl('multipass/backend/account/generate-token') ?>', {
        method: 'POST',
        body: formData
    })
        .then(response => response.json())
        .then(data => {
            hideLoading();
            if (data.code === 200) {
                displayTokenResult(data.data);
            } else {
                showMessage('error', data.msg || '<?= __('生成令牌失败') ?>');
            }
        })
        .catch(error => {
            hideLoading();
            showMessage('error', '<?= __('请求失败') ?>');
        });
}

function displayTokenResult(data) {
    document.getElementById('result-site-name').textContent = data.site_name;
    document.getElementById('result-username').textContent = data.username;
    document.getElementById('result-token').textContent = data.token;
    document.getElementById('result-login-url').textContent = data.login_url;
    document.getElementById('open-login-url').href = data.login_url;
    
    document.getElementById('token-result').classList.add('show');
    
    // 滚动到结果区域
    document.getElementById('token-result').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function copyToken() {
    const token = document.getElementById('result-token').textContent;
    copyToClipboard(token);
    showMessage('success', '<?= __('Token已复制到剪贴板') ?>');
}

function copyLoginUrl() {
    const url = document.getElementById('result-login-url').textContent;
    copyToClipboard(url);
    showMessage('success', '<?= __('登录链接已复制到剪贴板') ?>');
}

function copyToClipboard(text) {
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();
    document.execCommand('copy');
    document.body.removeChild(textarea);
}

// 显示消息提示
function showMessage(type, message) {
    const alertClass = type === 'success' ? 'success' : type === 'error' ? 'danger' : type === 'warning' ? 'warning' : 'info';
    const iconClass = type === 'success' ? 'mdi-check-circle' : type === 'error' ? 'mdi-alert-circle' : type === 'warning' ? 'mdi-alert' : 'mdi-information';
    
    const messageElement = document.createElement('div');
    messageElement.className = `alert alert-${alertClass} alert-dismissible fade show`;
    messageElement.setAttribute('role', 'alert');
    messageElement.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
    messageElement.innerHTML = `
        <i class="mdi ${iconClass} me-2"></i> ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    `;
    
    // 添加到页面
    document.body.appendChild(messageElement);
    
    // 3秒后自动消失
    setTimeout(() => {
        if (messageElement.parentNode) {
            messageElement.classList.remove('show');
            setTimeout(() => {
                if (messageElement.parentNode) {
                    messageElement.parentNode.removeChild(messageElement);
                }
            }, 300);
        }
    }, 3000);
}
</script>
