<script>
(function() {
    'use strict';
    
    var saveUrl = <?= json_encode($this->getBackendUrl('multipass/backend/site/save'), $jsonForScriptFlags) ?>;
    var deleteUrl = <?= json_encode($this->getBackendUrl('multipass/backend/site/delete'), $jsonForScriptFlags) ?>;
    var listUrl = <?= json_encode($this->getBackendUrl('multipass/backend/site/index'), $jsonForScriptFlags) ?>;
    var deleteConfirmTemplate = <?= json_encode((string)__('确定要删除站点 "%{1}" 吗？此操作不可恢复。'), $jsonForScriptFlags) ?>;
    
    function generateRandomKey(length) {
        var chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
        var result = '';
        for (var i = 0; i < length; i++) {
            result += chars.charAt(Math.floor(Math.random() * chars.length));
        }
        return result;
    }
    
    window.generateKey = function() {
        document.getElementById('secret_key').value = generateRandomKey(32);
    };
    
    window.copySecretKey = function(key) {
        var textarea = document.createElement('textarea');
        textarea.value = key;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
        BackendToast.success('<?= __('密钥已复制到剪贴板') ?>');
    };
    
    window.editSite = function(siteData) {
        document.getElementById('offcanvasTitle').textContent = '<?= __('编辑站点') ?>';
        document.getElementById('site_id').value = siteData.site_id || '';
        document.getElementById('site_name').value = siteData.site_name || '';
        document.getElementById('site_url').value = siteData.site_url || '';
        document.getElementById('secret_key').value = siteData.secret_key || '';
        document.getElementById('user_type').value = siteData.user_type || 'frontend';
        document.getElementById('is_enabled').checked = siteData.is_enabled == 1;
        
        var offcanvas = new bootstrap.Offcanvas(document.getElementById('addSiteOffcanvas'));
        offcanvas.show();
    };
    
    window.deleteSite = function(siteId, siteName) {
        BackendConfirm.show(deleteConfirmTemplate.replace('%{1}', siteName || ''))
            .then(function(confirmed) {
                if (confirmed) {
                    var formData = new FormData();
                    formData.append('site_id', siteId);
                    
                    window.Weline.Api.post(deleteUrl, formData)
                        .then(function(res) {
                            var data = (res && res.data) !== undefined ? res.data : res;
                            if (data.success || data.code === 200) {
                                BackendToast.success('<?= __('站点删除成功') ?>');
                                setTimeout(function() { window.location.reload(); }, 1000);
                            } else {
                                BackendToast.error(data.message || data.msg || '<?= __('删除失败') ?>');
                            }
                        })
                        .catch(function() {
                            BackendToast.error('<?= __('请求失败') ?>');
                        });
                }
            });
    };

    document.querySelectorAll('[data-multipass-site-action]').forEach(function(button) {
        button.addEventListener('click', function() {
            var action = button.getAttribute('data-multipass-site-action') || '';
            if (action === 'copy-secret') {
                copySecretKey(button.getAttribute('data-secret-key') || '');
                return;
            }
            if (action === 'edit') {
                try {
                    editSite(JSON.parse(button.getAttribute('data-site') || '{}'));
                } catch (e) {
                    BackendToast.error('<?= __('站点数据解析失败') ?>');
                }
                return;
            }
            if (action === 'delete') {
                deleteSite(parseInt(button.getAttribute('data-site-id') || '0', 10), button.getAttribute('data-site-name') || '');
                return;
            }
            if (action === 'generate-key') {
                generateKey();
            }
        });
    });
    
    document.getElementById('siteForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        var formData = new FormData(this);
        
        window.Weline.Api.post(saveUrl, formData)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success || data.code === 200) {
                    BackendToast.success('<?= __('站点保存成功') ?>');
                    setTimeout(function() { window.location.reload(); }, 1000);
                } else {
                    BackendToast.error(data.message || data.msg || '<?= __('保存失败') ?>');
                }
            })
            .catch(function() {
                BackendToast.error('<?= __('请求失败') ?>');
            });
    });
    
    document.getElementById('addSiteOffcanvas').addEventListener('hidden.bs.offcanvas', function() {
        document.getElementById('offcanvasTitle').textContent = '<?= __('添加站点') ?>';
        document.getElementById('siteForm').reset();
        document.getElementById('site_id').value = '';
        document.getElementById('is_enabled').checked = true;
    });
})();
</script>
