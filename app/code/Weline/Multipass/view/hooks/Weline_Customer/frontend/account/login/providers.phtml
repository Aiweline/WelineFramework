<?php
/**
 * Multipass official account login provider.
 *
 * Hook: Weline_Customer::frontend::account::login::providers
 *
 * @hook-priority 120
 * @hook-sort-order 20
 * @hook-solo false
 *
 * @var \Weline\Framework\View\Template $this
 */

use Weline\Framework\Manager\ObjectManager;
use Weline\Multipass\Service\IdentityClientService;

try {
    /** @var IdentityClientService $identityClientService */
    $identityClientService = ObjectManager::getInstance(IdentityClientService::class);
    $provider = $identityClientService->getDefaultProvider();
} catch (\Throwable) {
    $provider = null;
}

if (!$provider || !$provider->isActive()) {
    return;
}

$loginUrl = $this->getFrontendUrl('multipass/frontend/identity/login');
$returnUrl = (string) ($this->getData('redirect_url') ?? '');
$query = [
    'provider_id' => $provider->getId(),
];
if ($returnUrl !== '') {
    $query['return_url'] = $returnUrl;
}
$loginUrl .= (str_contains($loginUrl, '?') ? '&' : '?') . http_build_query($query);
?>
<div class="auth-form__provider auth-form__provider--multipass" style="margin-top: 1rem;">
    <a class="auth-form__submit"
       style="display:flex;align-items:center;justify-content:center;gap:.5rem;text-decoration:none;"
       href="<?= htmlspecialchars($loginUrl, ENT_QUOTES, 'UTF-8') ?>">
        <i class="ri-shield-user-line" aria-hidden="true"></i>
        <span><?= __('使用官网登录') ?></span>
    </a>
</div>
