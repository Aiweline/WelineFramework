<?php
/**
 * Weline_Multipass module - account identity bridge content.
 *
 * Hook: account.sidebar.content
 *
 * @hook-priority 170
 * @hook-sort-order 12
 * @hook-solo false
 */
use Weline\Customer\Api\View\AccountSidebarProjectionProviderInterface;
use Weline\Framework\Manager\ObjectManager;
use Weline\Framework\Runtime\RuntimeProviderResolver;
use Weline\Multipass\Service\IdentityBridgeService;

$projectionProvider = ObjectManager::getInstance(RuntimeProviderResolver::class)
    ->resolve(AccountSidebarProjectionProviderInterface::class);
if (!$projectionProvider instanceof AccountSidebarProjectionProviderInterface) {
    throw new \LogicException('Required Customer account sidebar projection provider is unavailable.');
}

$projection = $projectionProvider->forSections('identity-bridge', 'multipass-developer-apps');
if ($projection === null) {
    return;
}

$customerId = $projection->getCustomerId();
$identityBridgeService = ObjectManager::getInstance(IdentityBridgeService::class);
?>
<?php if ($projection->isSection('identity-bridge')): ?>
    <?php
    $identityBindings = [];
    if ($customerId !== null) {
        $identityBindings = $identityBridgeService->listBindingsForCustomer($customerId);
    }
    $this->assign('identity_bindings', $identityBindings);
    ?>
<section class="account-hook-section account-index__section d-none" id="identity-bridge-section" data-account-section="identity-bridge" hidden>
    <?= $this->fetch('Weline_Multipass::templates/frontend/account/identity-bridge.phtml') ?>
</section>
<?php elseif ($projection->isSection('multipass-developer-apps')): ?>
    <?php
    $developerApplications = [];
    if ($customerId !== null) {
        $developerApplications = $identityBridgeService->listDeveloperApplicationsForCustomer($customerId);
    }
    $this->assign('developer_applications', $developerApplications);
    $this->assign('developer_application_auto_approve', $identityBridgeService->isDeveloperApplicationAutoApproveEnabled());
    ?>
<section class="account-hook-section account-index__section d-none" id="multipass-developer-apps-section" data-account-section="multipass-developer-apps" hidden>
    <?= $this->fetch('Weline_Multipass::templates/frontend/account/developer-applications.phtml') ?>
</section>
<?php endif; ?>
