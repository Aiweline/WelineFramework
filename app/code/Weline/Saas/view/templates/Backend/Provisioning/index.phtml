$totalPages = (int) $this->getData('totalPages');
$search = (string) $this->getData('search');
$status = (string) $this->getData('status');
$statusList = $this->getData('statusList') ?: [];
$orderIdField = \Weline\Saas\Model\ProvisioningOrder::fields_ORDER_ID;
