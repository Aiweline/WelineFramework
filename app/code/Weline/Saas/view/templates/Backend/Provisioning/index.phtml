            <select name="status" class="form-select form-select-sm" style="max-width:120px;">
                <?php foreach ($statusList as $k => $v): ?>
                    <option value="<?= htmlspecialchars($k) ?>" <?= $status === $k ? 'selected' : '' ?>><?= htmlspecialchars($v) ?></option>
                <?php endforeach; ?>
            </select>
            <button type="submit" class="btn btn-sm btn-primary flex-shrink-0"><i class="mdi mdi-magnify"></i> <?= __('搜索') ?></button>
            <a href="<?= $this->getBackendUrl('*/backend/provisioning/index') ?>" class="btn btn-sm btn-secondary flex-shrink-0"><i class="mdi mdi-refresh"></i> <?= __('重置') ?></a>
        </form>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th><?= __('订单ID') ?></th>
                                <th><?= __('域名') ?></th>
                                <th><?= __('状态') ?></th>
                                <th><?= __('当前步骤') ?></th>
                                <th><?= __('错误信息') ?></th>
                                <th><?= __('创建时间') ?></th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php if (empty($items)): ?>
                                <tr><td colspan="6" class="text-center text-muted"><?= __('暂无数据') ?></td></tr>
                            <?php else: ?>
                                <?php foreach ($items as $row): ?>
                                    <tr>
                                        <td><?= (int)($row[$orderIdField] ?? 0) ?></td>
                                        <td><?= htmlspecialchars($row[$domainField] ?? '') ?></td>
                                        <td><?= htmlspecialchars($row[$statusField] ?? '') ?></td>
                                        <td><?= htmlspecialchars($row[$currentStepField] ?? '') ?></td>
                                        <td class="text-danger small"><?= htmlspecialchars($row[$errorField] ?? '') ?></td>
                                        <td><?= htmlspecialchars($row[$createdField] ?? '') ?></td>
                                    </tr>
                                <?php endforeach; ?>
                            <?php endif; ?>
