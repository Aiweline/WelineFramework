$currentStepField = \Weline\Saas\Model\ProvisioningOrder::fields_CURRENT_STEP;
$errorField = \Weline\Saas\Model\ProvisioningOrder::fields_ERROR_MESSAGE;
$createdField = \Weline\Saas\Model\ProvisioningOrder::fields_CREATED_AT;
?>
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0">
                <i class="mdi mdi-cloud-check text-primary"></i> <?= __('SaaS 配置订单') ?>
            </h4>
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="<?= $this->getBackendUrl('admin') ?>"><?= __('首页') ?></a></li>
                    <li class="breadcrumb-item"><?= __('SaaS 一站式配置') ?></li>
                    <li class="breadcrumb-item active"><?= __('配置订单') ?></li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="row"><template>Weline_Component::message.phtml</template></div>

