<!-- 图片预览容器 -->
@template(Weline_FileManager::image-preview/template.phtml)

<!-- 触发按钮 -->
<button type="button" class="btn btn-primary btn-sm waves-effect waves-light" 
        onclick="WelineMediaManager_{{target}}_open()">{{title}}</button>
<if condition="ext !== '*'"><br><span>@lang{允许的文件类型：}({{ext}})</span></if>
<br>
<span>@lang{允许的文件大小：}{{size_alias}}</span>

<!-- 自定义 Modal -->
<div id="{{target}}-modal-overlay" class="wm-modal-overlay" onclick="if(event.target===this)WelineMediaManager_{{target}}_close()">
    <div class="wm-modal-container">
        <div class="wm-modal-header">
            <h5 class="wm-modal-title">
                {{title}}
                <if condition="ext !== '*'"><span class="wm-modal-hint">@lang{允许的文件类型：}({{ext}})</span></if>
                <span class="wm-modal-hint">@lang{允许的文件大小：}{{size_alias}}</span>
            </h5>
            <button type="button" class="wm-modal-close" onclick="WelineMediaManager_{{target}}_close()">&times;</button>
        </div>
        <div class="wm-modal-body">
            <iframe id="{{target}}-file-manager-iframe" class="wm-modal-iframe" src="" frameborder="0"
                    data-connector="{{connector}}"></iframe>
        </div>
    </div>
</div>

<style>
/* weline-media 弹窗：使用主题变量，兼容暗色/亮色模式 */
.wm-modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--backend-color-bg-overlay, rgba(0, 0, 0, 0.5));
    z-index: 9999;
    justify-content: center;
    align-items: center;
}
.wm-modal-overlay.wm-show {
    display: flex;
}
.wm-modal-container {
    background: var(--backend-color-card-bg, #fff);
    border: 1px solid var(--backend-color-card-border, #dee2e6);
    border-radius: 8px;
    width: 90%;
    max-width: 1200px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    box-shadow: var(--backend-shadow-2xl, 0 25px 50px -12px rgba(0, 0, 0, 0.25));
}
.wm-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    border-bottom: 1px solid var(--backend-color-border-default, #dee2e6);
}
.wm-modal-title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    color: var(--backend-color-text-primary, #212529);
}
.wm-modal-hint {
    font-size: 12px;
    color: var(--backend-color-text-muted, #6c757d);
    margin-left: 10px;
}
.wm-modal-close {
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: var(--backend-color-text-muted, #6c757d);
    padding: 0;
    line-height: 1;
}
.wm-modal-close:hover {
    color: var(--backend-color-danger, #f46a6a);
}
.wm-modal-body {
    flex: 1;
    overflow: hidden;
    min-height: 70vh;
    background: var(--backend-color-card-bg, #fff);
}
.wm-modal-iframe {
    width: 100%;
    height: 70vh;
    border: none;
}
.wm-preview-item {
    display: inline-block;
    position: relative;
    margin: 4px;
    border: 1px solid var(--backend-color-border-default, #dee2e6);
    border-radius: 4px;
    overflow: hidden;
}
.wm-preview-img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    display: block;
}
.wm-preview-close {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 18px;
    height: 18px;
    background: var(--backend-color-danger, #f46a6a);
    color: var(--backend-color-text-inverse, #fff);
    border-radius: 50%;
    font-size: 14px;
    line-height: 16px;
    text-align: center;
    cursor: pointer;
    z-index: 1;
}
.wm-preview-close:hover {
    background: var(--backend-color-danger-hover, #f24a4a);
}
</style>

<script>
function WelineMediaManager_{{target}}_open() {
    var overlay = document.getElementById('{{target}}-modal-overlay');
    var iframe = document.getElementById('{{target}}-file-manager-iframe');
    if (!overlay) { alert('Modal not found'); return; }
    
    overlay.classList.add('wm-show');
    document.body.style.overflow = 'hidden';
    
    if (iframe) {
        var currentSrc = iframe.getAttribute('src');
        var connectorUrl = iframe.getAttribute('data-connector');
        if ((!currentSrc || currentSrc === '') && connectorUrl) {
            iframe.src = connectorUrl;
        }
    }
}

function WelineMediaManager_{{target}}_close() {
    var overlay = document.getElementById('{{target}}-modal-overlay');
    if (overlay) {
        overlay.classList.remove('wm-show');
        document.body.style.overflow = '';
    }
}

(function() {
    var targetId = '{{target}}';
    
    document.addEventListener('keydown', function(e) {
        var overlay = document.getElementById(targetId + '-modal-overlay');
        if (e.key === 'Escape' && overlay && overlay.classList.contains('wm-show')) {
            WelineMediaManager_{{target}}_close();
        }
    });
    
    window.addEventListener('message', function(e) {
        if (!e.data) return;
        
        // 处理取消消息
        if (e.data.type === 'weline-media-manager-cancel') {
            if (e.data.target && e.data.target !== targetId) return;
            WelineMediaManager_{{target}}_close();
            return;
        }
        
        if (e.data.type !== 'weline-media-manager-select') return;
        if (e.data.target && e.data.target !== targetId) return;
        
        var files = e.data.files || [];
        if (!files.length) return;
        
        var paths = [];
        files.forEach(function(f) {
            if (f.path) {
                paths.push(f.path);
            } else if (f.url) {
                paths.push(f.url);
            } else if (f.name) {
                paths.push(f.name);
            }
        });
        
        var isMulti = e.data.multi;
        var targetEl = document.getElementById(targetId);
        
        if (targetEl) {
            var value;
            if (isMulti && targetEl.value) {
                value = targetEl.value + ',' + paths.join(',');
            } else {
                value = paths.join(',');
            }
            
            if (targetEl.tagName === 'INPUT' || targetEl.tagName === 'TEXTAREA') {
                targetEl.value = value;
                targetEl.dispatchEvent(new Event('change', { bubbles: true }));
                targetEl.dispatchEvent(new Event('input', { bubbles: true }));
            } else {
                targetEl.textContent = value;
            }
        }
        
        var previewContainer = document.getElementById(targetId + '-preview');
        if (previewContainer) {
            if (!isMulti) {
                previewContainer.innerHTML = '';
            }
            files.forEach(function(f) {
                // 兼容 FileManager 预览模板的 HTML 结构（drag-item, drag-pic, data-src）
                var wrapper = document.createElement('div');
                wrapper.className = 'drag-item';
                wrapper.draggable = true;
                var relativePath = (f.path || f.url || '').replace(/^\/pub\/media\//, '');
                wrapper.innerHTML = '<div class="close" onclick="delSelectedImage(event)">x</div>' +
                    '<img data-src="' + relativePath + '" src="' + (f.thumb || f.url || f.path) + '" alt="' + (f.name || '') + '" class="drag-pic img-responsive" draggable="false" data-file="">';
                previewContainer.appendChild(wrapper);
            });
            // 触发 flushSelectedImage（如果存在）来同步隐藏输入框的值
            if (typeof flushSelectedImage === 'function') {
                flushSelectedImage();
            }
        }
        
        WelineMediaManager_{{target}}_close();
    });
})();
</script>

<notempty name="preview">
<script>
(function() {
    var previewContainer = document.getElementById('{{target}}-preview');
    if (!previewContainer) return;
    
    previewContainer.addEventListener('click', function(e) {
        var img = e.target.closest('.img');
        if (!img) return;
        
        var url = img.dataset.url;
        if (!url) return;
        
        var iframe = document.getElementById('{{target}}-file-manager-iframe');
        if (iframe) {
            iframe.src = url;
            var overlay = document.getElementById('{{target}}-modal-overlay');
            if (overlay) {
                overlay.classList.add('wm-show');
                document.body.style.overflow = 'hidden';
            }
        }
    });
})();
</script>
</notempty>
