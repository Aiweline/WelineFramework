<script>
(function() {
    'use strict';
    var baseUrl = '<?= htmlspecialchars((string)$this->getBackendUrl('*/backend/cron/listing')) ?>';
    var params = new URLSearchParams(window.location.search);
    function applyFilters(overrides) {
        var url = new URL(baseUrl, window.location.origin);
        var q = params.get('q');
        if (q) url.searchParams.set('q', q);
        var status = overrides.status !== undefined ? overrides.status : params.get('status');
        if (status) url.searchParams.set('status', status);
        var module = overrides.module !== undefined ? overrides.module : params.get('module');
        if (module) url.searchParams.set('module', module);
        window.location.href = url.toString();
    }
    var statusFilter = document.getElementById('weline-cron-status-filter');
    if (statusFilter) {
        statusFilter.addEventListener('change', function() { applyFilters({ status: this.value }); });
    }
    var moduleFilter = document.getElementById('weline-cron-module-filter');
    if (moduleFilter) {
        moduleFilter.addEventListener('change', function() { applyFilters({ module: this.value }); });
    }
    // 手风琴：点击整行展开/收起任务描述（操作列点击不触发展开）
    function toggleTaskDetail(mainRow) {
        var detailId = mainRow.getAttribute('data-detail-id');
        var detailRow = detailId ? document.getElementById(detailId) : null;
        if (!detailRow) return;
        var expanded = mainRow.classList.toggle('weline-cron-row-expanded');
        detailRow.style.display = expanded ? 'table-row' : 'none';
        detailRow.setAttribute('aria-hidden', !expanded);
    }
    document.querySelectorAll('.weline-cron-row-toggle').forEach(function(tr) {
        tr.addEventListener('click', function(ev) {
            if (ev.target.closest('.weline-cron-actions-cell')) return;
            toggleTaskDetail(tr);
        });
        tr.addEventListener('keydown', function(ev) {
            if (ev.key === 'Enter' || ev.key === ' ') {
                ev.preventDefault();
                if (!ev.target.closest('.weline-cron-actions-cell')) toggleTaskDetail(tr);
            }
        });
    });
})();
</script>

