                                    ];
                                    $taskStatus = $task['status'] ?? 'pending';
                                    $st = $statusMap[$taskStatus] ?? $statusMap['pending'];
                                    $runningDuration = ($taskStatus === 'running' && !empty($task['running_duration_human'])) ? $task['running_duration_human'] : '';
