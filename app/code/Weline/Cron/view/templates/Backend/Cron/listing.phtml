<script>
(function() {
    'use strict';
    var runStreamUrl = '<?= $welineCronRunStreamUrl ?>';
    var runHelpUrl = '<?= $welineCronRunHelpUrl ?>';
    var modal = document.getElementById('weline-cron-run-modal');
    if (!modal) return;
    /** 最近一次点击「运行」的按钮；SSE POST 的 execute_name 必须取自其 data-execute-name，避免 id 重复导致隐藏域错乱 */
    var welineCronRunSourceBtn = null;

    function closeModal() {
        modal.classList.remove('is-open');
        var term = window.WelineSseTerminal && window.WelineSseTerminal['weline-cron-run-terminal'];
        if (term && typeof term.stop === 'function') term.stop();
    }
    function openModal() {
        modal.classList.add('is-open');
    }

    function fillHelp(executeName) {
        var body = document.getElementById('weline-cron-run-help-body');
        if (!body) return;
        body.textContent = '<?= addslashes((string) __('加载中')) ?>…';
        fetch(runHelpUrl + '?execute_name=' + encodeURIComponent(executeName), {
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            credentials: 'same-origin'
        }).then(function(r) { return r.json(); }).then(function(j) {
            if (!j || !j.success) {
                body.textContent = (j && j.message) ? j.message : '<?= addslashes((string) __('加载失败')) ?>';
                return;
            }
            var parts = [];
            parts.push('<?= addslashes((string) __('调度说明')) ?>\n' + (j.tip || '-'));
            if (j.manual_args_hint) parts.push('\n\n<?= addslashes((string) __('手动参数')) ?>\n' + j.manual_args_hint);
            if (j.test_help_description) parts.push('\n\n<?= addslashes((string) __('测试说明')) ?>\n' + j.test_help_description);
            if (j.test_help_examples && j.test_help_examples.length) {
                parts.push('\n\n<?= addslashes((string) __('示例')) ?>:\n' + j.test_help_examples.join('\n'));
            }
            body.textContent = parts.join('');
        }).catch(function() {
            body.textContent = '<?= addslashes((string) __('加载失败')) ?>';
        });
    }

    document.querySelectorAll('.weline-cron-run-btn').forEach(function(btn) {
        btn.addEventListener('click', function(ev) {
            ev.preventDefault();
            ev.stopPropagation();
            welineCronRunSourceBtn = btn;
            var executeName = (btn.getAttribute('data-execute-name') || '').trim();
            var tn = (btn.getAttribute('data-task-name') || '').trim();
            modal.setAttribute('data-weline-cron-execute-name', executeName);
            var hid = document.getElementById('weline-cron-run-execute-name');
            if (hid) hid.value = executeName;
            var sub = document.getElementById('weline-cron-run-modal-title-task');
            if (sub) sub.textContent = tn ? (tn + (executeName ? ' · ' + executeName : '')) : (executeName ? '(' + executeName + ')' : '');
            document.getElementById('weline-cron-run-suffix').value = '';
            var details = document.getElementById('weline-cron-run-help-details');
            if (details) details.open = false;
            fillHelp(executeName);
            openModal();
        });
    });

    ['weline-cron-run-modal-close', 'weline-cron-run-close-btn', 'weline-cron-run-modal-backdrop'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('click', function() { closeModal(); });
    });

    document.getElementById('weline-cron-run-start-btn').addEventListener('click', function() {
        var term = window.WelineSseTerminal && window.WelineSseTerminal['weline-cron-run-terminal'];
        if (!term) return;
        var enPost = '';
        if (welineCronRunSourceBtn && welineCronRunSourceBtn.getAttribute) {
            enPost = (welineCronRunSourceBtn.getAttribute('data-execute-name') || '').trim();
        }
        if (!enPost) {
            enPost = (modal.getAttribute('data-weline-cron-execute-name') || '').trim();
        }
        if (!enPost) {
            var h = document.getElementById('weline-cron-run-execute-name');
            enPost = h ? (h.value || '').trim() : '';
        }
        if (!enPost) {
            var hint = document.getElementById('weline-cron-run-hint');
            if (hint) hint.textContent = '<?= addslashes((string) __('请先点击列表中的「运行」选择任务')) ?>';
            return;
        }
        var fd = new FormData();
        fd.append('csrf', document.getElementById('weline-cron-sse-csrf').value);
        fd.append('execute_name', enPost);
        fd.append('suffix', document.getElementById('weline-cron-run-suffix').value);
        if (typeof term.clear === 'function') term.clear();
        term.start(runStreamUrl, { method: 'POST', body: fd });
    });
})();
</script>
