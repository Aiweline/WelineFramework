    function updateAuthAndCredentials() {
        var credentialFields = document.getElementById('social-credential-fields');
        var oneClickWrap = document.getElementById('social-one-click-auth-wrap');
        var manualHint = document.getElementById('social-manual-auth-hint');
        var platformCode = getAccountPlatformCode();
        var platform = platformMap[platformCode] || {};
        var modes = Array.isArray(platform.auth_modes) ? platform.auth_modes.slice() : [];
        if (modes.indexOf('profile_only') === -1) {
            modes.push('profile_only');
        }
        var authChoice = getSocialChoice('social-auth-mode');
        var currentAuth = getAccountAuthMode() || 'profile_only';
        var authOptions = modes.map(function (mode) {
            return {
                value: mode,
                label: mode === 'profile_only' ? '<?= $h((string)__('仅展示')) ?>' : mode,
                meta: mode
            };
        });
        if (authChoice) {
            authChoice.setOptions(authOptions);
            if (!modes.some(function (mode) { return mode === currentAuth; })) {
                currentAuth = modes[0] || 'profile_only';
            }
            authChoice.setValue(currentAuth, true);
        }
        credentialFields.innerHTML = '';
        (Array.isArray(platform.config_fields) ? platform.config_fields : []).forEach(function (field) {
            var wrap = document.createElement('div');
            var label = document.createElement('label');
            var input = document.createElement('input');
            var key = String(field.key || '');
            if (!key) {
                return;
            }
            label.className = 'form-label';
            label.textContent = String(field.label || key);
            input.className = 'form-control';
            input.type = String(field.type || 'text') === 'password' ? 'password' : 'text';
            input.name = 'credential_' + key;
            input.setAttribute('data-credential-key', key);
            input.placeholder = field.required ? '<?= $h((string)__('必填')) ?>' : '<?= $h((string)__('可选')) ?>';
            wrap.appendChild(label);
            wrap.appendChild(input);
            credentialFields.appendChild(wrap);
        });
        var supportsOneClick = !!platform.supports_one_click_auth;
        if (oneClickWrap) {
            oneClickWrap.classList.toggle('d-none', !supportsOneClick);
        }
        if (manualHint) {
            manualHint.classList.toggle('d-none', supportsOneClick);
        }
    }

