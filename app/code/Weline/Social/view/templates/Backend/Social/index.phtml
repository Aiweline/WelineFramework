$queryProvider = (string)($this->getData('query_provider') ?? 'welineSocial');
$fakeSmokeUrl = (string)($this->getData('fake_smoke_url') ?? '/weline_social/frontend/social/smoke?fake=1');
$h = static fn(mixed $value): string => htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8');
$json = static fn(mixed $value): string => str_replace('</', '<\/', json_encode($value, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?: '{}');
$publishableAccounts = array_values(array_filter($accounts, static function (mixed $account): bool {
    return is_array($account)
        && (string)($account['status'] ?? '') === 'active'
        && (int)($account['publish_enabled'] ?? 0) === 1
        && (string)($account['test_status'] ?? '') === 'passed';
}));
$socialWebsiteSelectOptions = [];
foreach ($socialScopes as $group) {
    if (!is_array($group)) {
        continue;
    }
    foreach ((array)($group['items'] ?? []) as $item) {
        if (!is_array($item)) {
            continue;
        }
        $scopeId = (int)($item['scope_id'] ?? -1);
        if ($scopeId < 0) {
            continue;
        }
        $socialWebsiteSelectOptions[] = [
            'value' => (string)$scopeId,
            'label' => (string)($item['scope_title'] ?? $item['scope_label'] ?? $item['scope_code'] ?? $scopeId),
            'meta' => (string)($item['scope_code'] ?? ''),
        ];
    }
}
$socialWebsiteSelectOptionsJson = json_encode($socialWebsiteSelectOptions, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?: '[]';
$socialWebsiteSelectEmptyLabel = (string)__('请选择站点');
$socialWebsiteSelectPlaceholder = (string)__('搜索站点名称或编码');
