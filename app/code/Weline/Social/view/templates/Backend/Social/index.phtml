$accounts = (array)($this->getData('accounts') ?? []);
$websites = (array)($this->getData('websites') ?? []);
$socialScopes = (array)($this->getData('social_scopes') ?? []);
$websiteRelations = (array)($this->getData('website_relations') ?? []);
$scopeRelations = (array)($this->getData('scope_relations') ?? $websiteRelations);
$drafts = (array)($this->getData('drafts') ?? []);
$batches = (array)($this->getData('batches') ?? []);
