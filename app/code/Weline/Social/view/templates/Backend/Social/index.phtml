                <label class="form-label"><?= __('发布账户') ?></label>
                <div class="d-flex flex-wrap gap-3">
                    <?php foreach ($publishableAccounts as $account): ?>
                        <label class="form-check">
                            <input class="form-check-input" type="checkbox" name="account_ids[]" value="<?= (int)($account['account_id'] ?? 0) ?>">
                            <span class="form-check-label"><?= $h((string)($account['account_name'] ?? '')) ?></span>
                        </label>
                    <?php endforeach; ?>
                    <?php if ($publishableAccounts === []): ?><span class="text-muted"><?= __('暂无可发布账户。') ?></span><?php endif; ?>
                </div>
            </div>
            <div class="col-12">
                <button class="btn btn-primary" type="submit" <?= $publishableAccounts === [] ? 'disabled' : '' ?>><?= __('创建发布批次') ?></button>
                <span class="small text-muted ms-2"><?= __('默认按当前范围配置的社媒账户发布内容。') ?></span>
                <span class="small social-status ms-2" id="social-publish-status"></span>
            </div>
        </form>
    </section>

    <section class="workband mb-3 d-none" data-social-panel="records">
        <h5 class="mb-3"><?= __('发布记录') ?></h5>
        <?php if ($batches === []): ?><div class="text-muted"><?= __('暂无发布批次。') ?></div><?php endif; ?>
        <?php foreach ($batches as $batch): ?>
            <?php if (!is_array($batch)) { continue; } ?>
            <div class="border-bottom py-2">
                <div class="fw-semibold">#<?= (int)($batch['batch_id'] ?? 0) ?> <?= $h((string)($batch['title'] ?? '')) ?></div>
                <div class="small text-muted">
                    <?= $h((string)($batch['status'] ?? '')) ?> · <?= (int)($batch['success_count'] ?? 0) ?>/<?= (int)($batch['target_count'] ?? 0) ?>
                </div>
            </div>
        <?php endforeach; ?>
    </section>

    <section class="workband">
        <h5 class="mb-2"><?= __('扩展与平台族') ?></h5>
        <div class="d-flex flex-wrap gap-2">
            <?php foreach ($families as $family => $count): ?>
                <span class="badge bg-primary-subtle text-primary"><?= $h((string)$family) ?> <?= (int)$count ?></span>
            <?php endforeach; ?>
        </div>
        <?php if ($warnings !== []): ?>
            <div class="alert alert-warning mt-3 mb-0">
                <?php foreach ($warnings as $warning): ?>
                    <div><?= $h($warning) ?></div>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>
    </section>
</div>

<script type="application/json" id="weline-social-platform-json"><?= $json($platforms) ?></script>
<script type="application/json" id="weline-social-account-json"><?= $json($accounts) ?></script>
<script type="application/json" id="weline-social-website-json"><?= $json($websites) ?></script>
<script type="application/json" id="weline-social-website-relation-json"><?= $json($websiteRelations) ?></script>
<script type="application/json" id="weline-social-scope-json"><?= $json($socialScopes) ?></script>
<script type="application/json" id="weline-social-scope-relation-json"><?= $json($scopeRelations) ?></script>
<script>
(function () {
    var provider = '<?= $h($queryProvider) ?>';
    var platforms = JSON.parse(document.getElementById('weline-social-platform-json').textContent || '[]');
    var accounts = JSON.parse(document.getElementById('weline-social-account-json').textContent || '[]');
    var socialScopes = JSON.parse(document.getElementById('weline-social-scope-json').textContent || '[]');
    var scopeRelations = JSON.parse(document.getElementById('weline-social-scope-relation-json').textContent || '[]');
    var platformMap = {};
    var accountMap = {};
    var relationsByScope = {};
    var currentScope = null;
    var pendingScopeAssign = false;
    var messages = {
        queryUnavailable: '<?= $h((string)__('后台查询接口尚未就绪。')) ?>',
        saving: '<?= $h((string)__('正在保存账户...')) ?>',
        saved: '<?= $h((string)__('账户保存完成。')) ?>',
        scopeSaving: '<?= $h((string)__('正在保存范围默认社媒...')) ?>',
        scopeSaved: '<?= $h((string)__('范围默认社媒已保存。')) ?>',
        resolvingDefaults: '<?= $h((string)__('正在解析范围默认社媒...')) ?>',
        testing: '<?= $h((string)__('正在检测账户...')) ?>',
        disabled: '<?= $h((string)__('账户已禁用。')) ?>',
        working: '<?= $h((string)__('正在处理...')) ?>',
        bindingScope: '<?= $h((string)__('正在绑定到当前范围...')) ?>',
        bindAfterSave: '<?= $h((string)__('保存后会自动绑定到当前范围：')) ?>',
        currentScope: '<?= $h((string)__('当前范围：')) ?>',
        addedFromPlatform: '<?= $h((string)__('已选择平台，保存账户后会加入当前范围。')) ?>',
        generated: '<?= $h((string)__('创意草稿已生成。')) ?>',
        batchCreated: '<?= $h((string)__('发布批次已创建。')) ?>',
        needAccount: '<?= $h((string)__('请选择发布账户。')) ?>',
        needScope: '<?= $h((string)__('请选择一级范围和二级范围。')) ?>',
        needDraft: '<?= $h((string)__('请填写草稿 ID。')) ?>'
    };

    platforms.forEach(function (platform) {
        if (platform && platform.code) {
            platformMap[String(platform.code)] = platform;
        }
    });
    accounts.forEach(function (account) {
        if (account && account.account_id) {
            accountMap[String(account.account_id)] = account;
        }
    });
    scopeRelations.forEach(function (relation) {
        if (!relation || !relation.account_id || relation.status !== 'active') {
            return;
        }
        var key = relation.scope_key || buildScopeKey(relation);
        if (!relationsByScope[key]) {
            relationsByScope[key] = [];
        }
        relationsByScope[key].push(Number(relation.account_id || 0));
    });

    function setStatus(id, text, type) {
        var node = document.getElementById(id);
        if (!node) {
            return;
        }
        node.textContent = text || '';
        node.className = 'small social-status ' + (type === 'error' ? 'text-danger' : type === 'success' ? 'text-success' : 'text-muted');
    }

    function callSocial(operation, params) {
        if (!window.Weline || !window.Weline.Query || typeof window.Weline.Query.request !== 'function') {
            return Promise.reject(new Error(messages.queryUnavailable));
        }
        return window.Weline.Query.request(provider, operation, params || {}, {area: 'backend'});
    }

    function activateTab(name) {
        document.querySelectorAll('[data-social-tab]').forEach(function (item) { item.classList.remove('active'); });
        document.querySelectorAll('[data-social-panel]').forEach(function (panel) { panel.classList.add('d-none'); });
        var tab = document.querySelector('[data-social-tab="' + name + '"]');
        var panel = document.querySelector('[data-social-panel="' + name + '"]');
        if (tab) {
            tab.classList.add('active');
        }
        if (panel) {
            panel.classList.remove('d-none');
        }
    }

    function buildScopeKey(scope) {
        return [
            String(scope.scope_type || 'website'),
            String(Number(scope.scope_id || scope.website_id || 0)),
            String(scope.child_scope_type || 'website_default'),
            String(Number(scope.child_scope_id || 0))
        ].join(':');
    }

    function scopePayload(scope) {
        if (!scope) {
            return {};
        }
        return {
            scope_type: String(scope.scope_type || 'website'),
            scope_id: Number(scope.scope_id || 0),
            child_scope_type: String(scope.child_scope_type || 'website_default'),
            child_scope_id: Number(scope.child_scope_id || 0),
            website_id: Number(scope.website_id || scope.scope_id || 0)
        };
    }

    function scopeDisplay(scope) {
        if (!scope) {
            return '<?= $h((string)__('未选择范围')) ?>';
        }
        return String(scope.display_label || ((scope.scope_label || '') + ' / ' + (scope.child_scope_label || ''))).replace(/^\\s+|\\s+$/g, '');
    }

    function findScopeGroup(type) {
        var groups = Array.isArray(socialScopes) ? socialScopes : [];
        for (var i = 0; i < groups.length; i++) {
            if (String(groups[i].scope_type || '') === String(type || '')) {
                return groups[i];
            }
        }
        return groups[0] || null;
    }

    function findScopeItem(group, scopeId) {
        var items = group && Array.isArray(group.items) ? group.items : [];
        for (var i = 0; i < items.length; i++) {
            if (Number(items[i].scope_id || 0) === Number(scopeId || 0)) {
                return items[i];
            }
        }
        return items[0] || null;
    }

    function findChildScope(item, childValue) {
        var children = item && Array.isArray(item.children) ? item.children : [];
        for (var i = 0; i < children.length; i++) {
            var value = String(children[i].child_scope_type || 'website_default') + ':' + String(Number(children[i].child_scope_id || 0));
            if (value === String(childValue || '')) {
                return children[i];
            }
        }
        return children[0] || null;
    }

    function rebuildScopeItems() {
        var typeSelect = document.getElementById('social-scope-type');
        var scopeSelect = document.getElementById('social-scope-id');
        if (!typeSelect || !scopeSelect) {
            return;
        }
        var group = findScopeGroup(typeSelect.value);
        scopeSelect.innerHTML = '';
        (group && Array.isArray(group.items) ? group.items : []).forEach(function (item) {
            var option = document.createElement('option');
            option.value = String(Number(item.scope_id || 0));
            option.textContent = String(item.scope_label || item.scope_title || item.scope_code || item.scope_id || '');
            scopeSelect.appendChild(option);
        });
        rebuildChildScopes();
    }

    function rebuildChildScopes() {
        var typeSelect = document.getElementById('social-scope-type');
        var scopeSelect = document.getElementById('social-scope-id');
        var childSelect = document.getElementById('social-child-scope');
        if (!typeSelect || !scopeSelect || !childSelect) {
            return;
        }
        var group = findScopeGroup(typeSelect.value);
        var item = findScopeItem(group, scopeSelect.value);
        childSelect.innerHTML = '';
        (item && Array.isArray(item.children) ? item.children : []).forEach(function (child) {
            var option = document.createElement('option');
            option.value = String(child.child_scope_type || 'website_default') + ':' + String(Number(child.child_scope_id || 0));
            option.textContent = String(child.child_scope_label || child.child_scope_code || option.value);
            childSelect.appendChild(option);
        });
        updateCurrentScope();
    }

    function initializeScopeSelectors() {
        var typeSelect = document.getElementById('social-scope-type');
        if (!typeSelect) {
            return;
        }
        typeSelect.innerHTML = '';
        (Array.isArray(socialScopes) ? socialScopes : []).forEach(function (group) {
            var option = document.createElement('option');
            option.value = String(group.scope_type || '');
            option.textContent = String(group.scope_label || group.scope_type || '');
            typeSelect.appendChild(option);
        });
        rebuildScopeItems();
    }

    function updateCurrentScope() {
        var typeSelect = document.getElementById('social-scope-type');
        var scopeSelect = document.getElementById('social-scope-id');
        var childSelect = document.getElementById('social-child-scope');
        var group = typeSelect ? findScopeGroup(typeSelect.value) : null;
        var item = scopeSelect ? findScopeItem(group, scopeSelect.value) : null;
        var child = childSelect ? findChildScope(item, childSelect.value) : null;
        currentScope = item && child ? {
            scope_type: String(item.scope_type || group.scope_type || 'website'),
            scope_id: Number(item.scope_id || 0),
            scope_label: String(item.scope_label || item.scope_title || item.scope_code || ''),
            child_scope_type: String(child.child_scope_type || 'website_default'),
            child_scope_id: Number(child.child_scope_id || 0),
            child_scope_label: String(child.child_scope_label || child.child_scope_code || ''),
            website_id: Number(item.website_id || item.scope_id || 0),
            scope_key: String(child.scope_key || buildScopeKey({
                scope_type: item.scope_type || group.scope_type || 'website',
                scope_id: item.scope_id || 0,
                child_scope_type: child.child_scope_type || 'website_default',
                child_scope_id: child.child_scope_id || 0
            }))
        } : null;
        if (currentScope) {
            currentScope.display_label = scopeDisplay(currentScope);
        }
        renderScopeState();
    }

    function renderScopeText(labelId, keyId) {
        var label = document.getElementById(labelId);
        var key = document.getElementById(keyId);
        if (label) {
            label.textContent = scopeDisplay(currentScope);
        }
        if (key) {
            key.textContent = currentScope ? currentScope.scope_key : '';
        }
    }

    function renderScopeState() {
        renderScopeText('social-current-scope-label', 'social-current-scope-key');
        renderScopeText('social-scope-account-label', 'social-scope-account-key');
        renderScopeText('social-publish-scope-label', 'social-publish-scope-key');
        updateAccountScopeNote();
        updateScopeAccountChecks();
        resolvePublishDefaults();
    }

    function updateAccountScopeNote() {
        var note = document.getElementById('social-account-scope-note');
        if (!note) {
            return;
        }
        var display = scopeDisplay(currentScope);
        note.textContent = pendingScopeAssign
            ? messages.bindAfterSave + display
            : messages.currentScope + display;
    }

    function setCheckedAccountIds(container, ids) {
        var selected = {};
        (ids || []).forEach(function (id) {
            selected[String(id)] = true;
        });
        container.querySelectorAll('input[name="account_ids[]"]').forEach(function (input) {
            input.checked = !!selected[String(input.value)];
        });
    }

    function getSelectedAccountIds(form, name) {
        return Array.prototype.slice.call(form.querySelectorAll('input[name="' + name + '"]:checked')).map(function (item) {
            return Number(item.value || 0);
        }).filter(Boolean);
    }

    function updateScopeAccountChecks() {
        var form = document.getElementById('weline-social-scope-account-form');
        if (!currentScope || !form) {
            return;
        }
        var ids = relationsByScope[currentScope.scope_key] || [];
        form.querySelectorAll('input[name="scope_account_ids[]"]').forEach(function (input) {
            input.checked = ids.indexOf(Number(input.value || 0)) !== -1;
        });
    }

    function resolvePublishDefaults() {
        var form = document.getElementById('weline-social-publish-form');
        var allSites = document.getElementById('social-publish-all-sites');
        if (!form || !allSites) {
            return;
        }
        if (allSites.checked) {
            setStatus('social-publish-status', messages.resolvingDefaults, '');
            callSocial('resolvePublishAccounts', {all_sites: true})
                .then(function (result) {
                    setCheckedAccountIds(form, result.account_ids || []);
                    setStatus('social-publish-status', '', '');
                })
                .catch(function (error) { setStatus('social-publish-status', error.message, 'error'); });
            return;
        }
        if (!currentScope) {
            return;
        }
        setStatus('social-publish-status', messages.resolvingDefaults, '');
        var payload = scopePayload(currentScope);
        payload.publish_only = true;
        callSocial('getScopeDefaultAccounts', payload)
            .then(function (result) {
                var ids = (result.accounts || []).map(function (account) { return Number(account.account_id || 0); }).filter(Boolean);
                setCheckedAccountIds(form, ids);
                setStatus('social-publish-status', '', '');
            })
            .catch(function (error) { setStatus('social-publish-status', error.message, 'error'); });
    }

    function updateAuthAndCredentials() {
        var platformSelect = document.getElementById('social-platform-code');
        var authSelect = document.getElementById('social-auth-mode');
        var credentialFields = document.getElementById('social-credential-fields');
        var platform = platformMap[platformSelect.value] || {};
        var modes = Array.isArray(platform.auth_modes) ? platform.auth_modes.slice() : [];
        if (modes.indexOf('profile_only') === -1) {
            modes.push('profile_only');
        }
        authSelect.innerHTML = '';
        modes.forEach(function (mode) {
            var option = document.createElement('option');
            option.value = mode;
            option.textContent = mode === 'profile_only' ? '<?= $h((string)__('仅展示')) ?>' : mode;
            authSelect.appendChild(option);
        });
        credentialFields.innerHTML = '';
        (Array.isArray(platform.config_fields) ? platform.config_fields : []).forEach(function (field) {
            var wrap = document.createElement('div');
            var label = document.createElement('label');
            var input = document.createElement('input');
            var key = String(field.key || '');
            if (!key) {
                return;
            }
            label.className = 'form-label';
            label.textContent = String(field.label || key);
            input.className = 'form-control';
            input.type = String(field.type || 'text') === 'password' ? 'password' : 'text';
            input.name = 'credential_' + key;
            input.setAttribute('data-credential-key', key);
            input.placeholder = field.required ? '<?= $h((string)__('必填')) ?>' : '<?= $h((string)__('可选')) ?>';
            wrap.appendChild(label);
            wrap.appendChild(input);
            credentialFields.appendChild(wrap);
        });
    }

    function resetAccountForm() {
        var form = document.getElementById('weline-social-account-form');
        pendingScopeAssign = false;
        form.reset();
        form.elements.account_id.value = '';
        form.elements.sort_order.value = '1000';
        form.elements.widget_enabled.checked = true;
        form.elements.publish_enabled.checked = false;
        updateAuthAndCredentials();
        updateAccountScopeNote();
        setStatus('social-account-status', '', '');
    }

    function fillAccountForm(account) {
        pendingScopeAssign = false;
        var form = document.getElementById('weline-social-account-form');
        form.elements.account_id.value = account.account_id || '';
        form.elements.platform_code.value = account.platform_code || '';
        updateAuthAndCredentials();
        form.elements.account_name.value = account.account_name || '';
        form.elements.profile_url.value = account.profile_url || '';
        form.elements.auth_mode.value = account.auth_mode || 'profile_only';
        form.elements.sort_order.value = account.sort_order || 1000;
        form.elements.widget_enabled.checked = Number(account.widget_enabled || 0) === 1;
        form.elements.publish_enabled.checked = Number(account.publish_enabled || 0) === 1;
        updateAccountScopeNote();
        activateTab('accounts');
    }

    function startAddPlatform(platformCode) {
        if (!currentScope) {
            activateTab('scopeAccounts');
            setStatus('social-scope-account-status', messages.needScope, 'error');
            return;
        }
        var platform = platformMap[String(platformCode)] || {};
        resetAccountForm();
        pendingScopeAssign = true;
        var form = document.getElementById('weline-social-account-form');
        form.elements.platform_code.value = String(platformCode || '');
        updateAuthAndCredentials();
        form.elements.account_name.value = String(platform.title || platformCode || '') + ' - ' + scopeDisplay(currentScope);
        updateAccountScopeNote();
        activateTab('accounts');
        setStatus('social-account-status', messages.addedFromPlatform, '');
    }

    function assignAccountToCurrentScope(accountId) {
        if (!currentScope || !accountId) {
            return Promise.resolve(null);
        }
        var key = currentScope.scope_key;
        var ids = (relationsByScope[key] || []).slice();
        if (ids.indexOf(Number(accountId)) === -1) {
            ids.push(Number(accountId));
        }
        var payload = scopePayload(currentScope);
        payload.account_ids = ids;
        return callSocial('saveScopeAccountDefaults', payload).then(function (result) {
            relationsByScope[key] = (result.relations || []).map(function (relation) {
                return Number(relation.account_id || 0);
            }).filter(Boolean);
            return result;
        });
    }

    document.querySelectorAll('[data-social-tab]').forEach(function (button) {
        button.addEventListener('click', function () {
            activateTab(button.getAttribute('data-social-tab'));
        });
    });

    var scopeTypeSelect = document.getElementById('social-scope-type');
    if (scopeTypeSelect) {
        scopeTypeSelect.addEventListener('change', rebuildScopeItems);
    }
    var scopeIdSelect = document.getElementById('social-scope-id');
    if (scopeIdSelect) {
        scopeIdSelect.addEventListener('change', rebuildChildScopes);
    }
    var childScopeSelect = document.getElementById('social-child-scope');
    if (childScopeSelect) {
        childScopeSelect.addEventListener('change', updateCurrentScope);
    }
    document.getElementById('social-platform-code').addEventListener('change', updateAuthAndCredentials);
    document.getElementById('social-account-reset').addEventListener('click', resetAccountForm);
    var publishAllSites = document.getElementById('social-publish-all-sites');
    if (publishAllSites) {
        publishAllSites.addEventListener('change', function () {
            resolvePublishDefaults();
        });
    }
    document.querySelectorAll('[data-social-platform-add]').forEach(function (button) {
        button.addEventListener('click', function () {
            startAddPlatform(button.getAttribute('data-social-platform-add'));
        });
    });
    document.querySelectorAll('[data-social-edit]').forEach(function (button) {
        button.addEventListener('click', function () {
            fillAccountForm(accountMap[String(button.getAttribute('data-social-edit'))] || {});
        });
    });
    document.querySelectorAll('[data-social-test]').forEach(function (button) {
        button.addEventListener('click', function () {
            setStatus('social-account-status', messages.testing, '');
            callSocial('testAccount', {account_id: Number(button.getAttribute('data-social-test') || 0)})
                .then(function (result) {
                    setStatus('social-account-status', result.message || messages.saved, 'success');
                    window.setTimeout(function () { window.location.reload(); }, 800);
                })
                .catch(function (error) { setStatus('social-account-status', error.message, 'error'); });
        });
    });
    document.querySelectorAll('[data-social-disable]').forEach(function (button) {
        button.addEventListener('click', function () {
            setStatus('social-account-status', messages.working, '');
            callSocial('disableAccount', {account_id: Number(button.getAttribute('data-social-disable') || 0)})
                .then(function () {
                    setStatus('social-account-status', messages.disabled, 'success');
                    window.setTimeout(function () { window.location.reload(); }, 800);
                })
                .catch(function (error) { setStatus('social-account-status', error.message, 'error'); });
        });
    });

    document.getElementById('weline-social-account-form').addEventListener('submit', function (event) {
        event.preventDefault();
        var form = event.currentTarget;
        var credentials = {};
        form.querySelectorAll('[data-credential-key]').forEach(function (input) {
            if (input.value) {
                credentials[input.getAttribute('data-credential-key')] = input.value;
            }
        });
        var payload = {
            account_id: Number(form.elements.account_id.value || 0),
            platform_code: form.elements.platform_code.value,
            account_name: form.elements.account_name.value,
            profile_url: form.elements.profile_url.value,
            auth_mode: form.elements.auth_mode.value,
            widget_enabled: form.elements.widget_enabled.checked,
            publish_enabled: form.elements.publish_enabled.checked,
            sort_order: Number(form.elements.sort_order.value || 1000),
            credentials: credentials
        };
        setStatus('social-account-status', messages.saving, '');
        callSocial('saveCredentialAccount', payload)
            .then(function (result) {
                setStatus('social-account-status', result.message || messages.saved, result.success === false ? 'error' : 'success');
                var savedAccount = result && result.account ? result.account : {};
                var accountId = Number(savedAccount.account_id || payload.account_id || 0);
                if (pendingScopeAssign && accountId && currentScope) {
                    setStatus('social-account-status', messages.bindingScope, '');
                    return assignAccountToCurrentScope(accountId).then(function () {
                        window.setTimeout(function () { window.location.reload(); }, 900);
                    });
                }
                window.setTimeout(function () { window.location.reload(); }, 900);
            })
            .catch(function (error) { setStatus('social-account-status', error.message, 'error'); });
    });

    var scopeAccountForm = document.getElementById('weline-social-scope-account-form');
    if (scopeAccountForm) {
        scopeAccountForm.addEventListener('submit', function (event) {
            event.preventDefault();
            var form = event.currentTarget;
            if (!currentScope) {
                setStatus('social-scope-account-status', messages.needScope, 'error');
                return;
            }
            setStatus('social-scope-account-status', messages.scopeSaving, '');
            var payload = scopePayload(currentScope);
            payload.account_ids = getSelectedAccountIds(form, 'scope_account_ids[]');
            callSocial('saveScopeAccountDefaults', payload).then(function (result) {
                relationsByScope[currentScope.scope_key] = (result.relations || []).map(function (relation) {
                    return Number(relation.account_id || 0);
                }).filter(Boolean);
                setStatus('social-scope-account-status', result.message || messages.scopeSaved, 'success');
                resolvePublishDefaults();
            }).catch(function (error) { setStatus('social-scope-account-status', error.message, 'error'); });
        });
    }

    document.getElementById('weline-social-creative-form').addEventListener('submit', function (event) {
        event.preventDefault();
        var form = event.currentTarget;
        setStatus('social-creative-status', messages.working, '');
        callSocial('generateCreative', {
            title: form.elements.title.value,
            prompt: form.elements.prompt.value,
            platforms: platforms.map(function (platform) { return platform.code; }).filter(Boolean),
            use_ai: form.elements.use_ai.checked
        }).then(function () {
            setStatus('social-creative-status', messages.generated, 'success');
            window.setTimeout(function () { window.location.reload(); }, 900);
        }).catch(function (error) { setStatus('social-creative-status', error.message, 'error'); });
    });

    document.getElementById('weline-social-publish-form').addEventListener('submit', function (event) {
        event.preventDefault();
        var form = event.currentTarget;
        var accountIds = Array.prototype.slice.call(form.querySelectorAll('input[name="account_ids[]"]:checked')).map(function (item) {
            return Number(item.value || 0);
        }).filter(Boolean);
        var draftId = Number(form.elements.draft_id.value || 0);
        if (!draftId) {
            setStatus('social-publish-status', messages.needDraft, 'error');
            return;
        }
        var allSites = !!(form.elements.all_sites && form.elements.all_sites.checked);
        if (!currentScope && !allSites) {
            setStatus('social-publish-status', messages.needScope, 'error');
            return;
        }
        if (accountIds.length === 0 && !currentScope && !allSites) {
            setStatus('social-publish-status', messages.needAccount, 'error');
            return;
        }
        setStatus('social-publish-status', messages.working, '');
        var payload = currentScope && !allSites ? scopePayload(currentScope) : {};
        payload.draft_id = draftId;
        payload.account_ids = accountIds;
        payload.all_sites = allSites;
        payload.content_kind = 'news';
        callSocial('createPublishBatch', payload)
            .then(function () {
                setStatus('social-publish-status', messages.batchCreated, 'success');
                window.setTimeout(function () { window.location.reload(); }, 900);
            })
            .catch(function (error) { setStatus('social-publish-status', error.message, 'error'); });
    });

    initializeScopeSelectors();
    updateCurrentScope();
    updateAuthAndCredentials();
})();
</script>
