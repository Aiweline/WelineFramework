    function createSocialChoice(root, config) {
        config = config || {};
        if (!root) {
            return null;
        }
        var key = String(root.getAttribute('data-social-choice-key') || root.id || '');
        var trigger = root.querySelector('[data-social-choice-trigger]');
        var panel = root.querySelector('[data-social-choice-panel]');
        var search = root.querySelector('[data-social-choice-search]');
        var items = root.querySelector('[data-social-choice-items]');
        var empty = root.querySelector('[data-social-choice-empty]');
        var current = root.querySelector('[data-social-choice-current]');
        var meta = root.querySelector('[data-social-choice-meta]');
        var hidden = document.getElementById(key + '_value') || root.parentNode.querySelector('[data-social-choice-value]');
        var emptyLabel = String(config.emptyLabel || (current ? current.textContent : '') || '请选择');
        var options = [];
        var selected = '';
        var disabled = root.getAttribute('data-disabled') === '1';
        var onChange = typeof config.onChange === 'function' ? config.onChange : null;

        function close() {
            root.classList.remove('is-open');
            if (panel) {
                panel.hidden = true;
            }
            if (trigger) {
                trigger.setAttribute('aria-expanded', 'false');
            }
        }

        function openPanel() {
            if (disabled || !panel) {
                return;
            }
            root.classList.add('is-open');
            panel.hidden = false;
            if (trigger) {
                trigger.setAttribute('aria-expanded', 'true');
            }
            if (search) {
                search.focus();
                search.select();
            }
            renderList(search ? search.value : '');
        }

        function emitChange(silent) {
            if (!hidden) {
                return;
            }
            try {
                hidden.dispatchEvent(new Event('change', { bubbles: true }));
            } catch (e) {}
            if (!silent && onChange) {
                onChange(selected);
            }
        }

        function syncDisplay() {
            var picked = options.find(function (item) { return item.value === selected; }) || null;
            if (current) {
                current.textContent = picked ? picked.label : emptyLabel;
            }
            if (meta) {
                if (picked && picked.meta && picked.meta !== picked.label) {
                    meta.textContent = picked.meta;
                    meta.hidden = false;
                } else {
                    meta.textContent = '';
                    meta.hidden = true;
                }
            }
            if (hidden) {
                hidden.value = selected;
            }
        }

        function renderList(keyword) {
            if (!items) {
                return;
            }
            var kw = String(keyword || '').trim().toLowerCase();
            var filtered = options.filter(function (item) {
                return !kw
                    || item.label.toLowerCase().indexOf(kw) > -1
                    || item.meta.toLowerCase().indexOf(kw) > -1
                    || item.value.toLowerCase().indexOf(kw) > -1;
            });
            items.innerHTML = '';
            if (empty) {
                empty.hidden = filtered.length > 0;
            }
            filtered.forEach(function (item) {
                var button = document.createElement('button');
                button.type = 'button';
                button.className = 'social-choice-option' + (item.value === selected ? ' is-selected' : '');
                button.setAttribute('role', 'option');
                button.setAttribute('aria-selected', item.value === selected ? 'true' : 'false');
                button.setAttribute('data-value', item.value);
                var copy = document.createElement('span');
                copy.className = 'social-choice-option-copy';
                var label = document.createElement('span');
                label.className = 'social-choice-option-label';
                label.textContent = item.label;
                copy.appendChild(label);
                if (item.meta && item.meta !== item.label) {
                    var optionMeta = document.createElement('span');
                    optionMeta.className = 'social-choice-option-meta';
                    optionMeta.textContent = item.meta;
                    copy.appendChild(optionMeta);
                }
                var check = document.createElement('span');
                check.className = 'social-choice-check';
                check.setAttribute('aria-hidden', 'true');
                check.textContent = '✓';
                button.appendChild(copy);
                button.appendChild(check);
                button.addEventListener('click', function () {
                    selected = item.value;
                    syncDisplay();
                    close();
                    emitChange(false);
                });
                items.appendChild(button);
            });
        }

        function setOptions(nextOptions) {
            options = (nextOptions || []).map(function (item) {
                return {
                    value: String(item.value || ''),
                    label: String(item.label || item.value || ''),
                    meta: String(item.meta || '')
                };
            }).filter(function (item) {
                return item.value !== '';
            });
            if (selected && !options.some(function (item) { return item.value === selected; })) {
                selected = '';
            }
            syncDisplay();
            renderList(search ? search.value : '');
        }

        function setValue(value, silent) {
            selected = String(value || '');
            syncDisplay();
            renderList(search ? search.value : '');
            if (!silent) {
                emitChange(false);
            }
        }

        if (trigger) {
            trigger.addEventListener('click', function (event) {
                event.preventDefault();
                if (disabled) {
                    return;
                }
                if (root.classList.contains('is-open')) {
                    close();
                } else {
                    openPanel();
                }
            });
        }
        if (search) {
            search.addEventListener('input', function () {
                renderList(search.value || '');
            });
        }
        document.addEventListener('click', function (event) {
            if (!root.contains(event.target)) {
                close();
            }
        });
        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                close();
            }
        });

        var api = {
            setOptions: setOptions,
            setValue: setValue,
            getValue: function () { return selected; },
            setDisabled: function (nextDisabled) {
                disabled = !!nextDisabled;
                root.setAttribute('data-disabled', disabled ? '1' : '0');
                if (trigger) {
                    trigger.disabled = disabled;
                }
                if (search) {
                    search.disabled = disabled;
                }
                if (disabled) {
                    close();
                }
            }
        };
        if (key) {
            window.WelineSocialChoices[key] = api;
        }
        if (Array.isArray(config.options)) {
            setOptions(config.options);
            if (config.value) {
                setValue(config.value, true);
            } else if (options.length > 0) {
                setValue(options[0].value, true);
            }
        }
        return api;
    }

    createSocialChoice(document.getElementById('social-scope-type'), {
