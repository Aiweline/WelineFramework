    function resolvePublishDefaults() {
        var form = document.getElementById('weline-social-publish-form');
        var allSites = document.getElementById('social-publish-all-sites');
        if (!form || !allSites) {
            return;
        }
        if (allSites.checked) {
            setStatus('social-publish-status', messages.resolvingDefaults, '');
            callSocial('resolvePublishAccounts', {all_sites: true})
                .then(function (result) {
                    setCheckedAccountIds(form, result.account_ids || []);
                    setStatus('social-publish-status', '', '');
                })
                .catch(function (error) { setStatus('social-publish-status', error.message, 'error'); });
            return;
        }
        if (!currentScope) {
            return;
        }
        setStatus('social-publish-status', messages.resolvingDefaults, '');
        var payload = scopePayload(currentScope);
        payload.publish_only = true;
        callSocial('getScopeDefaultAccounts', payload)
            .then(function (result) {
                var ids = (result.accounts || []).map(function (account) { return Number(account.account_id || 0); }).filter(Boolean);
                setCheckedAccountIds(form, ids);
                setStatus('social-publish-status', '', '');
