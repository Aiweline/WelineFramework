<?php
/**
 * Session detail page.
 *
 * @var \Weline\Framework\View\Template $this
 */
$session = $session ?? null;
$messages = is_array($messages ?? null) ? $messages : [];
$listingUrl = $this->getBackendUrl('*/backend/session/listing');

$get = static function (mixed $item, string $key, mixed $default = ''): mixed {
    if (is_array($item)) {
        return $item[$key] ?? $default;
    }
    if (is_object($item)) {
        if (method_exists($item, 'getData')) {
            $value = $item->getData($key);
            return $value ?? $default;
        }
        if (isset($item->{$key})) {
            return $item->{$key};
        }
    }
    return $default;
};
?>

<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0"><?= __('Session Detail') ?></h4>
            <a href="<?= htmlspecialchars($listingUrl, ENT_QUOTES) ?>" class="btn btn-light"><?= __('Back') ?></a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <template>Weline_Component::message.phtml</template>
    </div>
</div>

<div class="row">
    <div class="col-xl-4">
        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0"><?= __('Session Info') ?></h5></div>
            <div class="card-body">
                <div class="mb-2"><strong><?= __('ID') ?>:</strong> <?= (int) $get($session, 'session_id', 0) ?></div>
                <div class="mb-2"><strong><?= __('Title') ?>:</strong> <?= htmlspecialchars((string) $get($session, 'title', '-')) ?></div>
                <div class="mb-2"><strong><?= __('Role ID') ?>:</strong> <?= (int) $get($session, 'role_id', 0) ?></div>
                <div class="mb-2"><strong><?= __('Channel') ?>:</strong> <?= htmlspecialchars((string) $get($session, 'channel', '')) ?></div>
                <div class="mb-2"><strong><?= __('Context ID') ?>:</strong> <?= htmlspecialchars((string) $get($session, 'context_id', '')) ?></div>
                <div class="mb-2"><strong><?= __('Status') ?>:</strong> <?= htmlspecialchars((string) $get($session, 'status', '')) ?></div>
                <div class="mb-2"><strong><?= __('Message Count') ?>:</strong> <?= (int) $get($session, 'message_count', 0) ?></div>
                <div class="mb-2"><strong><?= __('Updated At') ?>:</strong> <?= htmlspecialchars((string) $get($session, 'updated_at', '')) ?></div>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0"><?= __('Messages') ?></h5></div>
            <div class="card-body">
                <?php if (!empty($messages)): ?>
                    <div class="d-flex flex-column gap-2">
                        <?php foreach ($messages as $message): ?>
                            <?php
                            $role = (string) $get($message, 'role', 'assistant');
                            $content = (string) $get($message, 'content', '');
                            $createdAt = (string) $get($message, 'created_at', '');
                            ?>
                            <div class="border rounded p-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="badge bg-light text-dark"><?= htmlspecialchars($role) ?></span>
                                    <small class="text-muted"><?= htmlspecialchars($createdAt) ?></small>
                                </div>
                                <div style="white-space: pre-wrap;"><?= htmlspecialchars($content) ?></div>
                            </div>
                        <?php endforeach; ?>
                    </div>
                <?php else: ?>
                    <div class="text-muted"><?= __('No messages in this session yet.') ?></div>
                <?php endif; ?>
            </div>
        </div>
    </div>
</div>
