<?php
/**
 * Session listing page.
 *
 * @var \Weline\Framework\View\Template $this
 */
$sessions = is_array($sessions ?? null) ? $sessions : [];
$currentStatus = trim((string)($current_status ?? ''));
$currentChannel = trim((string)($current_channel ?? ''));
$listingUrl = $this->getBackendUrl('*/backend/session/listing');

$get = static function (mixed $item, string $key, mixed $default = ''): mixed {
    if (is_array($item)) {
        return $item[$key] ?? $default;
    }
    if (is_object($item)) {
        if (method_exists($item, 'getData')) {
            $value = $item->getData($key);
            return $value ?? $default;
        }
        if (isset($item->{$key})) {
            return $item->{$key};
        }
    }
    return $default;
};
