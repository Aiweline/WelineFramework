<?php
/**
 * Bot chat console landing page.
 *
 * @var \Weline\Framework\View\Template $this
 */
$roles = is_array($roles ?? null) ? $roles : [];
$roleManageUrl = $this->getBackendUrl('*/backend/role/listing');

$get = static function (mixed $item, string $key, mixed $default = ''): mixed {
    if (is_array($item)) {
        return $item[$key] ?? $default;
    }
    if (is_object($item)) {
        if (method_exists($item, 'getData')) {
            $value = $item->getData($key);
            return $value ?? $default;
        }
        if (isset($item->{$key})) {
            return $item->{$key};
        }
    }
    return $default;
};
?>

