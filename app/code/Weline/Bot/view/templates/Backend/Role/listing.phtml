<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0"><lang>角色管理</lang></h4>
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="javascript:void(0);"><lang>Bot</lang></a></li>
                    <li class="breadcrumb-item active"><lang>角色管理</lang></li>
                </ol>
            </div>
