$defaultBotProfile = (string)($initialGuide['bot_profile'] ?? ($guideConfig['default_profile'] ?? 'multi_project'));
$defaultProjectCount = max(1, (int)($initialGuide['project_count'] ?? 1));
$maxProjectCount = max(1, (int)($max_project_count ?? ($guideConfig['max_project_count'] ?? 200)));

$listingUrl = $this->getBackendUrl('*/backend/role/listing');
$addRoleUrl = $this->getBackendUrl('*/backend/role/add');

$buildAddUrl = static function (string $baseUrl, array $params): string {
    $filtered = [];
    foreach ($params as $key => $value) {
        $str = trim((string)$value);
        if ($str !== '') {
            $filtered[$key] = $str;
        }
    }

    if (empty($filtered)) {
        return $baseUrl;
    }

    $query = http_build_query($filtered);
    return $baseUrl . (str_contains($baseUrl, '?') ? '&' : '?') . $query;
};

$profileProjectDefaults = [
    'single_project' => 1,
    'multi_project' => min(12, $maxProjectCount),
    'enterprise' => min(30, $maxProjectCount),
];
