<script>
(function () {
    'use strict';

    var suggestUrl = <?= json_encode($suggestUrl, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
    var roleTemplates = <?= json_encode($roleTemplates, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
    var guideProfiles = <?= json_encode($guideProfiles, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
    var form = document.getElementById('botRoleForm');
    var generateBtn = document.getElementById('generateSuggestionBtn');
    var applyTemplateBaselineBtn = document.getElementById('applyTemplateBaselineBtn');
    var toggleAdvancedBtn = document.getElementById('toggleAdvancedBtn');
    var advancedFields = document.getElementById('advancedFields');
    var warningBox = document.getElementById('suggestionWarnings');
    var sourceBadge = document.getElementById('suggestionSource');
    var botProfileSelect = document.getElementById('bot_profile');
    var botProfileHint = document.getElementById('botProfileHint');

    function toast(type, message) {
        if (window.BackendToast && typeof window.BackendToast[type] === 'function') {
            window.BackendToast[type](message);
            return;
        }
        if (window.BackendToast && typeof window.BackendToast.info === 'function') {
            window.BackendToast.info(message);
            return;
        }
        console.log('[role-form][' + type + ']', message);
    }

    function setWarnings(messages) {
        if (!Array.isArray(messages) || messages.length === 0) {
            warningBox.classList.add('d-none');
            warningBox.innerHTML = '';
            return;
        }

        warningBox.classList.remove('d-none');
        warningBox.innerHTML = messages.map(function (item) {
            return '<div>' + String(item) + '</div>';
        }).join('');
    }

    function setSuggestionSource(source, templateName) {
        if (!source) {
            sourceBadge.classList.add('d-none');
            sourceBadge.innerText = '';
            return;
        }

        sourceBadge.classList.remove('d-none');
        if (source === 'ai') {
            sourceBadge.className = 'badge bg-success';
            sourceBadge.innerText = 'Source: AI suggestion' + (templateName ? (' / ' + templateName) : '');
            return;
        }

        sourceBadge.className = 'badge bg-secondary';
        sourceBadge.innerText = 'Source: template fallback' + (templateName ? (' / ' + templateName) : '');
    }

    function slugify(value) {
        return String(value || '')
            .trim()
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, '_')
            .replace(/^_+|_+$/g, '');
    }

    function collectPayload() {
        var modelId = parseInt((document.getElementById('model_id') || {}).value || '0', 10);
        if (!Number.isFinite(modelId)) {
            modelId = 0;
        }

        return {
            template_code: (document.getElementById('template_code') || {}).value || 'general_assistant',
            brief: (document.getElementById('guide_brief') || {}).value || '',
            project_count: parseInt((document.getElementById('project_count') || {}).value || '1', 10) || 1,
            target_outcome: (document.getElementById('target_outcome') || {}).value || '',
            workflow_style: (document.getElementById('workflow_style') || {}).value || 'balanced',
            risk_level: (document.getElementById('risk_level') || {}).value || 'safe',
            bot_profile: (document.getElementById('bot_profile') || {}).value || 'multi_project',
            role_name: (document.getElementById('name') || {}).value || '',
            role_code: (document.getElementById('code') || {}).value || '',
            model_id: modelId,
            icon: (document.getElementById('icon') || {}).value || 'mdi-robot'
        };
    }

    function parseJsonSafe(raw) {
        try {
            return JSON.parse(raw);
        } catch (e) {
            return null;
        }
    }

    function findTemplateByCode(templateCode) {
        if (!Array.isArray(roleTemplates)) {
            return null;
        }

        for (var i = 0; i < roleTemplates.length; i += 1) {
            if (String((roleTemplates[i] || {}).code || '') === String(templateCode || '')) {
                return roleTemplates[i];
            }
        }

        return null;
    }

    function applyTemplateBaseline() {
        var templateCode = (document.getElementById('template_code') || {}).value || '';
        var template = findTemplateByCode(templateCode);
        if (!template) {
            toast('error', 'Template not found');
            return;
        }

        var codeInput = document.getElementById('code');
        var nameInput = document.getElementById('name');
        var draft = Object.assign({}, template);

        if (codeInput && String(codeInput.value || '').trim() !== '') {
            draft.code = codeInput.value;
        }
        if (nameInput && String(nameInput.value || '').trim() !== '') {
            draft.name = nameInput.value;
        }

        applyDraft(draft);
        setSuggestionSource('template', String(template.name || template.code || ''));
        setWarnings([]);
        toast('success', 'Template baseline applied');

        if (advancedFields) {
            advancedFields.style.display = '';
        }
    }

    function updateBotProfileHint() {
        if (!botProfileHint || !botProfileSelect || !Array.isArray(guideProfiles)) {
            return;
        }

        var selected = String(botProfileSelect.value || '');
        var matched = null;
        for (var i = 0; i < guideProfiles.length; i += 1) {
            var profile = guideProfiles[i] || {};
            if (String(profile.code || '') === selected) {
                matched = profile;
                break;
            }
        }

        if (matched && matched.description) {
            botProfileHint.innerText = String(matched.description);
            return;
        }

        botProfileHint.innerText = 'Select a profile to get project-scale defaults.';
    }

    function applyDraft(draft) {
        if (!draft || typeof draft !== 'object') {
            return;
        }

        var codeInput = document.getElementById('code');
        var nameInput = document.getElementById('name');
        var descInput = document.getElementById('description');
        var promptInput = document.getElementById('system_prompt');
        var statusInput = document.getElementById('status');
        var iconInput = document.getElementById('icon');
        var modelInput = document.getElementById('model_id');
        var adapterInput = document.getElementById('scenario_adapter_code');
        var permissionsInput = document.getElementById('permissions_text');
        var modelConfigInput = document.getElementById('model_config_text');

        if (codeInput && draft.code) {
            codeInput.value = slugify(draft.code);
        }
        if (nameInput && draft.name) {
            nameInput.value = String(draft.name);
        }
        if (descInput && draft.description) {
            descInput.value = String(draft.description);
        }
        if (promptInput && draft.system_prompt) {
            promptInput.value = String(draft.system_prompt);
        }
        if (statusInput && draft.status) {
            statusInput.value = String(draft.status);
        }
        if (iconInput && draft.icon) {
            iconInput.value = String(draft.icon);
        }
        if (modelInput && typeof draft.model_id !== 'undefined') {
            modelInput.value = String(draft.model_id);
        }
        if (adapterInput && draft.scenario_adapter_code) {
            adapterInput.value = String(draft.scenario_adapter_code);
        }

        if (permissionsInput && Array.isArray(draft.permissions)) {
            permissionsInput.value = draft.permissions.join('\n');
        }

        if (modelConfigInput && draft.model_config && typeof draft.model_config === 'object') {
            modelConfigInput.value = JSON.stringify(draft.model_config, null, 2);
        }

        if (Array.isArray(draft.skills)) {
            var checkboxes = form.querySelectorAll('.role-skill-checkbox');
            checkboxes.forEach(function (checkbox) {
                checkbox.checked = draft.skills.indexOf(checkbox.value) >= 0;
            });
        }
    }

    function requestSuggestion() {
        var payload = collectPayload();

        generateBtn.disabled = true;
        generateBtn.innerText = 'Generating...';
        setWarnings([]);

        fetch(suggestUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin',
            body: JSON.stringify(payload)
        }).then(function (response) {
            return response.text().then(function (raw) {
                var data = parseJsonSafe(raw);
                if (!data) {
                    throw new Error('Invalid response');
                }
                return data;
            });
        }).then(function (data) {
            if (!data.success) {
                throw new Error(data.msg || 'Suggestion failed');
            }

            var result = data.data || {};
            applyDraft(result.draft || {});
            setWarnings(result.warnings || []);
            setSuggestionSource(result.source || '', ((result.template || {}).name || ''));
            if (advancedFields) {
                advancedFields.style.display = '';
            }
            toast('success', data.msg || 'Suggestion generated');
        }).catch(function (error) {
            setSuggestionSource('', '');
            toast('error', error && error.message ? error.message : 'Suggestion failed');
        }).finally(function () {
            generateBtn.disabled = false;
            generateBtn.innerHTML = '<i class="mdi mdi-auto-fix me-1"></i>Generate AI Suggestion';
        });
    }

    if (generateBtn) {
        generateBtn.addEventListener('click', requestSuggestion);
    }

    if (applyTemplateBaselineBtn) {
        applyTemplateBaselineBtn.addEventListener('click', applyTemplateBaseline);
    }

    if (botProfileSelect) {
        botProfileSelect.addEventListener('change', updateBotProfileHint);
        updateBotProfileHint();
    }

    if (toggleAdvancedBtn && advancedFields) {
        toggleAdvancedBtn.addEventListener('click', function () {
            if (advancedFields.style.display === 'none') {
                advancedFields.style.display = '';
                toggleAdvancedBtn.innerHTML = '<i class="mdi mdi-eye-off me-1"></i>Hide Advanced Settings';
                return;
            }

            advancedFields.style.display = 'none';
            toggleAdvancedBtn.innerHTML = '<i class="mdi mdi-tune me-1"></i>Show Advanced Settings';
        });
    }
})();
</script>
