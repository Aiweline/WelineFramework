<?php
/**
 * Schedule form page.
 *
 * @var \Weline\Framework\View\Template $this
 */
$schedule = $schedule ?? null;
$scheduleData = is_array($schedule) ? $schedule : ($schedule && method_exists($schedule, 'getData') ? $schedule->getData() : []);
$roles = is_array($roles ?? null) ? $roles : [];

$listingUrl = $this->getBackendUrl('*/backend/schedule/listing');
$saveUrl = $this->getBackendUrl('*/backend/schedule/save');

$contextText = '';
$contextRaw = $scheduleData['context'] ?? [];
if (is_string($contextRaw)) {
    $contextText = $contextRaw;
} elseif (is_array($contextRaw)) {
    $encoded = json_encode($contextRaw, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
    $contextText = is_string($encoded) ? $encoded : '';
}
?>

<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0"><?= !empty($scheduleData['schedule_id']) ? __('Edit Schedule') : __('Create Schedule') ?></h4>
            <a href="<?= htmlspecialchars($listingUrl, ENT_QUOTES) ?>" class="btn btn-light"><?= __('Back') ?></a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <template>Weline_Component::message.phtml</template>
    </div>
</div>

<form action="<?= htmlspecialchars($saveUrl, ENT_QUOTES) ?>" method="post">
    <csrf/>
    <?php if (!empty($scheduleData['schedule_id'])): ?>
        <input type="hidden" name="id" value="<?= (int) $scheduleData['schedule_id'] ?>">
    <?php endif; ?>

    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label"><?= __('Name') ?> <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" name="name" required value="<?= htmlspecialchars((string)($scheduleData['name'] ?? '')) ?>">
                </div>
                <div class="col-md-6">
                    <label class="form-label"><?= __('Role') ?></label>
                    <select class="form-select" name="role_id">
                        <option value="0"><?= __('No role') ?></option>
                        <?php foreach ($roles as $role): ?>
                            <?php
                            $roleId = is_array($role) ? (int)($role['role_id'] ?? 0) : (int)($role->getData('role_id') ?? 0);
                            $roleName = is_array($role) ? (string)($role['name'] ?? '') : (string)($role->getData('name') ?? '');
                            ?>
                            <option value="<?= $roleId ?>" <?= (int)($scheduleData['role_id'] ?? 0) === $roleId ? 'selected' : '' ?>>
                                <?= htmlspecialchars($roleName) ?>
                            </option>
                        <?php endforeach; ?>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label"><?= __('Cron Expression') ?></label>
                    <input type="text" class="form-control" name="trigger_expr" value="<?= htmlspecialchars((string)($scheduleData['trigger_expr'] ?? '0 * * * *')) ?>" placeholder="0 * * * *">
                </div>
                <div class="col-md-6">
                    <label class="form-label"><?= __('Status') ?></label>
                    <select class="form-select" name="status">
                        <option value="enabled" <?= (string)($scheduleData['status'] ?? 'enabled') === 'enabled' ? 'selected' : '' ?>><?= __('Enabled') ?></option>
                        <option value="disabled" <?= (string)($scheduleData['status'] ?? '') === 'disabled' ? 'selected' : '' ?>><?= __('Disabled') ?></option>
                        <option value="paused" <?= (string)($scheduleData['status'] ?? '') === 'paused' ? 'selected' : '' ?>><?= __('Paused') ?></option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label"><?= __('Description') ?></label>
                    <textarea class="form-control" name="description" rows="3"><?= htmlspecialchars((string)($scheduleData['description'] ?? '')) ?></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label"><?= __('Prompt') ?> <span class="text-danger">*</span></label>
                    <textarea class="form-control" name="prompt" rows="6" required><?= htmlspecialchars((string)($scheduleData['prompt'] ?? '')) ?></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label"><?= __('Context JSON') ?></label>
                    <textarea class="form-control font-monospace" name="context" rows="6" placeholder='{"scope":"daily"}'><?= htmlspecialchars($contextText) ?></textarea>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="mdi mdi-content-save me-1"></i><?= __('Save') ?>
                </button>
            </div>
        </div>
    </div>
</form>
