<?php
/**
 * @var \Weline\Deploy\Controller\Backend\CoreUpdate $this
 */
$pageContext = is_array($this->getData('pageContext')) ? $this->getData('pageContext') : [];
$runOutput = (string)($this->getData('runOutput') ?: '');
$defaultBranch = (string)($pageContext['default_branch'] ?? 'dev');
$coreRepoUrl = (string)($pageContext['core_repo_url'] ?? '');
$isProduction = !empty($pageContext['is_production']);
$protectedPaths = is_array($pageContext['protected_paths'] ?? null) ? $pageContext['protected_paths'] : [];
$runUrl = (string)($this->getData('runUrl') ?: '');
$attr = static fn(string $v): string => htmlspecialchars($v, ENT_QUOTES, 'UTF-8');
?>
<style>
    .weline-core-update .wcu-alert {
        background: var(--backend-color-bg-secondary, #1e293b);
        border: 1px solid var(--backend-color-border, #334155);
        color: var(--backend-color-text, #e2e8f0);
    }
    .weline-core-update .wcu-output {
        background: var(--backend-color-bg-tertiary, #0f172a);
        color: var(--backend-color-text, #e2e8f0);
        border: 1px solid var(--backend-color-border, #334155);
        border-radius: .375rem;
        padding: 1rem;
        max-height: 420px;
        overflow: auto;
        white-space: pre-wrap;
        font-family: var(--bs-font-monospace, monospace);
        font-size: .85rem;
    }
</style>

<w:backend:card class="weline-core-update">
    <w:slot:header>
        <h5 class="mb-0"><?= __('核心更新') ?></h5>
    </w:slot:header>
    <w:slot:body>
        <div class="alert wcu-alert mb-3">
            <?= __('等价于命令') ?> <code>php bin/w update:core -b &lt;branch&gt;</code>。
            <?= __('不会覆盖 env.php、.env、dev/deploy/.config 及业务模块目录。') ?>
        </div>

        <if condition="$isProduction">
            <div class="alert wcu-alert mb-3">
                <?= __('正式站执行前将自动整站备份。') ?>
            </div>
        </if>

        <div class="row g-3 mb-3">
            <div class="col-md-8">
                <label class="form-label"><?= __('核心仓库') ?></label>
                <input type="text" class="form-control font-monospace" readonly value="<?= $attr($coreRepoUrl !== '' ? $coreRepoUrl : (string)__('未配置，将使用默认 GitHub/Gitee 仓库')) ?>">
            </div>
            <div class="col-md-4">
                <label class="form-label"><?= __('默认分支') ?></label>
                <input type="text" class="form-control" readonly value="<?= $attr($defaultBranch) ?>">
            </div>
        </div>

        <h6 class="mb-2"><?= __('受保护路径') ?></h6>
        <ul class="small text-muted">
            <?php foreach ($protectedPaths as $path): ?>
                <li><code><?= $attr((string)$path) ?></code></li>
            <?php endforeach; ?>
        </ul>

        <form method="post" action="<?= $attr($runUrl) ?>" class="mt-3" id="wcu-form">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label" for="wcu-branch"><?= __('更新分支') ?></label>
                    <input type="text" class="form-control" id="wcu-branch" name="branch" value="<?= $attr($defaultBranch) ?>" placeholder="dev">
                </div>
                <div class="col-md-8">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="confirm_core_update" value="1" id="wcu-confirm">
                        <label class="form-check-label" for="wcu-confirm"><?= __('我确认要执行核心更新') ?></label>
                    </div>
                    <button type="submit" class="btn btn-danger" id="wcu-submit" disabled><?= __('开始核心更新') ?></button>
                </div>
            </div>
        </form>

        <notempty name="runOutput">
            <h6 class="mt-4 mb-2"><?= __('执行日志') ?></h6>
            <pre class="wcu-output mb-0"><?= $attr($runOutput) ?></pre>
        </notempty>
    </w:slot:body>
</w:backend:card>

<script>
(function () {
    const confirmBox = document.getElementById('wcu-confirm');
    const submitBtn = document.getElementById('wcu-submit');
    const form = document.getElementById('wcu-form');
    function syncState() {
        if (submitBtn) submitBtn.disabled = !(confirmBox && confirmBox.checked);
    }
    confirmBox?.addEventListener('change', syncState);
    form?.addEventListener('submit', () => {
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = '<?= $attr((string)__('执行中...')) ?>';
        }
    });
    syncState();
})();
</script>
