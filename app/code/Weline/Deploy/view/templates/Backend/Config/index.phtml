$webhookSetupCommand = (string)($webhookMeta['setup_command'] ?? 'php bin/w deploy:webhook:setup --base-url=https://你的域名');
$webhookRotatePathCommand = (string)($webhookMeta['rotate_path_command'] ?? 'php bin/w deploy:webhook:setup --rotate-path -y --base-url=https://你的域名');
$webhookReady = !empty($webhookMeta['ready']);
$value = static fn(string $key, string $default = ''): string => htmlspecialchars((string)($settings[$key] ?? $default), ENT_QUOTES, 'UTF-8');
$checked = static fn(string $key): string => ((string)($settings[$key] ?? '') === '1') ? 'checked' : '';
$secretHint = static fn(string $key): string => ((string)($settings[$key . '_configured'] ?? '') === '1') ? (string)__('已配置，留空表示不修改') : (string)__('未配置');
$attr = static fn(string $v): string => htmlspecialchars($v, ENT_QUOTES, 'UTF-8');
$copyInputGroup = static function (string $fieldValue, bool $canCopy = true) use ($attr): string {
    $escaped = $attr($fieldValue);
    if (!$canCopy || $fieldValue === '') {
        return '<input type="text" class="form-control font-monospace" readonly value="' . $escaped . '">';
    }

    return '<div class="input-group">'
        . '<input type="text" class="form-control font-monospace" readonly value="' . $escaped . '" data-deploy-copy-source>'
        . '<button type="button" class="btn btn-outline-secondary" data-deploy-copy-btn>'
        . '<i class="mdi mdi-content-copy me-1"></i>' . $attr((string)__('立即复制'))
        . '</button></div>';
};
$copyCodeToolbar = static function (bool $canCopy = true) use ($attr): string {
    if (!$canCopy) {
        return '';
    }

    return '<div class="weline-deploy-config-code-toolbar">'
        . '<button type="button" class="btn btn-sm btn-outline-secondary" data-deploy-copy-btn>'
        . '<i class="mdi mdi-content-copy me-1"></i>' . $attr((string)__('立即复制'))
        . '</button></div>';
};
$webhookHealthCurl = $webhookUrl !== '' ? "curl -s '" . $webhookUrl . "?health=1'" : '';
$webhookPostCurl = $webhookUrl !== ''
    ? "curl -s -X POST '" . $webhookUrl . "' \\\n  -H 'Content-Type: application/json' \\\n  -H 'Authorization: Bearer 你的密钥' \\\n  --data '{\"ref\":\"refs/heads/main\"}'"
    : '';
$webhookTagPostCurl = $webhookUrl !== ''
    ? "curl -s -X POST '" . $webhookUrl . "' -H 'Content-Type: application/json' -H 'Authorization: Bearer 你的密钥' --data '{\"ref\":\"refs/tags/v1.0.0\"}'"
    : '';
