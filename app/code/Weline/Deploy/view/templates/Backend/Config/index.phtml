    <script>
        (function () {
            var root = document.querySelector('.weline-deploy-config');
            if (!root) {
                return;
            }

            var copiedLabel = <?= json_encode((string)__('已复制'), JSON_UNESCAPED_UNICODE) ?>;

            function resolveCopyText(button) {
                var explicit = button.getAttribute('data-deploy-copy-text');
                if (explicit) {
                    return explicit;
                }

                var group = button.closest('.input-group');
                if (group) {
                    var input = group.querySelector('[data-deploy-copy-source]');
                    if (input) {
                        return input.value || '';
                    }
                }

                var block = button.closest('.weline-deploy-config-code-block');
                if (block) {
                    var source = block.querySelector('[data-deploy-copy-source]');
                    if (source) {
                        return (source.textContent || '').trim();
                    }
                }

                return '';
            }

            function fallbackCopy(text) {
                var textarea = document.createElement('textarea');
                textarea.value = text;
                textarea.setAttribute('readonly', 'readonly');
                textarea.style.position = 'fixed';
                textarea.style.left = '-9999px';
                document.body.appendChild(textarea);
                textarea.select();
                var ok = false;
                try {
                    ok = document.execCommand('copy');
                } catch (e) {
                    ok = false;
                }
                document.body.removeChild(textarea);
                return ok;
            }

            function markCopied(button) {
                var icon = button.querySelector('.mdi');
                var originalHtml = button.innerHTML;
                button.classList.add('is-copied');
                button.innerHTML = '<i class="mdi mdi-check me-1"></i>' + copiedLabel;
                window.setTimeout(function () {
                    button.classList.remove('is-copied');
                    button.innerHTML = originalHtml;
                }, 1600);
            }

            root.addEventListener('click', function (event) {
                var button = event.target.closest('[data-deploy-copy-btn]');
                if (!button) {
                    return;
                }

                event.preventDefault();
                var text = resolveCopyText(button);
                if (!text) {
                    return;
                }

                var done = function () {
                    markCopied(button);
                };

                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(text).then(done).catch(function () {
                        if (fallbackCopy(text)) {
                            done();
                        }
                    });
                    return;
                }

                if (fallbackCopy(text)) {
                    done();
                }
            });
        })();
    </script>
