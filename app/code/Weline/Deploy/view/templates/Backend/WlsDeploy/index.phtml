                                        <p class="wdep-release-meta"><?= $escapeHtml($record['duration'] ?: __('耗时未知')) ?></p>
                                    </div>
                                    <div>
                                        <span class="wdep-pill <?= $statusClass ?>"><?= $escapeHtml($record['status_label'] ?? '') ?></span>
                                        <?php if (!empty($record['is_current'])): ?>
                                            <span class="wdep-pill is-ok"><?= $escapeHtml(__('当前')) ?></span>
                                        <?php endif; ?>
                                    </div>
                                    <?php if (!empty($record['error_message'])): ?>
                                        <div class="wdep-release-main" style="grid-column: 1 / -1;">
                                            <p class="wdep-release-meta"><?= $escapeHtml($record['error_message']) ?></p>
                                        </div>
                                    <?php endif; ?>
                                </article>
                            <?php endforeach; ?>
                        </div>
                    <?php else: ?>
                        <div class="wdep-empty">
                            <?= $escapeHtml($historyScopeScoped
                                ? __('当前项目暂无发布记录。完成一次项目上下文发布或 Tag Webhook 后会写入这里。')
                                : __('暂无发布记录。完成一次命令发布或 Tag Webhook 后会写入发布历史。')) ?>
                        </div>
                    <?php endif; ?>
                </div>
            </article>
        </section>
    </main>
</div>

<script>
    (function () {
        var shell = document.querySelector('[data-wls-deploy-shell]');
        var toggle = document.querySelector('[data-wdep-theme-toggle]');
        var label = document.querySelector('[data-wdep-theme-label]');
        var storageKey = 'wls_panel_theme';

        if (!shell) {
            return;
        }

        function applyTheme(theme) {
            var nextTheme = theme === 'dark' ? 'dark' : 'light';
            shell.setAttribute('data-theme', nextTheme);
            document.documentElement.style.colorScheme = nextTheme;
            if (label) {
                label.textContent = nextTheme === 'dark'
                    ? '<?= $escapeHtml(__('浅色')) ?>'
                    : '<?= $escapeHtml(__('深色')) ?>';
            }
        }

        var savedTheme = 'light';
        try {
            savedTheme = localStorage.getItem(storageKey) || savedTheme;
        } catch (error) {
            savedTheme = 'light';
        }
        applyTheme(savedTheme);

        if (toggle) {
            toggle.addEventListener('click', function () {
                var currentTheme = shell.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
                var nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
                try {
                    localStorage.setItem(storageKey, nextTheme);
                } catch (error) {
                    return;
                }
                applyTheme(nextTheme);
            });
        }

        var replayInput = document.querySelector('[data-wls-webhook-replay-ref]');
        document.querySelectorAll('[data-wls-webhook-replay-sample]').forEach(function (button) {
            button.addEventListener('click', function () {
                if (!replayInput) {
                    return;
                }
                replayInput.value = button.getAttribute('data-wls-webhook-replay-sample') || '';
                replayInput.focus();
            });
        });

        var manualPlanInput = document.querySelector('[data-wls-manual-plan-ref]');
        var manualReleaseConfirm = document.querySelector('[data-wls-manual-release-confirm]');
        var manualReleaseRun = document.querySelector('[data-wls-manual-release-run]');
        var syncManualReleaseButton = function () {
            if (!manualReleaseRun) {
                return;
            }
            var blocked = manualReleaseRun.getAttribute('data-release-blocked') === '1';
            var hasRef = manualPlanInput && manualPlanInput.value.trim() !== '';
            var confirmed = manualReleaseConfirm && manualReleaseConfirm.checked;
            manualReleaseRun.disabled = blocked || !hasRef || !confirmed;
        };
        if (manualPlanInput) {
            manualPlanInput.addEventListener('input', syncManualReleaseButton);
        }
        if (manualReleaseConfirm) {
            manualReleaseConfirm.addEventListener('change', syncManualReleaseButton);
        }
        syncManualReleaseButton();
        document.querySelectorAll('[data-wls-manual-plan-sample]').forEach(function (button) {
            button.addEventListener('click', function () {
                if (!manualPlanInput) {
                    return;
                }
                manualPlanInput.value = button.getAttribute('data-wls-manual-plan-sample') || '';
                manualPlanInput.focus();
                syncManualReleaseButton();
            });
        });
    })();
</script>
