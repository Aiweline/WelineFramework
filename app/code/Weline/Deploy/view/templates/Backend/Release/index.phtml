<?php
/**
 * @var \Weline\Deploy\Controller\Backend\Release $this
 * @var array $records
 * @var array|null $current
 */
$records = $this->getData('records') ?: [];
$current = $this->getData('current');
$rollbackUrl = (string)($this->getData('rollbackUrl') ?: '');
$isProduction = !empty($this->getData('isProduction'));
$attr = static fn(string $v): string => htmlspecialchars($v, ENT_QUOTES, 'UTF-8');
?>
<style>
    .weline-release-history .wrh-alert {
        background: var(--backend-color-bg-secondary, #1e293b);
        border: 1px solid var(--backend-color-border, #334155);
        color: var(--backend-color-text, #e2e8f0);
    }
</style>

<w:backend:card class="weline-release-history">
    <w:slot:header>
        <h5 class="mb-0"><?= __('发布历史') ?></h5>
    </w:slot:header>
    <w:slot:body>
        <?php if ($current): ?>
            <div class="alert wrh-alert mb-3">
                <strong><?= __('当前版本') ?>:</strong>
                <code><?= $attr((string)($current['deploy_version'] ?? '')) ?></code>
                <span class="badge bg-secondary ms-2"><?= $attr((string)($current['git_ref_type'] ?? '')) ?></span>
                <?php if (!empty($current['git_tag'])): ?>
                    <span class="badge bg-info ms-1"><?= $attr((string)$current['git_tag']) ?></span>
                <?php endif; ?>
                <span class="text-muted ms-2"><?= date('Y-m-d H:i:s', (int)($current['deployed_at'] ?? 0)) ?></span>
            </div>
        <?php else: ?>
            <div class="alert wrh-alert mb-3"><?= __('尚未发布过') ?></div>
        <?php endif; ?>

        <if condition="$isProduction">
            <div class="alert wrh-alert mb-3"><?= __('正式站回滚前将自动整站备份。') ?></div>
        </if>

        <?php if (empty($records)): ?>
            <p class="text-muted"><?= __('暂无发布记录') ?></p>
        <?php else: ?>
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead>
                        <tr>
                            <th><?= __('时间') ?></th>
                            <th><?= __('版本') ?></th>
                            <th><?= __('类型') ?></th>
                            <th><?= __('触发') ?></th>
                            <th><?= __('范围') ?></th>
                            <th><?= __('状态') ?></th>
                            <th><?= __('耗时') ?></th>
                            <th><?= __('Commit') ?></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($records as $record): ?>
                            <?php
                            $status = (string)$record->getData('status');
                            $badgeClass = match ($status) {
                                'success' => 'bg-success',
                                'failed'  => 'bg-danger',
                                'running' => 'bg-warning text-dark',
                                default   => 'bg-secondary',
                            };
                            $startedAt = (int)$record->getData('started_at');
                            $duration  = $record->getData('duration_ms');
                            $scope = trim((string)$record->getData('project_id'));
                            if ($scope === '') {
                                $scope = trim((string)$record->getData('domain'));
                            }
                            if ($scope === '') {
                                $scope = trim((string)$record->getData('profile_key'));
                            }
                            $projectType = trim((string)$record->getData('project_type'));
                            $releaseId = (string)$record->getData('release_id');
                            $isCurrent = (int)$record->getData('is_current') === 1;
                            $canRollback = $status === 'success' && !$isCurrent;
                            ?>
                            <tr>
                                <td class="text-nowrap"><?= $startedAt ? date('Y-m-d H:i:s', $startedAt) : '-' ?></td>
                                <td>
                                    <code><?= $attr((string)$record->getData('deploy_version')) ?></code>
                                    <?php if ($isCurrent): ?>
                                        <span class="badge bg-primary ms-1"><?= __('当前') ?></span>
                                    <?php endif; ?>
                                </td>
                                <td>
                                    <?php if ((string)$record->getData('git_ref_type') === 'tag'): ?>
                                        <span class="badge bg-info"><?= __('tag') ?></span>
                                        <?php if ($record->getData('git_tag')): ?>
                                            <small class="text-muted ms-1"><?= $attr((string)$record->getData('git_tag')) ?></small>
                                        <?php endif; ?>
                                    <?php else: ?>
                                        <span class="badge bg-secondary"><?= $attr((string)$record->getData('git_ref_type')) ?></span>
                                    <?php endif; ?>
                                </td>
                                <td><?= $attr((string)$record->getData('trigger_type')) ?></td>
                                <td>
                                    <?php if ($scope !== ''): ?>
                                        <code><?= $attr($scope) ?></code>
                                        <?php if ($projectType !== ''): ?>
                                            <small class="text-muted ms-1"><?= $attr($projectType) ?></small>
                                        <?php endif; ?>
                                    <?php else: ?>
                                        <span class="text-muted"><?= __('全局') ?></span>
                                    <?php endif; ?>
                                </td>
                                <td><span class="badge <?= $badgeClass ?>"><?= __($status) ?></span></td>
                                <td class="text-nowrap"><?= $duration ? round($duration / 1000, 1) . 's' : '-' ?></td>
                                <td><code class="small"><?= $attr(substr((string)$record->getData('git_commit'), 0, 8)) ?></code></td>
                                <td class="text-end">
                                    <?php if ($canRollback): ?>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-warning"
                                                data-action="rollback"
                                                data-release-id="<?= $attr($releaseId) ?>"
                                                data-version="<?= $attr((string)$record->getData('deploy_version')) ?>">
                                            <?= __('回滚到此版本') ?>
                                        </button>
                                    <?php endif; ?>
                                </td>
                            </tr>
                            <?php if ($status === 'failed' && $record->getData('error_message')): ?>
                                <tr>
                                    <td colspan="9" class="text-danger small p-1 ps-3">
                                        <?= $attr((string)$record->getData('error_message')) ?>
                                    </td>
                                </tr>
                            <?php endif; ?>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
        <?php endif; ?>
    </w:slot:body>
</w:backend:card>

<form method="post" action="<?= $attr($rollbackUrl) ?>" id="wrh-rollback-form" class="d-none">
    <input type="hidden" name="release_id" id="wrh-release-id" value="">
    <input type="hidden" name="confirm_rollback" id="wrh-confirm-rollback" value="0">
    <input type="hidden" name="confirm_older_version" id="wrh-confirm-older" value="0">
</form>

<div class="modal fade" id="wrh-rollback-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><?= __('确认回滚') ?></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="wrh-rollback-summary"></p>
                <div class="alert alert-warning"><?= __('回滚可能导致数据迁移、配置或代码不兼容。') ?></div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="wrh-ui-confirm-rollback" value="1">
                    <label class="form-check-label" for="wrh-ui-confirm-rollback"><?= __('我确认要回滚到此版本') ?></label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="wrh-ui-confirm-older" value="1">
                    <label class="form-check-label" for="wrh-ui-confirm-older"><?= __('我确认要回滚到更旧版本') ?></label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><?= __('取消') ?></button>
                <button type="button" class="btn btn-warning" id="wrh-run-rollback" disabled><?= __('执行回滚') ?></button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    const modalEl = document.getElementById('wrh-rollback-modal');
    const modal = modalEl ? new bootstrap.Modal(modalEl) : null;
    const form = document.getElementById('wrh-rollback-form');
    const releaseIdInput = document.getElementById('wrh-release-id');
    const confirmRollbackInput = document.getElementById('wrh-confirm-rollback');
    const confirmOlderInput = document.getElementById('wrh-confirm-older');
    const uiConfirmRollback = document.getElementById('wrh-ui-confirm-rollback');
    const uiConfirmOlder = document.getElementById('wrh-ui-confirm-older');
    const runBtn = document.getElementById('wrh-run-rollback');
    const summaryEl = document.getElementById('wrh-rollback-summary');

    function syncState() {
        if (runBtn) runBtn.disabled = !(uiConfirmRollback && uiConfirmRollback.checked);
    }

    document.body.addEventListener('click', (event) => {
        const btn = event.target.closest('[data-action="rollback"]');
        if (!btn) return;
        if (releaseIdInput) releaseIdInput.value = btn.dataset.releaseId || '';
        if (summaryEl) summaryEl.textContent = '<?= $attr((string)__('回滚到版本')) ?> ' + (btn.dataset.version || '');
        if (uiConfirmRollback) uiConfirmRollback.checked = false;
        if (uiConfirmOlder) uiConfirmOlder.checked = false;
        syncState();
        if (modal) modal.show();
    });

    uiConfirmRollback?.addEventListener('change', syncState);
    runBtn?.addEventListener('click', () => {
        if (confirmRollbackInput) confirmRollbackInput.value = uiConfirmRollback && uiConfirmRollback.checked ? '1' : '0';
        if (confirmOlderInput) confirmOlderInput.value = uiConfirmOlder && uiConfirmOlder.checked ? '1' : '0';
        if (form) form.submit();
    });
})();
</script>
