<?php
/**
 * @var \Weline\Deploy\Controller\Backend\Release $this
 * @var array $records
 * @var array|null $current
 */
$records = $this->getData('records') ?: [];
$current = $this->getData('current');
?>
<w:backend:card>
    <w:slot:header>
        <h5 class="mb-0"><?= __('发布历史') ?></h5>
    </w:slot:header>
    <w:slot:body>
        <?php if ($current): ?>
            <div class="alert alert-success mb-3">
                <strong><?= __('当前版本') ?>:</strong>
                <?= htmlspecialchars($current['deploy_version'] ?? '', ENT_QUOTES, 'UTF-8') ?>
                <span class="badge bg-secondary ms-2"><?= htmlspecialchars($current['git_ref_type'] ?? '', ENT_QUOTES, 'UTF-8') ?></span>
                <?php if (!empty($current['git_tag'])): ?>
                    <span class="badge bg-info ms-1"><?= htmlspecialchars($current['git_tag'], ENT_QUOTES, 'UTF-8') ?></span>
                <?php endif; ?>
                <span class="text-muted ms-2"><?= date('Y-m-d H:i:s', $current['deployed_at'] ?? 0) ?></span>
            </div>
        <?php else: ?>
            <div class="alert alert-warning mb-3"><?= __('尚未发布过') ?></div>
        <?php endif; ?>

        <?php if (empty($records)): ?>
            <p class="text-muted"><?= __('暂无发布记录') ?></p>
        <?php else: ?>
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead>
                        <tr>
                            <th><?= __('时间') ?></th>
                            <th><?= __('版本') ?></th>
                            <th><?= __('类型') ?></th>
                            <th><?= __('触发') ?></th>
                            <th><?= __('范围') ?></th>
                            <th><?= __('状态') ?></th>
                            <th><?= __('耗时') ?></th>
                            <th><?= __('Commit') ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($records as $record): ?>
                            <?php
                            $status = (string)$record->getData('status');
                            $badgeClass = match ($status) {
                                'success' => 'bg-success',
                                'failed'  => 'bg-danger',
                                'running' => 'bg-warning text-dark',
                                default   => 'bg-secondary',
                            };
                            $startedAt = (int)$record->getData('started_at');
                            $duration  = $record->getData('duration_ms');
                            $scope = trim((string)$record->getData('project_id'));
                            if ($scope === '') {
                                $scope = trim((string)$record->getData('domain'));
                            }
                            if ($scope === '') {
                                $scope = trim((string)$record->getData('profile_key'));
                            }
                            $projectType = trim((string)$record->getData('project_type'));
                            ?>
                            <tr>
                                <td class="text-nowrap"><?= $startedAt ? date('Y-m-d H:i:s', $startedAt) : '-' ?></td>
                                <td>
                                    <code><?= htmlspecialchars((string)$record->getData('deploy_version'), ENT_QUOTES, 'UTF-8') ?></code>
                                    <?php if ((int)$record->getData('is_current') === 1): ?>
                                        <span class="badge bg-primary ms-1"><?= __('当前') ?></span>
                                    <?php endif; ?>
                                </td>
                                <td>
                                    <?php if ((string)$record->getData('git_ref_type') === 'tag'): ?>
                                        <span class="badge bg-info"><?= __('tag') ?></span>
                                        <?php if ($record->getData('git_tag')): ?>
                                            <small class="text-muted ms-1"><?= htmlspecialchars((string)$record->getData('git_tag'), ENT_QUOTES, 'UTF-8') ?></small>
                                        <?php endif; ?>
                                    <?php else: ?>
                                        <span class="badge bg-secondary"><?= __('branch') ?></span>
                                    <?php endif; ?>
                                </td>
                                <td><?= htmlspecialchars((string)$record->getData('trigger_type'), ENT_QUOTES, 'UTF-8') ?></td>
                                <td>
                                    <?php if ($scope !== ''): ?>
                                        <code><?= htmlspecialchars($scope, ENT_QUOTES, 'UTF-8') ?></code>
                                        <?php if ($projectType !== ''): ?>
                                            <small class="text-muted ms-1"><?= htmlspecialchars($projectType, ENT_QUOTES, 'UTF-8') ?></small>
                                        <?php endif; ?>
                                    <?php else: ?>
                                        <span class="text-muted"><?= __('全局') ?></span>
                                    <?php endif; ?>
                                </td>
                                <td><span class="badge <?= $badgeClass ?>"><?= __($status) ?></span></td>
                                <td class="text-nowrap"><?= $duration ? round($duration / 1000, 1) . 's' : '-' ?></td>
                                <td><code class="small"><?= htmlspecialchars(substr((string)$record->getData('git_commit'), 0, 8), ENT_QUOTES, 'UTF-8') ?></code></td>
                            </tr>
                            <?php if ($status === 'failed' && $record->getData('error_message')): ?>
                                <tr>
                                    <td colspan="8" class="text-danger small p-1 ps-3">
                                        <?= htmlspecialchars((string)$record->getData('error_message'), ENT_QUOTES, 'UTF-8') ?>
                                    </td>
                                </tr>
                            <?php endif; ?>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
        <?php endif; ?>
    </w:slot:body>
</w:backend:card>
