# Git 部署配置示例文件
#
# 复制此文件为项目根目录的 .env 文件并根据实际情况修改配置
# 此文件用于配置 Git 拉取和部署相关参数

# Git 仓库配置
GIT_REPO_URL=https://github.com/username/repository.git
GIT_BRANCH=main
GIT_USERNAME=your_username
GIT_TOKEN=your_access_token_or_password

# 部署配置
# DEPLOY_DIR 自动使用 .env 文件所在目录，无需配置
BACKUP_BEFORE_DEPLOY=true
CLEAN_BEFORE_DEPLOY=false

# Git 高级配置（可选）
# GIT_REMOTE_NAME=origin
# GIT_PULL_STRATEGY=merge
# GIT_CREDENTIAL_HELPER=cache

# ---------------------------------------------------------------------------
# 框架核心更新（php bin/w update:core -b <分支>）
# 未配置时使用公用官网仓库；配置后可使用自建或私有仓库及密钥
# ---------------------------------------------------------------------------
# 核心更新仓库地址（不配置则使用默认 Gitee 官网）
# CORE_UPDATE_REPO_URL=https://gitee.com/your-org/WelineFramework.git
# 默认分支（配置后可不带 -b 参数）
# CORE_UPDATE_BRANCH_DEFAULT=master
# 私有仓库鉴权：Token（HTTPS 时自动注入 URL，建议使用 oauth2 token）
# CORE_UPDATE_REPO_TOKEN=your_token
# 私有仓库鉴权：用户名（可选，仅用 Token 时以 oauth2 作为用户名）
# CORE_UPDATE_REPO_USERNAME=git

